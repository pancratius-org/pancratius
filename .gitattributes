# Binary content — don't try to diff or merge these as text.
*.docx binary
*.pdf  binary
*.epub binary
*.jpg  binary
*.jpeg binary
*.png  binary
*.webp binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.mp3  binary
*.mp4  binary
*.zip  binary

# Normalize line endings for text content.
*.md     text eol=lf whitespace=-blank-at-eol
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.astro  text eol=lf
*.py     text eol=lf

# GitHub Linguist: keep repository language stats focused on product source.
# These trees intentionally contain generated outputs, bad/good source fixtures,
# and retired research scripts; they should not imply production JavaScript.
audit/fixtures/** linguist-vendored
docs/scratchpad/** linguist-documentation
