# Astro build output — fully transient.
dist/
.astro/

# Local scratch output from conversion/audit scripts.
.cache/

# Transient source archive/prototype tree. Production content lives under
# content/, data/, public/, scripts/, and src/.
legacy/

# Sitemap pairing source: regenerated by scripts/build_slug_map.py from content/.
data/slug-map.json

# Bulk-archive manifest: regenerated by scripts/build_bulk_archives.py at build.
data/bulk-archives.json

# Web-public copies of the conceptosphere graph payloads. The source artefacts
# live in `data/` (committed); these copies are emitted by
# scripts/build_copy_graph_payloads.py before every build/dev/check.
public/data/pancratius-concepts-graph.json
public/data/pancratius-books-graph.json

# Local embedding cache for the conceptosphere pipeline — multi-GB once populated.
data/conceptosphere-embed-cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp

# Test output
test-results/
playwright-report/

# Python (uv) envs for scripts/
.venv/
__pycache__/
*.pyc
