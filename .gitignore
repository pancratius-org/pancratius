# Astro build output — fully transient.
dist/
.astro/

# Local scratch output from corpus tooling and audits.
.cache/

# Transient source archive/prototype tree. Production content lives under
# src/content/, data/, public/, pancratius/, build/, audit/, tests/, and src/.
legacy/

# Sitemap pairing source: regenerated by build/slug-map.ts from src/content/.
data/slug-map.json

# Bulk-archive manifest: regenerated by build/bulk-archives.ts at build.
data/bulk-archives.json

# Per-import provenance manifests (timestamps, source hashes): volatile, written
# by pancratius/import_docx.py outside the committed bundle so re-import stays
# byte-identical. Never committed.
data/imports/

# Web-public copies of the conceptosphere graph payloads. The source artefacts
# live in `data/` (committed); these copies are emitted by
# build/copy-graph-payloads.ts before every build/dev/check.
public/data/pancratius-concepts-graph.json
public/data/pancratius-books-graph.json

# Local copy of the last built Pagefind index for `astro dev`.
public/pagefind/

# Local embedding cache for the conceptosphere pipeline — multi-GB once populated.
data/conceptosphere-embed-cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.claude/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp

# Test output
test-results/
playwright-report/

# Python (uv) envs for pancratius/
.venv/
__pycache__/
*.pyc
