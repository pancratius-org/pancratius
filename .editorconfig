root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown: preserve trailing whitespace so the two-space line-break syntax survives.
[*.md]
trim_trailing_whitespace = false

# Python: 4-space indent per PEP 8.
[*.py]
indent_size = 4

# Makefiles use real tabs.
[Makefile]
indent_style = tab
