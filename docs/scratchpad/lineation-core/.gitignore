# Derived / transient — never source of truth.
# Records are rebuilt fail-loud from the committed DOCX (`build_records`); the irreplaceable
# annotation truth lives in `annotations/` (committed), NOT here.
_artifacts/
_teacher/
.venv/
__pycache__/
.pytest_cache/
*.egg-info/

# a study's derived reply RESUME cache — regenerable by re-calling the panel; the durable
# scorecard/report/manifest beside it ARE committed. Commit a replies.jsonl only when a claim needs
# it to reproduce.
src/lineation_core/evaluation/experiments/*/replies.jsonl
