{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "astro.config.ts",
    "src/**/*",
    "src/content/**/*.md"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "legacy",
    "design",
    "scripts",
    "tests",
    "public"
  ]
}
