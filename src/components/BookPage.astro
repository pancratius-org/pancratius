---
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import BookCover from "@/components/BookCover.astro";
import Colophon from "@/components/Colophon.astro";
import SimilarPair from "@/components/SimilarPair.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import WorkDownloadActions from "@/components/WorkDownloadActions.astro";
import Share from "@/components/Share.astro";
import BackLink from "@/components/BackLink.astro";
import TagRow from "@/components/TagRow.astro";
import LeadParagraph from "@/components/LeadParagraph.astro";
import Pager from "@/components/Pager.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, workUrl } from "@/lib/i18n";
import { neighbors } from "@/lib/neighbors";
import { hasToc } from "@/lib/toc";
import { bookPageCopy } from "@/lib/i18n/copy";
import { coverAbsoluteUrl } from "@/lib/covers";
import { seoForWork } from "@/lib/seo";
import {
  entryForAuthoredLocale,
  getPairsByKind,
  localizedWorkPairs,
  resolveCrossRefs,
  workTags,
  type WorkPair,
} from "@/lib/works";

interface Props {
  pair: WorkPair;
  locale: Locale;
}

const { pair, locale } = Astro.props;
// Existence: this page only exists in `locale` if the locale was authored.
const entry = entryForAuthoredLocale(pair, locale);
if (!entry) {
  throw new Error(`BookPage: no ${locale} entry for book #${pair.number}`);
}

const copy = bookPageCopy[locale];
const { Content, headings } = await render(entry);
const coverUrl = coverAbsoluteUrl(pair, locale);
const seo = seoForWork({
  pair,
  locale,
  ...(coverUrl === null ? {} : { coverUrl }),
});
const crossRefs = await resolveCrossRefs(entry, locale);
const tags = workTags(entry);
const useToc = hasToc(headings);
const backHref = kindIndexUrl("book", locale);

const allBookPairs = await getPairsByKind("book");
// Existence: the pager only walks books that exist in the current locale.
const pagerPairs = localizedWorkPairs(allBookPairs, locale);
const { prev, next } = neighbors(pagerPairs, pair.number);
const number = String(pair.number).padStart(2, "0");
const pad = (n: number) => String(n).padStart(2, "0");
---
<Base {locale} {seo}>
  <article class="l-canvas l-canvas--wide l-page-block book-page">
    <BackLink href={backHref} label={copy.back(pagerPairs.length)} />

    <header class="book-page__masthead">
      <p class="book-page__meta kicker">{copy.meta}</p>

      <div class="book-page__cover">
        <BookCover {pair} {locale} alt={copy.coverAlt(entry.data.title)} loading="eager" />
      </div>
      <div class="book-page__body">
        <div class="book-page__num" aria-hidden="true">{number}</div>
        <h1 class="book-page__title" id="bp-title">
          <span class="sr-only">{copy.srPrefix(number)}</span>{entry.data.title}
        </h1>
        <p class="book-page__description">{entry.data.description}</p>
        <TagRow {tags} />
        <div class="book-page__actions">
          <WorkDownloadActions {pair} {entry} {locale} />
          <Share {locale} />
        </div>
      </div>
    </header>

    <div class:list={["book-page__layout", { "book-page__layout--toc": useToc }]}>
      {useToc && <TableOfContents {headings} {locale} />}
      <div
        class="prose"
        data-pagefind-body
        data-pagefind-meta={`title:${entry.data.title}`}
        data-leadable
      >
        <Content />
      </div>
    </div>

    <LeadParagraph />

    <Colophon {pair} {locale} />

    <Pager
      ariaLabel={copy.pagerAria}
      prev={prev && { href: workUrl("book", prev.entry.data.slug, locale), label: pad(prev.pair.number), title: prev.entry.data.title }}
      next={next && { href: workUrl("book", next.entry.data.slug, locale), label: pad(next.pair.number), title: next.entry.data.title }}
    />

    <SimilarPair {entry} {locale} {crossRefs} />
  </article>
</Base>

<style>
  .book-page__masthead {
    display: grid;
    grid-template-columns: 220px 1fr;
    grid-template-areas:
      "meta meta"
      "cover body";
    column-gap: 2.5rem;
    row-gap: 1.4rem;
    align-items: start;
    margin-bottom: 3rem;
    padding-bottom: 2.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .book-page__meta { margin: 0; }
  .book-page__masthead .book-page__meta  { grid-area: meta;  }
  .book-page__masthead .book-page__cover { grid-area: cover; }
  .book-page__masthead .book-page__body  { grid-area: body;  }
  @media (max-width: 720px) {
    .book-page__masthead {
      grid-template-columns: 1fr;
      grid-template-areas:
        "meta"
        "cover"
        "body";
      row-gap: 1.25rem;
    }
    .book-page__masthead .book-page__cover { max-width: 200px; }
  }

  .book-page__cover :global(.bcv) {
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.4), 0 50px 80px -40px rgba(0, 0, 0, 0.7);
  }
  :global([data-theme="light"]) .book-page__cover :global(.bcv) {
    box-shadow: 0 1px 0 rgba(20, 17, 13, 0.06), 0 40px 70px -38px rgba(60, 45, 20, 0.40);
  }

  .book-page__num {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: clamp(3.8rem, 7vw, 6rem);
    color: var(--accent);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
    font-feature-settings: "onum" 1, "lnum" 0, "kern" 1;
  }
  .book-page__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: -0.018em;
    margin: 0 0 0.95rem;
    text-wrap: balance;
    font-feature-settings: "lnum" 0, "onum" 1, "kern" 1;
  }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
  .book-page__description {
    margin: 0 0 1.15rem;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.6;
  }

  .book-page__actions {
    margin: 0.9rem 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5em 1.1rem;
  }
  .book-page__body :global(.work-actions) {
    margin: 0;
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--ink-soft);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    align-items: baseline;
  }
  .book-page__body :global(.work-actions a) {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .book-page__body :global(.work-actions a:hover) { color: var(--accent); }
  .book-page__body :global(.work-actions__label) {
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 11px;
    margin-right: 0.2em;
  }
  .book-page__body :global(.work-actions__sep) { color: var(--rule-2); }

  .book-page__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
  }
  @media (min-width: 1100px) {
    .book-page__layout--toc {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }
    .book-page:has(.book-page__layout--toc) > :global(.colophon),
    .book-page:has(.book-page__layout--toc) > :global(.pager),
    .book-page:has(.book-page__layout--toc) > :global(.sim) {
      margin-left: calc(220px + 3rem);
    }
  }
</style>
