---
/*
 * Verse — the lineation-preserving body register.
 *
 * The second of the two body renderers (the other is <Prose>). Wraps a
 * rendered Markdown body in `<div class="prose prose--verse">`, the whole-body
 * verse register: left-aligned, no drop cap, stanza paragraph-gap rhythm.
 * Lineation is CommonMark two-trailing-space hard breaks (rendered as `<br>`),
 * the one corpus-wide encoding — the CSS does NOT use `white-space: pre-line`,
 * so it never infers a break from a raw newline. That CSS lives in
 * `src/styles/reading/` under the shared `.prose--verse` / `.prose--poem`
 * rules.
 *
 * Dumb by design: no slug logic, no page-specific branching. The component
 * identity *is* the register — there is no `register` prop. The mission page
 * adds `prose--manifesto` for its lede-opener and
 * trailing-signature gestures. Project verse subpages can add `prose--project`
 * without inheriting those mission-only accents.
 *
 * Usage — render the page's `<Content/>` into the default slot:
 *
 *   const { Content } = await render(page);
 *   <Verse><Content /></Verse>
 *
 * `class` is appended after the base register classes for any page-local
 * modifier. A poem/work page COULD adopt this later (it already shares the
 * `.prose--poem` lineation encoding) — this component is deliberately free of
 * any page identity so that move is a one-line swap.
 */

interface Props {
  /** Extra register class(es) appended after the base verse classes. */
  class?: string;
}

const { class: extraClass } = Astro.props;
---
<div class:list={["prose", "prose--verse", extraClass]}>
  <slot />
</div>
