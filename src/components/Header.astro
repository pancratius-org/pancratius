---
import type { Locale, RoutedKind } from "@/lib/i18n";
import { HEADER_NAV, homeUrl, localizePath } from "@/lib/i18n";
import { chromeCopy } from "@/lib/i18n/copy";
import { getPage } from "@/lib/pages";
import { hasMessagesInLocale } from "@/lib/messages";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: Partial<Record<Locale, string>>;
}

const { locale, currentPath, alternates } = Astro.props;
const homeHref = homeUrl(locale);
const currentRoute = currentPath;
const copy = chromeCopy[locale];

// Resolvers for `kindGate`: a routed kind shows in the nav only where it has
// authored content in this locale. Each routed kind that can gate registers its
// "is anything authored here" check; kinds absent from the map never gate.
const KIND_GATE: Partial<Record<RoutedKind, (locale: Locale) => Promise<boolean>>> = {
  message: hasMessagesInLocale,
};

// Drop nav items whose backing content isn't authored in the current locale:
// `pageSlug` items need their page, `kindGate` items need ≥1 entry of that kind.
const navItems = await Promise.all(
  HEADER_NAV.map(async item => {
    if (item.pageSlug) {
      const page = await getPage(item.pageSlug, locale);
      if (!page) return null;
    }
    if (item.kindGate && !(await KIND_GATE[item.kindGate]?.(locale) ?? true)) {
      return null;
    }
    return item;
  }),
).then(items => items.filter((x): x is typeof HEADER_NAV[number] => x !== null));

function isCurrent(path: string): boolean {
  const localizedPath = localizePath(path, locale);
  return currentRoute === localizedPath || currentRoute.startsWith(localizedPath);
}
---
<header class="rail" role="banner">
  <a class="rail__mark" href={homeHref}>
    <b>{copy.brand}</b>
    <span>{copy.tagline}</span>
  </a>

  <nav class="rail__nav" aria-label={copy.navAria}>
    {navItems.map(item => (
      <a
        href={localizePath(item.path, locale)}
        aria-current={isCurrent(item.path) ? "page" : undefined}
      >
        {item.label[locale]}
      </a>
    ))}
  </nav>

  <div class="rail__right">
    <LanguageSwitcher currentLocale={locale} {alternates} />
    <button
      class="icon-btn"
      id="themeBtn"
      type="button"
      aria-label={copy.themeAria}
    >
      <svg class="moon" viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M13.2 9.8A5.5 5.5 0 1 1 6.2 2.8a5.5 5.5 0 0 0 7 7Z" />
      </svg>
      <svg class="sun" viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="8" cy="8" r="3" />
        <path d="M8 1.5v1.6M8 12.9v1.6M1.5 8h1.6M12.9 8h1.6M3.4 3.4l1.1 1.1M11.5 11.5l1.1 1.1M3.4 12.6l1.1-1.1M11.5 4.5l1.1-1.1" />
      </svg>
    </button>
    <button
      class="rail__menu-btn"
      id="menuBtn"
      type="button"
      aria-expanded="false"
      aria-controls="menuPanel"
      aria-label={copy.menuOpenAria}
      data-open-label={copy.menuOpenAria}
      data-close-label={copy.menuCloseAria}
    >
      <span class="rail__menu-rules" aria-hidden="true"><i></i><i></i></span>
      <span class="rail__menu-text">{copy.menuLabel}</span>
    </button>
  </div>
</header>

<div class="menu" id="menuPanel" data-state="closed">
  <div class="menu__backdrop" id="menuBackdrop"></div>
  <nav class="menu__sheet" aria-label={copy.menuPanelAria}>
    <p class="menu__kicker">{copy.navAria}</p>
    <ul class="menu__list">
      {navItems.map(item => (
        <li>
          <a
            class="menu__link"
            href={localizePath(item.path, locale)}
            aria-current={isCurrent(item.path) ? "page" : undefined}
          >
            {item.label[locale]}
          </a>
        </li>
      ))}
    </ul>
    <div class="menu__foot">
      <LanguageSwitcher currentLocale={locale} {alternates} />
    </div>
  </nav>
</div>

<script>
  // Theme toggle. Reads/writes localStorage; mirrors what ThemeInit.astro
  // does at startup. Decoupled so the toggle still works if ThemeInit didn't
  // run for some reason.
  const btn = document.getElementById("themeBtn");
  if (btn) {
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try { localStorage.setItem("pncr-theme", next); } catch (_) { /* ignore */ }
    });
  }
</script>

<script>
  // Mobile menu sheet. Toggles the slide-down panel and owns its accessibility:
  // aria-expanded + label swap, body scroll lock, focus moved into the panel on
  // open and restored to the button on close, Esc and outside-click to dismiss,
  // and a focus trap so Tab cycles within the open sheet.
  const menuBtn = document.getElementById("menuBtn");
  const panel = document.getElementById("menuPanel");
  const backdrop = document.getElementById("menuBackdrop");
  const sheet = panel?.querySelector<HTMLElement>(".menu__sheet");

  if (menuBtn && panel && backdrop && sheet) {
    const openLabel = menuBtn.dataset.openLabel ?? "";
    const closeLabel = menuBtn.dataset.closeLabel ?? "";
    const focusableSelector =
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

    const isOpen = () => panel.dataset.state === "open";

    const focusable = (): HTMLElement[] =>
      Array.from(sheet.querySelectorAll<HTMLElement>(focusableSelector))
        .filter(el => el.offsetParent !== null);

    const onKeydown = (event: KeyboardEvent) => {
      if (event.key === "Escape") {
        event.preventDefault();
        close();
        return;
      }
      if (event.key !== "Tab") return;
      const items = focusable();
      const first = items[0];
      const last = items[items.length - 1];
      if (!first || !last) return;
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    const open = () => {
      if (isOpen()) return;
      panel.dataset.state = "open";
      menuBtn.setAttribute("aria-expanded", "true");
      menuBtn.setAttribute("aria-label", closeLabel);
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", onKeydown);
      focusable()[0]?.focus();
    };

    const close = () => {
      if (!isOpen()) return;
      panel.dataset.state = "closed";
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", openLabel);
      document.body.style.overflow = "";
      document.removeEventListener("keydown", onKeydown);
      menuBtn.focus();
    };

    menuBtn.addEventListener("click", () => (isOpen() ? close() : open()));
    backdrop.addEventListener("click", close);
    // A section link navigates away; close first so state is clean on return.
    sheet.querySelectorAll("a[href]").forEach(link =>
      link.addEventListener("click", close),
    );

    // If the viewport grows past the mobile breakpoint while open, the sheet is
    // hidden by CSS — tear down the locked state so the page isn't stuck.
    const desktop = window.matchMedia("(min-width: 721px)");
    desktop.addEventListener("change", e => {
      if (e.matches && isOpen()) close();
    });
  }
</script>

<style>
  .rail {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 0.95rem var(--rail);
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    font-family: var(--sans);
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .rail__mark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.65rem;
    font-family: var(--serif);
    color: inherit;
    text-decoration: none;
  }
  .rail__mark b {
    font-weight: 500;
    font-size: 17px;
    font-variant: small-caps;
    letter-spacing: 0.08em;
    color: var(--ink);
  }
  .rail__mark span {
    color: var(--ink-mute);
    font-style: italic;
    font-size: 13.5px;
  }
  .rail__mark:hover b { color: var(--accent); }

  .rail__nav {
    display: flex;
    gap: 1.4rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .rail__nav a {
    color: var(--ink-soft);
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease);
    text-decoration: none;
  }
  .rail__nav a:hover { color: var(--ink); border-bottom-color: var(--accent); }
  .rail__nav a[aria-current="page"] {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .rail__right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Menu toggle: a quiet hand-set label, not a glyph button. Two short rules
     stack beside it as a restrained mark. Hidden above the mobile breakpoint. */
  .rail__menu-btn {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 1px;
    color: var(--ink-soft);
    height: 32px;
    padding: 0 0.7rem;
    cursor: pointer;
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .rail__menu-btn:hover { color: var(--accent); border-color: var(--accent-soft); }
  .rail__menu-rules {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    width: 14px;
  }
  .rail__menu-rules i {
    display: block;
    height: 1px;
    background: currentColor;
  }
  .rail__menu-rules i:first-child { width: 14px; }
  .rail__menu-rules i:last-child  { width: 9px; }

  .icon-btn {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 1px;
    cursor: pointer;
    padding: 0;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .icon-btn:hover { color: var(--accent); border-color: var(--accent-soft); }
  .icon-btn svg { width: 14px; height: 14px; display: block; }
  .icon-btn .moon { display: none; }
  .icon-btn .sun  { display: block; }
  :global([data-theme="light"]) .icon-btn .moon { display: block; }
  :global([data-theme="light"]) .icon-btn .sun  { display: none; }

  /* The slide-down sheet. Lives above the page but tucks under the sticky rail
     (rail is z-index 50; the sheet sits just below so the bar stays legible).
     Hidden entirely on desktop, where the inline nav row owns navigation. */
  .menu { display: none; }

  @media (max-width: 720px) {
    .rail {
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
    }
    /* On mobile the inline nav row and the bar's language switch step aside;
       the section list and the language switch move into the sheet. */
    .rail__nav { display: none; }
    .rail__right > :global(.lang) { display: none; }
    .rail__menu-btn { display: inline-flex; }

    .menu {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 40;
      visibility: hidden;
    }
    .menu[data-state="open"] { visibility: visible; }

    .menu__backdrop {
      position: absolute;
      inset: 0;
      background: color-mix(in srgb, var(--bg) 62%, transparent);
      backdrop-filter: saturate(120%) blur(6px);
      -webkit-backdrop-filter: saturate(120%) blur(6px);
      opacity: 0;
      transition: opacity 0.24s var(--ease);
    }
    .menu[data-state="open"] .menu__backdrop { opacity: 1; }

    .menu__sheet {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      /* Clear the sticky rail so the sheet reads as dropping from under it. */
      padding: calc(0.95rem + 32px + 1.4rem) var(--rail) calc(var(--rail) + 0.5rem);
      background: color-mix(in srgb, var(--bg-rise) 96%, transparent);
      backdrop-filter: saturate(140%) blur(12px);
      -webkit-backdrop-filter: saturate(140%) blur(12px);
      border-bottom: 1px solid var(--rule-2);
      box-shadow: var(--paper-shadow);
      transform: translateY(-100%);
      transition: transform 0.28s var(--ease);
      max-height: 100dvh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }
    .menu[data-state="open"] .menu__sheet { transform: translateY(0); }

    .menu__kicker {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin: 0 0 1.1rem;
    }
    .menu__kicker::before {
      content: "";
      display: inline-block;
      width: 22px;
      height: 1px;
      background: var(--accent);
      vertical-align: middle;
      margin-right: 0.8rem;
    }

    .menu__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
    }
    .menu__list li + li { border-top: 1px solid var(--rule); }
    .menu__link {
      display: block;
      padding: 0.9rem 0;
      font-family: var(--serif);
      font-size: 1.15rem;
      letter-spacing: 0.005em;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.18s var(--ease);
    }
    .menu__link:hover { color: var(--ink); }
    .menu__link[aria-current="page"] {
      color: var(--ink);
      position: relative;
      padding-left: 0.95rem;
    }
    .menu__link[aria-current="page"]::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 1.1em;
      background: var(--accent);
    }

    .menu__foot {
      margin-top: 1.6rem;
      padding-top: 1.3rem;
      border-top: 1px solid var(--rule);
    }
  }

  @media (max-width: 720px) and (prefers-reduced-motion: reduce) {
    .menu__backdrop,
    .menu__sheet { transition: none; }
  }
</style>
