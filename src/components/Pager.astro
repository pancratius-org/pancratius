---
// Reading-flow prev/next at the foot of a catalogued detail page (books,
// videos). Number + title, editorial register. Messages keep their own
// date-based pager; both resolve neighbours through `lib/neighbors.ts`.
interface PagerItem {
  href: string;
  /** Catalogue number, already zero-padded by the caller. */
  label: string;
  title: string;
}

interface Props {
  prev: PagerItem | null;
  next: PagerItem | null;
  ariaLabel: string;
}

const { prev, next, ariaLabel } = Astro.props;
---
{(prev || next) && (
  <nav class="pager" aria-label={ariaLabel}>
    <div class="pager__slot">
      {prev && (
        <a class="pager__link pager__link--prev" href={prev.href}>
          <span class="pager__arrow" aria-hidden="true">←</span>
          <span class="pager__num">{prev.label}</span>
          <span class="pager__title">{prev.title}</span>
        </a>
      )}
    </div>
    <div class="pager__slot pager__slot--next">
      {next && (
        <a class="pager__link pager__link--next" href={next.href}>
          <span class="pager__num">{next.label}</span>
          <span class="pager__title">{next.title}</span>
          <span class="pager__arrow" aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </nav>
)}

<style>
  .pager {
    margin: 3rem 0 0;
    padding: 1.6rem 0 0;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    font-family: var(--sans);
    font-size: 12.5px;
    line-height: 1.4;
  }
  .pager__slot--next { justify-self: end; text-align: right; }
  .pager__link {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 0.6rem;
    align-items: baseline;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.4rem 0;
  }
  .pager__link--next { grid-template-columns: 1fr auto auto; }
  .pager__link:hover { color: var(--accent); }
  .pager__link:hover .pager__title { color: var(--accent); }
  .pager__arrow { color: var(--ink-mute); }
  .pager__num {
    font-variant-numeric: oldstyle-nums proportional-nums;
    color: var(--ink-mute);
    letter-spacing: 0.12em;
  }
  .pager__title {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .pager { grid-template-columns: 1fr; gap: 1rem; }
    .pager__slot--next { justify-self: start; text-align: left; }
  }
</style>
