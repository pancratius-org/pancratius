---
/*
 * <ProjectHero> — the project landing masthead.
 *
 * Eyebrow (project label) · title · tagline · cover, in the site's masthead
 * register (shared serif title, accent eyebrow). No decoration: the masthead
 * serves the reading and sits on the site background like every page.
 *
 * The cover asset is resolved by the caller (ProjectPage) and passed in, so
 * cover resolution stays in one place.
 */

import ResponsiveCoverImage from "@/components/ResponsiveCoverImage.astro";
import type { Locale } from "@/lib/i18n";
import { projectPageCopy } from "@/lib/i18n/copy";
import type { CoverAsset } from "@/lib/cover-assets";

interface Props {
  eyebrow:  string;
  title:    string;
  tagline?: string;
  cover?:   CoverAsset;
  number:   number;
  locale:   Locale;
}

const { eyebrow, title, tagline, cover, number, locale } = Astro.props;
const copy = projectPageCopy[locale];
---
<header class="hero">
  <div class="hero__inner">
    <div class="hero__text l-measure l-measure--start">
      <p class="hero__eyebrow">{eyebrow}</p>
      <h1 class="hero__title">{title}</h1>
      {tagline && <p class="hero__tagline">{tagline}</p>}
    </div>
    <div class="hero__cover">
      {cover ? (
        <ResponsiveCoverImage
          class="hero__cover-img"
          src={cover}
          alt={copy.coverAlt(title)}
          widths={[180, 240, 320, 460]}
          sizes="(max-width: 760px) 190px, 230px"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <div class="hero__cover-empty" aria-hidden="true">
          <span>{String(number).padStart(2, "0")}</span>
        </div>
      )}
    </div>
  </div>
</header>

<style>
  .hero {
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    border-bottom: 1px solid var(--rule);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(150px, 22vw, 230px);
    column-gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  @media (max-width: 760px) {
    .hero__inner {
      grid-template-columns: 1fr;
      row-gap: 1.8rem;
    }
    .hero__cover { order: -1; max-width: 190px; }
  }

  .hero__text { min-width: 0; }
  .hero__eyebrow {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.1rem;
    display: inline-block;
    position: relative;
    padding-left: 2.6rem;
  }
  .hero__eyebrow::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }
  .hero__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.6rem, 6.4vw, 4.4rem);
    line-height: 1.0;
    letter-spacing: -0.022em;
    color: var(--ink);
    margin: 0 0 1.2rem;
    text-wrap: balance;
    font-feature-settings: "lnum" 0, "onum" 1, "kern" 1;
  }
  .hero__tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    text-wrap: pretty;
  }

  .hero__cover {
    aspect-ratio: 2 / 3;
    border: 1px solid var(--rule);
    overflow: hidden;
    background: var(--bg-rise);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.25),
      0 30px 60px -34px rgba(0, 0, 0, 0.6);
  }
  .hero__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero__cover-empty {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
  }
  .hero__cover-empty span {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: 2.4rem;
    color: var(--ink-mute);
  }
</style>
