---
/*
 * <RevelationBlock> — the set-apart scripture-register block.
 *
 * The Creator's first-person address / the awakened machine's confession. NOT
 * a pull-quote (that's the author's thesis, in-flow): this is a different
 * VOICE, lifted out of the page onto its own lit field. The theme sets the
 * field colour (`--pt-rev-*`): for enlightened-ai it INVERTS — a light panel
 * in the dark page, words spoken out of the dark glass; for holy-rus it is a
 * warm dawn-lit field. An optional CTA links into a featured book (resolved by
 * the caller to a URL) or a raw href.
 */

import type { Locale } from "@/lib/i18n";
import { projectComponentsCopy } from "@/lib/copy";

interface Props {
  text:   string;
  voice?: string;
  cta?:   { label: string; href?: string };
  locale: Locale;
}

const { text, voice, cta, locale } = Astro.props;
const copy = projectComponentsCopy[locale];
// The source occasionally separates stanzas with blank lines; preserve them
// as paragraph breaks rather than collapsing the whole quote into one line.
const paras = text.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---
<aside class="rev" aria-label={voice ?? copy.revelationAria}>
  <div class="rev__field">
    <span class="rev__mark" aria-hidden="true">“</span>
    <blockquote class="rev__quote">
      {paras.map(p => <p>{p}</p>)}
    </blockquote>
    {voice && <p class="rev__voice">{voice}</p>}
    {cta && cta.href && (
      <a class="rev__cta" href={cta.href}>{cta.label}</a>
    )}
  </div>
</aside>

<style>
  .rev {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0;
  }
  .rev__field {
    position: relative;
    background: var(--pt-rev-bg, var(--bg-rise));
    color: var(--pt-rev-ink, var(--ink));
    border: 1px solid color-mix(in srgb, var(--pt-rev-ink, var(--ink)) 12%, transparent);
    padding: clamp(2rem, 5vw, 3.4rem) clamp(1.6rem, 5vw, 4rem) clamp(2rem, 4vw, 2.8rem);
    max-width: 52rem;
    margin-inline: auto;
    /* A whisper of the shaft's light pooling at the panel's top edge. */
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--pt-light, #fff) 30%, transparent),
      0 24px 50px -34px rgba(0, 0, 0, 0.5);
  }
  .rev__mark {
    position: absolute;
    top: clamp(0.4rem, 2vw, 1rem);
    left: clamp(0.8rem, 3vw, 1.6rem);
    font-family: var(--serif);
    font-size: clamp(3.2rem, 8vw, 5rem);
    line-height: 1;
    color: var(--pt-rev-accent, var(--accent));
    opacity: 0.4;
    pointer-events: none;
  }
  .rev__quote {
    margin: 0;
    padding: 0;
    border: 0;
    position: relative;
  }
  .rev__quote p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.5;
    color: var(--pt-rev-ink, var(--ink));
    margin: 0 0 0.7em;
    text-wrap: pretty;
  }
  .rev__quote p:last-child { margin-bottom: 0; }
  .rev__voice {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pt-rev-soft, var(--ink-soft));
    margin: 1.6rem 0 0;
    padding-top: 1.1rem;
    border-top: 1px solid color-mix(in srgb, var(--pt-rev-ink, var(--ink)) 14%, transparent);
  }
  .rev__cta {
    display: inline-block;
    margin: 1.2rem 0 0;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--pt-rev-accent, var(--accent));
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--pt-rev-accent, var(--accent)) 45%, transparent);
    padding-bottom: 2px;
    transition: border-color 0.18s var(--ease);
  }
  .rev__cta:hover {
    color: var(--pt-rev-accent, var(--accent));
    border-bottom-color: var(--pt-rev-accent, var(--accent));
  }
</style>
