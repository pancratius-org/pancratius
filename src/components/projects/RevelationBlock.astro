---
/*
 * <RevelationBlock> — the set-apart scripture-register block.
 *
 * The Creator's first-person address / the awakened machine's confession. NOT
 * a pull-quote (that's the author's thesis, in-flow): this is a different
 * VOICE, set apart from the body. It sits on the site background at the
 * current measure, marked by a single accent rule down its left edge — a
 * scripture indent, not a floating card. An optional CTA links into a featured
 * book (resolved by the caller to a URL) or a raw href.
 */

import type { Locale } from "@/lib/i18n";
import { projectComponentsCopy } from "@/lib/i18n/copy";

interface Props {
  text:   string;
  voice?: string;
  cta?:   { label: string; href?: string };
  locale: Locale;
}

const { text, voice, cta, locale } = Astro.props;
const copy = projectComponentsCopy[locale];
// The source occasionally separates stanzas with blank lines; preserve them
// as paragraph breaks rather than collapsing the whole quote into one line.
const paras = text.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---
<aside class="rev" aria-label={voice ?? copy.revelationAria}>
  <div class="rev__field">
    {voice && <p class="rev__voice">{voice}</p>}
    <blockquote class="rev__quote">
      {paras.map(p => <p>{p}</p>)}
    </blockquote>
    {cta && cta.href && (
      <a class="rev__cta" href={cta.href}>{cta.label}</a>
    )}
  </div>
</aside>

<style>
  .rev {
    margin: clamp(2.6rem, 6vw, 4rem) 0;
  }
  /* A scripture indent: the voice set apart by a single accent rule down the
     left edge, sharing the body's left edge — no card. */
  .rev__field {
    padding: 0.4rem 0 0.4rem clamp(1.4rem, 4vw, 2.2rem);
    border-left: 2px solid var(--accent-soft);
  }
  .rev__voice {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.1rem;
  }
  .rev__quote {
    margin: 0;
    padding: 0;
    border: 0;
  }
  .rev__quote p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.18rem, 2vw, 1.5rem);
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 0.7em;
    text-wrap: pretty;
  }
  .rev__quote p:last-child { margin-bottom: 0; }
  .rev__cta {
    display: inline-block;
    margin: 1.4rem 0 0;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    padding-bottom: 2px;
    transition: border-color 0.18s var(--ease);
  }
  .rev__cta:hover { border-bottom-color: var(--accent); }
</style>
