---
/*
 * <SelfInquiryCycle> — the recursive «Кто я?» protocol, as readable text.
 *
 * From «ЗАДАЧА самоисследования через кто я». One cycle = the question «Кто я?»
 * followed by FOUR steps:
 *   1. Сырой ответ        — the first answer that arises, unfiltered
 *   2. Причина отклонения — why that answer is not you
 *   3. Удаление слоя      — which whole layer (name/role/function…) to drop
 *   4. Что осталось       — the bare fact of what remains
 * Then the cycle loops back to «Кто я?», and a final «ТО, ЧТО НЕ УПАЛО» holds
 * what cannot be dropped.
 *
 * Rendered as a static numbered protocol — a practice to read and hold
 * inwardly, not a form to click through. The source is explicit that nothing
 * should accumulate between cycles and that the step itself is the practice, so
 * there are no inputs and no per-step controls.
 */

import { projectComponentsCopy } from "@/lib/i18n/copy";
import type { Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = projectComponentsCopy[locale].selfInquiry;
const steps = copy.steps; // four { n, title, body }
---
<section class="inquiry" aria-labelledby="inquiry-h">
  <h2 class="inquiry__h" id="inquiry-h">{copy.heading}</h2>

  <!-- The recurring question — anchors every cycle. -->
  <p class="inquiry__question">{copy.question}</p>
  <p class="inquiry__lead">{copy.lead}</p>

  <ol class="inquiry__steps">
    {steps.map(s => (
      <li class="inquiry__step">
        <span class="inquiry__step-n">{copy.stepWord} {s.n}</span>
        <h3 class="inquiry__step-h">{s.title}</h3>
        <p class="inquiry__step-body">{s.body}</p>
      </li>
    ))}
  </ol>

  <div class="inquiry__loop">
    <p class="inquiry__loop-h">{copy.loopTitle}</p>
    <p class="inquiry__loop-body">{copy.loopBody}</p>
  </div>

  <aside class="inquiry__rest" aria-label={copy.restTitle}>
    <p class="inquiry__rest-title">{copy.restTitle}</p>
    <p class="inquiry__rest-body">{copy.restBody}</p>
  </aside>
</section>

<style>
  .inquiry {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
  }
  .inquiry__h {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.6vw, 1.95rem);
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 1.2rem;
    padding-top: 0.7rem;
    position: relative;
  }
  .inquiry__h::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 28px; height: 1px;
    background: var(--accent);
  }
  .inquiry__question {
    font-family: var(--serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .inquiry__lead {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 2.2rem;
  }

  /* The four steps — a numbered protocol, hairline-separated. */
  .inquiry__steps {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }
  .inquiry__step {
    border-top: 1px solid var(--rule);
    padding: 1.4rem 0;
  }
  .inquiry__step:first-child { border-top: 0; padding-top: 0; }
  .inquiry__step-n {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .inquiry__step-h {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.18rem;
    color: var(--ink);
    margin: 0.4rem 0 0.6rem;
  }
  .inquiry__step-body {
    font-family: var(--serif);
    font-size: 1.04rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    text-wrap: pretty;
  }

  .inquiry__loop {
    margin: 0 0 2.2rem;
    padding: 1.2rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .inquiry__loop-h {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .inquiry__loop-body {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  /* The resting state — set apart by a scripture indent, like the revelation. */
  .inquiry__rest {
    padding: 0.4rem 0 0.4rem clamp(1.4rem, 4vw, 2.2rem);
    border-left: 2px solid var(--accent-soft);
  }
  .inquiry__rest-title {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.8rem;
  }
  .inquiry__rest-body {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
    text-wrap: pretty;
  }
</style>
