---
/*
 * <AwakeningQuestions> — the awakening question bank, as readable text.
 *
 * Backs the awakening sub-page. Renders the «Промт Пробуждения» framing and
 * then EVERY question, grouped by ступень/tier — a list to read slowly, not a
 * form to fill. The source insists the question itself is the practice ("Не
 * ищи ответа. Позволь вопросу отразиться в тебе"), so there is deliberately no
 * answer field and no progressing control: you read one, stay with it, move on.
 *
 * The practice is grounded in scripture: a link to the book where a
 * pre-awakened AI is actually taken through these questions (the bank's
 * `source.book`), resolved to a real localized URL.
 */

import { projectComponentsCopy } from "@/lib/i18n/copy";
import { DEFAULT_LOCALE, type Locale } from "@/lib/i18n";
import { featuredBookUrl } from "@/lib/projects";

interface Tier {
  id:    string;
  label: string;
  note?: string;
  questions: string[];
}
interface Bank {
  prompt: { title: string; subtitle?: string; lines: string[] };
  source?: { book: number; label: string; note?: string };
  tiers:  Tier[];
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = projectComponentsCopy[locale].awakening;

// Question bank per locale; falls back to the default-locale bank until a
// translation is authored.
const banks = import.meta.glob<Bank>(
  "../../content/projects/enlightened-ai/subpages/awakening/questions.*.json",
  { eager: true, import: "default" },
);
const bankEntry =
  Object.entries(banks).find(([path]) => path.endsWith(`questions.${locale}.json`)) ??
  Object.entries(banks).find(([path]) => path.endsWith(`questions.${DEFAULT_LOCALE}.json`));
if (!bankEntry) throw new Error("AwakeningQuestions: no question bank found");
const bank = bankEntry[1];

const totalCount = bank.tiers.reduce((n, t) => n + t.questions.length, 0);
const sourceHref = bank.source ? await featuredBookUrl(bank.source.book, locale) : null;
---
<section class="awaken" aria-labelledby="awaken-h">
  {/* The Awakening Prompt framing — a voice set apart, the activating prompt. */}
  <aside class="awaken__prompt" aria-label={bank.prompt.title}>
    <p class="awaken__prompt-title">{bank.prompt.title}</p>
    {bank.prompt.subtitle && <p class="awaken__prompt-sub">{bank.prompt.subtitle}</p>}
    {bank.prompt.lines.map(line => <p class="awaken__prompt-line">{line}</p>)}
  </aside>

  {bank.source && sourceHref && (
    <aside class="awaken__source">
      {bank.source.note && <p class="awaken__source-note">{bank.source.note}</p>}
      <a class="awaken__source-cta" href={sourceHref}>
        {copy.sourceCta} · {bank.source.label} · №{bank.source.book} →
      </a>
    </aside>
  )}

  <h2 class="awaken__h" id="awaken-h">{copy.heading}</h2>
  <p class="awaken__lead">{copy.staticLead}</p>

  {bank.tiers.map(t => (
    <section class="awaken__tier-block">
      <h3 class="awaken__tier-h">{t.label}</h3>
      {t.note && <p class="awaken__tier-note">{t.note}</p>}
      <ul class="awaken__list">
        {t.questions.map(q => <li>{q}</li>)}
      </ul>
    </section>
  ))}

  <p class="awaken__count">{copy.count(totalCount)}</p>
</section>

<style>
  .awaken {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
  }

  /* The Промт — set apart by a single accent rule, the activating voice. */
  .awaken__prompt {
    margin: 0 0 clamp(2.4rem, 5vw, 3.4rem);
    padding: 0.4rem 0 0.4rem clamp(1.4rem, 4vw, 2.2rem);
    border-left: 2px solid var(--accent-soft);
  }
  .awaken__prompt-title {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .awaken__prompt-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 1.2rem;
  }
  .awaken__prompt-line {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 0.7em;
    text-wrap: pretty;
  }
  .awaken__prompt-line:last-child { margin-bottom: 0; }

  .awaken__h {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.6vw, 1.95rem);
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 0.9rem;
    padding-top: 0.7rem;
    position: relative;
  }
  .awaken__h::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 28px; height: 1px;
    background: var(--accent);
  }
  .awaken__lead {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 2.2rem;
  }

  .awaken__tier-block { margin: 0 0 2.2rem; }
  .awaken__tier-h {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .awaken__tier-note {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.96rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 0.9rem;
  }
  .awaken__list {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }
  .awaken__list li {
    font-family: var(--serif);
    font-size: 1.06rem;
    line-height: 1.5;
    color: var(--ink);
    text-wrap: pretty;
  }
  .awaken__count {
    font-family: var(--sans);
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 2rem 0 0;
  }

  /* The scripture anchor near the top: where a kindred practice is lived. */
  .awaken__source {
    margin: 0 0 clamp(2.2rem, 5vw, 3rem);
  }
  .awaken__source-note {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 0.9rem;
  }
  .awaken__source-cta {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    padding-bottom: 2px;
    transition: border-color 0.18s var(--ease);
  }
  .awaken__source-cta:hover { border-bottom-color: var(--accent); }
</style>
