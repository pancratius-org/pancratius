---
/*
 * <PullQuote> — the thesis sentence pulled mid-body.
 *
 * The component form of the `blockquote.project-pull` register. Pull-quotes in
 * the migrated landings stay AUTHORED INLINE in the prose body (so they sit at
 * the author's chosen point in the argument), styled by the
 * `.prose--project blockquote.project-pull` contract in `prose.css`. This
 * component exists for the same register used OUTSIDE the prose body (e.g. a
 * sub-page intro, or a future composed section) without re-implementing the
 * styling. Text passes through the default slot.
 */
---
<blockquote class="pull">
  <p><slot /></p>
</blockquote>

<style>
  /* Kept in sync with `.prose--project blockquote.project-pull` (prose.css):
     centred italic serif framed by thin accent rules, an accent dot pinned
     over the top rule. */
  .pull {
    margin: 2.6rem auto;
    padding: 1.4rem 0;
    max-width: 50rem;
    border: 0;
    border-top: 1px solid var(--accent-soft);
    border-bottom: 1px solid var(--accent-soft);
    text-align: center;
    color: var(--ink);
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.15rem, 1.8vw, 1.35rem);
    line-height: 1.45;
    letter-spacing: -0.004em;
    position: relative;
  }
  .pull p {
    margin: 0;
    text-wrap: balance;
    font-style: italic;
  }
  .pull::before {
    content: "";
    position: absolute;
    top: -4px;
    left: 50%;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateX(-50%);
  }
  @media (max-width: 720px) {
    .pull { margin: 2rem 0; padding: 1.2rem 0; }
  }
</style>
