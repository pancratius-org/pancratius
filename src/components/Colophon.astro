---
import type { Locale } from "@/lib/i18n";
import { downloadUrl, pageUrl } from "@/lib/i18n";
import { colophonCopy, downloadLabelCopy } from "@/lib/i18n/copy";
import { entryForAuthoredLocale, type WorkPair } from "@/lib/works";
import { availableFormatsForWork, FORMAT_LABEL, type DownloadFormat } from "@/lib/downloads";

interface Props {
  pair:   WorkPair;
  locale: Locale;
}

const { pair, locale } = Astro.props;
// Existence: the colophon renders on a page that exists in `locale`.
const entry = entryForAuthoredLocale(pair, locale);
if (!entry) {
  throw new Error(`Colophon: no ${locale} entry for ${pair.kind} #${pair.number}`);
}
const formats: DownloadFormat[] = availableFormatsForWork(pair, locale);

const licenseHref = pageUrl("license", locale);

const copy = colophonCopy[locale];
---
<aside class="colophon footer-note">
  <p class="row">
    <b>{downloadLabelCopy[locale]}</b>{" "}
    {formats.map((fmt, i) => (
      <>
        {i > 0 && " · "}
        <a href={downloadUrl(pair.kind, entry.data.slug, fmt, locale)} download>
          {FORMAT_LABEL[fmt]}
        </a>
      </>
    ))}
  </p>
  <p class="row">{copy.rights_before}<a href={licenseHref}>{copy.rights_link}</a>{copy.rights_after}</p>
</aside>

<style>
  .colophon {
    max-width: var(--col-text);
    margin: 4rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .colophon b { color: var(--ink-soft); font-weight: 500; }
  .colophon a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .colophon a:hover { color: var(--accent); }
  .colophon .row + .row { margin-top: 0.35rem; }
</style>
