---
import type { Locale } from "@/lib/i18n";
import { DEFAULT_LOCALE, routedUrl } from "@/lib/i18n";
import { authoredVideoPairs, displayVideoEntry, formatDuration, videoTags, type VideoPair } from "@/lib/videos";
import { videoCardCopy, localeBadge } from "@/lib/i18n/copy";
import VideoCover from "./VideoCover.astro";

interface Props {
  pair:    VideoPair;
  locale:  Locale;
  /** Optional short blurb shown under the title (italic). */
  blurb?:  string;
}

const { pair, locale, blurb } = Astro.props;
const copy = videoCardCopy[locale];
const display = displayVideoEntry(pair, locale);
const localeFallback = display.linkLocale !== locale;
const linkLocale: Locale = display.linkLocale;
const entry = display.entry;
const href = routedUrl("video", entry.data.slug, linkLocale);
const tags = videoTags(entry);
const hasTranslationBadge =
  locale === DEFAULT_LOCALE && authoredVideoPairs(pair).some(item => item.locale !== DEFAULT_LOCALE);
const altPrefix = copy.coverAltPrefix;
const duration = formatDuration(entry.data.duration);
---
<a
  class="vid"
  {href}
  role="listitem"
  data-title={entry.data.title.toLowerCase()}
  data-tags={tags.join("|")}
  data-number={pair.number}
>
  <VideoCover {pair} {locale} alt={`${altPrefix}: ${entry.data.title}`} badge={duration} />
  <div class="vid__body">
    <span class="vid__num work-card-num">{String(pair.number).padStart(2, "0")}</span>
    <h2 class="vid__title">{entry.data.title}</h2>
    {blurb && <p class="work-card-teaser">{blurb}</p>}
    {hasTranslationBadge && <span class="work-card-badge">{localeBadge.both}</span>}
    {localeFallback && <span class="work-card-badge work-card-badge--fallback">{localeBadge.russianOnly}</span>}
  </div>
</a>

<style>
  .vid {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.9rem;
    text-decoration: none;
    color: inherit;
  }
  .vid :global(.vcv) {
    transition: border-color 0.18s var(--ease);
  }
  .vid:hover :global(.vcv) { border-color: var(--accent-soft); }
  .vid__num { margin-bottom: 0.3rem; }
  .vid__title {
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: 1.22;
    font-weight: 600;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 0.45rem;
    text-wrap: balance;
  }
  .vid:hover .vid__title { color: var(--accent); }
  .vid.is-hidden { display: none; }
</style>
