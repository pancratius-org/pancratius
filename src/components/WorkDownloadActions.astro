---
import type { Locale } from "@/lib/i18n";
import { downloadUrl } from "@/lib/i18n";
import { availableFormatsForWork, FORMAT_LABEL } from "@/lib/downloads";
import { downloadLabelCopy } from "@/lib/i18n/copy";
import type { WorkEntry, WorkPair } from "@/lib/works";

interface Props {
  pair: WorkPair;
  entry: WorkEntry;
  locale: Locale;
  downloadAttribute?: boolean;
}

const { pair, entry, locale, downloadAttribute = false } = Astro.props;
const formats = availableFormatsForWork(pair, locale);
const labelId = `work-actions-${pair.kind}-${pair.number}-${locale}`;
---
{formats.length > 0 && (
  <div class="work-actions" role="group" aria-labelledby={labelId}>
    <span id={labelId} class="work-actions__label">{downloadLabelCopy[locale]}</span>
    {formats.map((fmt, i) => (
      <>
        {i > 0 && <span class="work-actions__sep">·</span>}
        {downloadAttribute ? (
          <a href={downloadUrl(pair.kind, entry.data.slug, fmt, locale)} download>{FORMAT_LABEL[fmt]}</a>
        ) : (
          <a href={downloadUrl(pair.kind, entry.data.slug, fmt, locale)}>{FORMAT_LABEL[fmt]}</a>
        )}
      </>
    ))}
  </div>
)}
