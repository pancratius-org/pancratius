---
// Support block for /support/ — the donation appeal's bespoke composition
// shared by the RU and EN support routes: the appeal in a support-specific prose
// register + a SupportChannels widget and seal in a sticky rail. Owns the
// route-local validation of the `channels` frontmatter and the two-column
// support grid, so the support routes stay thin and the layout is defined once.
// The default slot receives the rendered Markdown body.
import { z } from "astro/zod";

import Prose from "@/components/Prose.astro";
import SupportChannels from "@/components/SupportChannels.astro";

import type { Locale } from "@/lib/i18n";
import type { PageEntry } from "@/lib/pages";

// Route-local schema for /support/'s bespoke frontmatter. `kind` selects how
// SupportChannels renders each row (qr image, mono card/text + copy, link +
// copy).
const supportExtras = z.object({
  channels: z
    .array(
      z.object({
        kind: z.enum(["qr", "card", "link", "text"]),
        label: z.string().min(1),
        value: z.string().min(1),
        caption: z.string().optional(),
      })
    )
    .default([]),
});

interface Props {
  page: PageEntry;
  locale: Locale;
}

const { page, locale } = Astro.props;
const support = supportExtras.parse(page.data);
const channels = support.channels.map(c => ({
  kind: c.kind,
  label: c.label,
  value: c.value,
  ...(c.caption === undefined ? {} : { caption: c.caption }),
}));
---
<Prose><slot /></Prose>

{channels.length > 0 && (
  <div class="support-widget">
    <SupportChannels channels={channels} locale={locale} />
    <svg
      class="support-seal"
      viewBox="0 0 32 32"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="16" cy="16" r="10" fill="none" stroke="currentColor" stroke-width="2" />
      <circle cx="16" cy="16" r="2.4" fill="currentColor" />
    </svg>
  </div>
)}

<style>
  /* Support-specific prose register. The appeal opens with a `>` blockquote
     lead and runs in muted ink with a wider measure than default prose. The
     `.prose` is rendered by <Prose>, so target it via :global under the
     route-owned `.static--support` (which <PageShell> renders — also global). */
  :global(.static--support .prose blockquote) {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2.2vw, 1.85rem);
    line-height: 1.32;
    color: var(--ink);
    border-left: none;
    padding: 0;
    margin: 0 0 2rem;
    text-wrap: balance;
    max-width: none;
  }
  :global(.static--support .prose blockquote p) {
    margin: 0;
    font-style: italic;
  }
  :global(.static--support .prose p) {
    color: var(--ink-soft);
    max-width: none;
  }
  :global(.static--support .prose > p:last-child) {
    margin-top: 1.6rem;
    font-style: italic;
    color: var(--ink-soft);
  }

  .support-widget {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    align-items: stretch;
    width: 100%;
  }
  .support-seal {
    display: block;
    width: 28px;
    height: 28px;
    margin: 0.4rem auto 0;
    color: var(--accent);
    opacity: 0.85;
  }

  @media (min-width: 920px) {
    :global(.static--support) {
      max-width: 68rem;
      grid-template-columns: minmax(0, 1.4fr) minmax(280px, 1fr);
      grid-template-areas:
        "head    head"
        "body    widget";
      gap: 2.5rem 3.5rem;
      align-items: start;
    }
    :global(.static--support .static__head) { grid-area: head; }
    :global(.static--support .prose)        { grid-area: body; max-width: none; }
    :global(.static--support) .support-widget { grid-area: widget; position: sticky; top: 6rem; }
  }
  @media (min-width: 1180px) {
    :global(.static--support) {
      grid-template-columns: minmax(0, 1.5fr) minmax(320px, 1fr);
    }
  }
</style>
