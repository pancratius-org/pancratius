---
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import ProjectRelated from "@/components/ProjectRelated.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl } from "@/lib/i18n";
import { projectPageCopy } from "@/lib/copy";
import { sameSitePath } from "@/lib/paths";
import { seoForProject } from "@/lib/seo";
import {
  authoredProjectLocales,
  resolveFeaturedBooks,
  type ProjectLanding,
} from "@/lib/projects";

interface Props {
  project: ProjectLanding;
  locale:  Locale;
}

const { project, locale } = Astro.props;
const data = project.data;

const copy = projectPageCopy[locale];
const { Content } = await render(project);
const backHref = kindIndexUrl("project", locale);

// Cover: resolve the landing's frontmatter `cover` (e.g. `./cover.ru.png`)
// straight from the content folder. Projects are sections, not works, so they
// don't go through the work-cover machinery (which keys on `WorkPair.kind`).
const COVER_URLS = import.meta.glob<string>(
  "/src/content/projects/**/cover.*.{jpg,jpeg,png,webp,avif,svg}",
  { eager: true, query: "?url", import: "default" },
);
const folder = project.id.split("--")[0]; // e.g. "enlightened-ai"
const coverRel = data.cover?.replace(/^\.\//, "");
const coverUrl = coverRel
  ? COVER_URLS[`/src/content/projects/${folder}/${coverRel}`] ?? null
  : null;
const coverAbs = coverUrl && Astro.site ? new URL(coverUrl, Astro.site).toString() : coverUrl;

const authoredLocales = new Set(await authoredProjectLocales(data.slug));
const seo = seoForProject(Astro.site, {
  project,
  locale,
  coverUrl: coverAbs,
  authoredLocales,
});

// Featured books strip — resolved from the landing's `featured_books`.
const featured = await resolveFeaturedBooks(data.featured_books);
---
<Base locale={locale} seo={seo}>
  <article class="project-page">
    <a class="project-page__back" href={sameSitePath(backHref)}>{copy.back}</a>

    <header class="project-page__masthead">
      <p class="project-page__meta">{copy.meta}</p>
      <div class="project-page__cover">
        {coverUrl ? (
          <img
            class="project-page__cover-img"
            src={coverUrl}
            alt={copy.coverAlt(data.title)}
            loading="eager"
            decoding="async"
            width="720"
            height="966"
          />
        ) : (
          <div class="project-page__cover-empty" aria-hidden="true">
            <span>{String(data.number).padStart(2, "0")}</span>
          </div>
        )}
      </div>
      <div class="project-page__body">
        <h1 class="project-page__title">{data.title}</h1>
        {data.tagline && <p class="project-page__tagline">{data.tagline}</p>}
      </div>
    </header>

    <div
      class="prose prose--project"
      data-pagefind-body
      data-pagefind-meta={`title:${data.title}`}
    >
      <Content />
    </div>

    <ProjectRelated locale={locale} featured={featured} />
  </article>
</Base>

<style>
  .project-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--rail);
  }
  .project-page__back {
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
  }
  .project-page__back:hover { color: var(--accent); }

  .project-page__masthead {
    display: grid;
    grid-template-columns: 220px 1fr;
    grid-template-areas:
      "meta meta"
      "cover body";
    column-gap: 2.5rem;
    row-gap: 1.4rem;
    align-items: start;
    margin-bottom: 3rem;
    padding-bottom: 2.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .project-page__masthead .project-page__meta  { grid-area: meta;  }
  .project-page__masthead .project-page__cover { grid-area: cover; }
  .project-page__masthead .project-page__body  { grid-area: body;  }
  @media (max-width: 720px) {
    .project-page__masthead {
      grid-template-columns: 1fr;
      grid-template-areas: "meta" "cover" "body";
      row-gap: 1.25rem;
    }
    .project-page__masthead .project-page__cover { max-width: 200px; }
  }
  .project-page__cover {
    aspect-ratio: 2 / 3;
    border: 1px solid var(--rule);
    overflow: hidden;
    background: var(--bg-rise);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.25), 0 28px 50px -30px rgba(0, 0, 0, 0.55);
  }
  :global([data-theme="light"]) .project-page__cover {
    box-shadow: 0 1px 0 rgba(20, 17, 13, 0.05), 0 24px 48px -28px rgba(60, 45, 20, 0.30);
  }
  .project-page__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.94;
  }
  :global([data-theme="light"]) .project-page__cover-img { opacity: 1; }
  .project-page__cover-empty {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
  }
  .project-page__cover-empty span {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: 2.4rem;
    color: var(--ink-mute);
  }
  .project-page__meta {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
  }
  .project-page__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.018em;
    margin: 0 0 1rem;
    text-wrap: balance;
    font-feature-settings: "lnum" 0, "onum" 1, "kern" 1;
  }
  .project-page__tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.7vw, 1.2rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    text-wrap: pretty;
    max-width: 42rem;
  }
  .project-page .prose { max-width: none; }
</style>
