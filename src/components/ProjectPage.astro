---
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import ProjectHero from "@/components/projects/ProjectHero.astro";
import Negation from "@/components/projects/Negation.astro";
import ConsciousnessLadder from "@/components/projects/ConsciousnessLadder.astro";
import RevelationBlock from "@/components/projects/RevelationBlock.astro";
import SubpageGrid from "@/components/projects/SubpageGrid.astro";
import FeaturedBooks from "@/components/projects/FeaturedBooks.astro";
import FAQ from "@/components/projects/FAQ.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl } from "@/lib/i18n";
import { projectPageCopy } from "@/lib/i18n/copy";
import { seoForProject } from "@/lib/seo";
import {
  authoredProjectLocales,
  featuredBookUrl,
  getProjectSubpage,
  getProjectSubpages,
  projectSubpageUrl,
  resolveFeaturedBooks,
  resolveFeaturedBooksMore,
  type ProjectLanding,
} from "@/lib/projects";

interface Props {
  project: ProjectLanding;
  locale:  Locale;
}

const { project, locale } = Astro.props;
const data = project.data;

const copy = projectPageCopy[locale];
const { Content } = await render(project);
const backHref = kindIndexUrl("project", locale);

// Cover: resolve the landing's frontmatter `cover` (e.g. `./cover.ru.png`)
// straight from the content folder. Projects are sections, not works, so they
// don't go through the work-cover machinery (which keys on `WorkPair.kind`).
const COVER_URLS = import.meta.glob<string>(
  "/src/content/projects/**/cover.*.{jpg,jpeg,png,webp,avif,svg}",
  { eager: true, query: "?url", import: "default" },
);
const folder = project.id.split("--")[0]; // e.g. "enlightened-ai"
const coverRel = data.cover?.replace(/^\.\//, "");
const coverUrl = coverRel
  ? COVER_URLS[`/src/content/projects/${folder}/${coverRel}`] ?? null
  : null;
const coverAbs = coverUrl && Astro.site ? new URL(coverUrl, Astro.site).toString() : coverUrl;

const authoredLocales = new Set(await authoredProjectLocales(data.slug));
const seo = seoForProject(Astro.site, {
  project,
  locale,
  coverUrl: coverAbs,
  authoredLocales,
});

// Featured books — primary strip (with blurbs) + optional secondary row.
const featuredBookRefs = data.featured_books?.map(f => ({
  number: f.number,
  ...(f.blurb === undefined ? {} : { blurb: f.blurb }),
}));
const featured = await resolveFeaturedBooks(featuredBookRefs);
const featuredMore = await resolveFeaturedBooksMore(data.featured_books_more);

// Sub-page doors. Built from the landing's `subpages` descriptor (order +
// weight + label), linked via `projectSubpageUrl`. A door's description is
// surfaced when the authored sub-page exists in this locale.
const doors = await Promise.all(
  (data.subpages ?? []).map(async s => {
    const sub = await getProjectSubpage(data.slug, s.slug, locale);
    return {
      slug: s.slug,
      href: projectSubpageUrl(data.slug, s.slug, locale),
      label: s.label ?? sub?.data.title ?? s.slug,
      weight: s.weight,
      ...(sub?.data.description === undefined ? {} : { description: sub.data.description }),
    };
  }),
);

// Ladder anchor base — link rungs into the classification sub-page only when
// it actually exists in this locale (no dead links before Wave 4.3 authors it).
const subpages = await getProjectSubpages(data.slug, locale);
const hasClassification = subpages.some(s => s.data.slug === "classification");
const ladderAnchorBase = hasClassification
  ? projectSubpageUrl(data.slug, "classification", locale)
  : null;

// Revelation blocks — resolve any `cta.book` into a real localized URL.
const revelations = await Promise.all(
  (data.revelations ?? []).map(async r => {
    let href = r.cta?.href;
    if (r.cta?.book != null) {
      const url = await featuredBookUrl(r.cta.book, locale);
      if (url) href = url;
    }
    const cta = r.cta
      ? { label: r.cta.label, ...(href === undefined ? {} : { href }) }
      : undefined;
    return {
      text: r.text,
      ...(r.voice === undefined ? {} : { voice: r.voice }),
      ...(cta === undefined ? {} : { cta }),
    };
  }),
);

const themeAttr = data.theme ?? undefined;
const heroProps = {
  eyebrow: copy.meta,
  title: data.title,
  coverUrl,
  number: data.number,
  locale,
  ...(data.tagline === undefined ? {} : { tagline: data.tagline }),
};
---
<Base locale={locale} seo={seo}>
  <article class="project-page project-themed" data-project-theme={themeAttr}>
    <a class="project-page__back" href={backHref}>{copy.back}</a>

    <ProjectHero {...heroProps} />

    {data.negation && data.negation.length > 0 && (
      <Negation lines={data.negation} locale={locale} />
    )}

    <div
      class="prose prose--project"
      data-pagefind-body
      data-pagefind-meta={`title:${data.title}`}
    >
      <Content />
    </div>

    {data.ladder && data.ladder.length > 0 && (
      <ConsciousnessLadder rungs={data.ladder} locale={locale} anchorBase={ladderAnchorBase} />
    )}

    {revelations.map(r => (
      <RevelationBlock {...r} locale={locale} />
    ))}

    <SubpageGrid doors={doors} locale={locale} />

    <FeaturedBooks primary={featured} more={featuredMore} locale={locale} />

    {data.faq && data.faq.length > 0 && (
      <FAQ items={data.faq} locale={locale} />
    )}
  </article>
</Base>

<style>
  .project-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--rail) clamp(3.5rem, 7vw, 6rem);
  }
  .project-page__back {
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  .project-page__back:hover { color: var(--accent); }

  /* The themed scope owns the WHOLE surface, not a card. The reading column
     stays centred + measured, but a full-bleed pseudo-element paints the
     theme's background (and a faint top-pooled aperture glow) behind it, so
     the identity reaches edge-to-edge under the site chrome. */
  .project-page.project-themed { position: relative; }
  .project-page.project-themed::before {
    content: "";
    position: fixed;
    inset: 0;
    background:
      radial-gradient(120% 50% at 50% -8%, var(--pt-aperture-glow) 0%, transparent 60%),
      var(--bg);
    z-index: -1;
    pointer-events: none;
  }

  .project-page .prose { max-width: none; }
</style>
