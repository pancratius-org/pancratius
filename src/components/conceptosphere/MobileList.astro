---
// Mobile fallback: a statically-rendered grouped list, one section per
// Leiden community, two modes (Концепты / Книги, or Concepts / Books in EN).
// Both modes are emitted into the HTML; the client script toggles `hidden`
// on whichever mode is active so the JS-disabled load still shows the
// default mode immediately.
//
// Per the universal "respect the reader" constraint: this is not a fallback
// notice, it is the same data made navigable without a graph. The rows are
// built (in page-data.ts) from the SAME per-locale payload the desktop graph
// fetches — the build-time RU⋈overlay join — so concept and community labels
// render in the page's locale (English on /en/), never raw Russian under an
// English URL. Book titles localise where an EN work pair exists; RU-only books
// degrade to a "Russian original" badge + RU link.

import type { Locale } from "@/lib/i18n";
import ModeToggle from "./ModeToggle.astro";
import SearchInput from "./SearchInput.astro";
import { conceptosphereStrings } from "./strings";
import type {
  ConceptosphereBookRow,
  ConceptosphereConceptRow,
  ConceptosphereSection,
} from "./page-data";

interface Props {
  locale: Locale;
  initialMode: "concepts" | "books";
  booksIndexHref: string;
  conceptSections: ConceptosphereSection<ConceptosphereConceptRow>[];
  bookSections: ConceptosphereSection<ConceptosphereBookRow>[];
}
const {
  locale,
  initialMode,
  booksIndexHref,
  conceptSections,
  bookSections,
} = Astro.props;
const t = conceptosphereStrings(locale);
const initialPlaceholder = t.modes[initialMode].searchPlaceholder;

// Number-formatting locale: each row's frequency renders here at build time
// (mobile fallback is static HTML), so we localise digit grouping/spacing.
const numberLocale = t.numberLocale;
---
<section class="cs-mobile-tools">
  <ModeToggle variant="mobile" {locale} activeMode={initialMode} />
  <SearchInput
    variant="mobile"
    {locale}
    placeholder={initialPlaceholder}
  />
</section>

<section
  class="cs-mobile"
  id="cs-mobile"
  aria-label={t.mobileListAriaLabel}
>
  <p class="cs-mobile-note">
    {t.mobileNote}
  </p>

  {/* Concepts mode list */}
  <div
    data-cs-mobile-mode="concepts"
    hidden={initialMode !== "concepts"}
  >
    <nav class="cs-mobile-chips" aria-label={t.mobileChipsConceptsAria}>
      <button type="button" data-cs-cluster-chip aria-pressed="true">{t.mobileChipAll}</button>
      {conceptSections.map(({ com }) => (
        <button
          type="button"
          data-cs-cluster-chip
          data-com={com.id}
          aria-pressed="false"
        >
          <span class="cs-sw" style={`background:${com.color}`}></span>
          {com.label}
        </button>
      ))}
    </nav>

    {conceptSections.map(({ com, rows }) => (
      <section class="cs-mobile-group" data-cs-group data-com={com.id}>
        <h2>
          <span class="cs-sw" style={`background:${com.color}`}></span>
          {com.label}
          <span class="cs-sz" aria-label={`${t.mobileGroupSizeAriaPrefix} ${rows.length}`}>{rows.length}</span>
        </h2>
        <ul>
          {rows.map((row) => (
            <li data-cs-row data-search={row.searchHay}>
              <details>
                <summary>
                  <span class="cs-summary-main">
                    <span class="cs-title">{row.label}</span>
                  </span>
                  <span class="cs-freq">{row.frequency.toLocaleString(numberLocale)}</span>
                </summary>
                <div class="cs-detail">
                  {row.topBooks.length > 0 ? (
                    <>
                      <p class="cs-detail-h">{t.mobileAppearsInHeading}</p>
                      <ul class="cs-detail-books">
                        {row.topBooks.map((b) => (
                          <li><a href={b.href}>{b.title}</a></li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <p class="cs-detail-empty">{t.conceptNotBoundToBook}</p>
                  )}
                </div>
              </details>
            </li>
          ))}
        </ul>
      </section>
    ))}
    <p class="cs-mobile-empty" data-cs-empty hidden>{t.mobileEmpty}</p>
  </div>

  {/* Books mode list */}
  <div
    data-cs-mobile-mode="books"
    hidden={initialMode !== "books"}
  >
    <nav class="cs-mobile-chips" aria-label={t.mobileChipsBooksAria}>
      <button type="button" data-cs-cluster-chip aria-pressed="true">{t.mobileChipAll}</button>
      {bookSections.map(({ com }) => (
        <button
          type="button"
          data-cs-cluster-chip
          data-com={com.id}
          aria-pressed="false"
        >
          <span class="cs-sw" style={`background:${com.color}`}></span>
          {com.label}
        </button>
      ))}
    </nav>

    {bookSections.map(({ com, rows }) => (
      <section class="cs-mobile-group" data-cs-group data-com={com.id}>
        <h2>
          <span class="cs-sw" style={`background:${com.color}`}></span>
          {com.label}
          <span class="cs-sz" aria-label={`${t.mobileGroupSizeAriaPrefix} ${rows.length}`}>{rows.length}</span>
        </h2>
        <ul>
          {rows.map((row) => (
            <li data-cs-row data-search={row.searchHay}>
              <a class="cs-book-row" href={row.href}>
                {row.coverUrl ? (
                  <img class="cs-cover" src={row.coverUrl} alt="" loading="lazy" decoding="async" />
                ) : (
                  <span class="cs-cover is-miss" aria-hidden="true"></span>
                )}
                <span class="cs-book-row-meta">
                  <span class="cs-freq">{t.bookNumberPrefix} {row.number}</span>
                  {!row.localized && <span class="cs-ru-badge">{t.russianOriginalBadge}</span>}
                  <span class="cs-title">{row.title}</span>
                  {row.topConcepts.length > 0 && (
                    <span class="cs-book-row-concepts">
                      {row.topConcepts.slice(0, 5).map((c) => c.label).join(" · ")}
                    </span>
                  )}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
    <p class="cs-mobile-empty" data-cs-empty hidden>{t.mobileEmpty}</p>

    <p class="cs-mobile-note cs-mobile-foot">
      {t.mobileFootPrompt}<a href={booksIndexHref}>{t.mobileFootLink}</a>
    </p>
  </div>
</section>

<style>
  /* Default visibility: visible everywhere. The runtime adds `.cs-js` to
     <html> the moment it boots, then the desktop-only rule below hides the
     list and shows the graph. This means JS-disabled loads — including
     screen readers and crawlers — see the full grouped list, not an empty
     canvas. */
  .cs-mobile-tools {
    display: block;
    padding: 14px var(--rail) 10px;
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 96%, transparent);
  }
  .cs-mobile {
    display: block;
    padding: 16px var(--rail) 28px;
  }

  @media (min-width: 840px) {
    :global(html.cs-js) .cs-mobile-tools { display: none; }
    :global(html.cs-js) .cs-mobile { display: none; }
  }

  .cs-mobile-note {
    margin: 0 0 14px;
    color: var(--cs-ink-trace);
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cs-mobile-foot {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--cs-rule);
  }
  .cs-mobile-foot a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-soft);
  }

  .cs-mobile-chips {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    padding: 0 0 12px;
    scrollbar-width: thin;
    margin-bottom: 4px;
  }
  .cs-mobile-chips button {
    appearance: none;
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--cs-ink-edge);
    border-radius: 2px;
    background: var(--cs-panel-bg);
    color: var(--cs-ink-faint);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 8px;
    cursor: pointer;
  }
  .cs-mobile-chips button[aria-pressed="true"] {
    color: var(--accent);
    border-color: var(--accent-soft);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .cs-mobile-chips .cs-sw {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: 0 0 8px;
  }

  .cs-mobile-group {
    margin: 0 0 22px;
    padding: 0 0 14px;
    border-bottom: 1px solid var(--cs-rule);
  }
  .cs-mobile-group:last-of-type { border-bottom: 0; }
  .cs-mobile-group h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 20px;
    margin: 0 0 8px;
  }
  .cs-mobile-group h2 .cs-sw {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .cs-mobile-group h2 .cs-sz {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--cs-ink-trace);
    margin-left: auto;
  }
  .cs-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cs-mobile details {
    border-bottom: 1px dashed var(--cs-ink-edge);
  }
  .cs-mobile-group li:last-child details { border-bottom: 0; }
  .cs-mobile summary {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    list-style: none;
    cursor: pointer;
  }
  .cs-mobile summary::-webkit-details-marker { display: none; }
  .cs-mobile .cs-summary-main { flex: 1; min-width: 0; }
  .cs-mobile .cs-title {
    display: block;
    color: var(--cs-ink);
    line-height: 1.25;
  }
  .cs-mobile .cs-freq {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--cs-ink-trace);
  }

  .cs-mobile .cs-cover {
    width: 44px;
    height: 64px;
    flex: 0 0 44px;
    object-fit: cover;
    border: 1px solid var(--cs-ink-edge);
    background: var(--cs-bg-soft);
    display: block;
  }
  .cs-mobile .cs-cover.is-miss {
    background:
      repeating-linear-gradient(135deg,
        color-mix(in srgb, var(--cs-ink) 4%, transparent) 0 4px,
        transparent 4px 8px),
      var(--cs-bg-soft);
  }

  .cs-book-row {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px dashed var(--cs-ink-edge);
    color: inherit;
    text-decoration: none;
  }
  .cs-mobile-group li:last-child .cs-book-row { border-bottom: 0; }
  .cs-book-row-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .cs-book-row-meta .cs-freq { letter-spacing: 0.08em; text-transform: uppercase; }
  .cs-book-row-meta .cs-ru-badge {
    align-self: flex-start;
    margin: 2px 0;
    padding: 1px 6px;
    border: 1px solid var(--accent-soft);
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cs-ink-trace);
  }
  .cs-book-row-meta .cs-title { font-size: 15px; color: var(--cs-ink); }
  .cs-book-row-concepts {
    margin-top: 4px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--cs-ink-trace);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .cs-book-row:hover .cs-title { color: var(--accent); }
  .cs-book-row:hover .cs-cover { border-color: var(--accent-soft); }

  .cs-detail {
    padding: 0 0 12px 0;
    color: var(--cs-ink-faint);
    font-size: 13px;
  }
  .cs-detail .cs-detail-h {
    margin: 4px 0 6px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cs-ink-trace);
  }
  .cs-detail-books {
    margin: 0;
    padding: 0 0 0 1rem;
  }
  .cs-detail-books li {
    padding: 2px 0;
  }
  .cs-detail-books a {
    color: var(--cs-ink);
    text-decoration: underline;
    text-decoration-color: var(--cs-rule-2);
    text-underline-offset: 3px;
  }
  .cs-detail-books a:hover { color: var(--accent); }

  .cs-mobile-empty {
    margin: 22px 0;
    color: var(--cs-ink-faint);
    font-style: italic;
  }
</style>
