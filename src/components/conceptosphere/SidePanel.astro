---
// Right-rail analytical detail. Empty in the rendered HTML; the graph script
// populates `#cs-panel-body` when a node is hovered or pinned. The wrapper
// exists so styles ship even when the panel hasn't been opened yet.

import type { Locale } from "@/lib/i18n";
import { conceptosphereStrings } from "./strings";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = conceptosphereStrings(locale);
---
<aside class="cs-panel" id="cs-panel" aria-label={t.sidePanelAriaLabel}>
  <button
    class="cs-panel-close"
    id="cs-panel-close"
    type="button"
    aria-label={t.sidePanelCloseLabel}
  >×</button>
  <div class="cs-panel-body" id="cs-panel-body"></div>
</aside>

<style>
  .cs-panel {
    position: absolute;
    top: 66px;
    bottom: 16px;
    right: 16px;
    width: 320px;
    background: var(--cs-panel-strong, var(--cs-panel-bg));
    border: 1px solid var(--cs-rule);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 20px 22px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--cs-rule-2) transparent;
    z-index: 25;
    transform: translateX(calc(100% + 24px));
    transition: transform 140ms ease;
    border-radius: 2px;
  }
  .cs-panel.is-open { transform: translateX(0); }
  .cs-panel.is-pinned { border-color: var(--accent-soft); }

  .cs-panel-close {
    position: absolute;
    top: 10px;
    right: 12px;
    background: none;
    border: 0;
    color: var(--cs-ink-trace);
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
    font-family: var(--mono);
  }
  .cs-panel-close:hover { color: var(--accent); }

  /* — panel inner styles, scoped via :global so the dynamically-rendered HTML
       (returned from the script) participates in them.
       Names mirror the prototype so swapping the markup template stays mechanical. */
  .cs-panel :global(.cs-com-tag) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cs-ink-faint);
  }
  .cs-panel :global(.cs-com-tag .cs-sw) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .cs-panel :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.18;
    margin: 4px 0 8px;
    letter-spacing: 0.005em;
    hyphens: auto;
  }
  .cs-panel :global(.cs-book-title-heading) {
    margin-top: 4px;
  }
  .cs-panel :global(.cs-stats) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 14px;
    padding: 10px 0 14px;
    border-bottom: 1px solid var(--cs-rule);
    margin-bottom: 14px;
  }
  .cs-panel :global(.cs-stats dt) {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cs-ink-trace);
  }
  .cs-panel :global(.cs-stats dd) {
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--cs-ink);
  }
  .cs-panel :global(.cs-books-h) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cs-ink-trace);
    margin: 0 0 10px;
    font-weight: 500;
  }
  .cs-panel :global(ol.cs-books) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cs-panel :global(ol.cs-books li) {
    display: flex;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--cs-ink-edge);
  }
  .cs-panel :global(ol.cs-books li:last-child) { border-bottom: 0; }
  .cs-panel :global(.cs-conv) {
    color: var(--accent);
    display: inline-block;
    flex: 0 0 auto;
    font-size: 16px;
    line-height: 1;
    margin-top: 1px;
    text-shadow: 0 0 8px color-mix(in srgb, var(--accent) 28%, transparent);
  }
  .cs-panel :global(.cs-conv-foot) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--cs-ink-trace);
    margin: 8px 0 0;
  }
  .cs-panel :global(ol.cs-books.cs-similar-tf) { margin-bottom: 16px; }
  .cs-panel :global(ol.cs-books .cs-cover) {
    width: 36px;
    height: 52px;
    flex: 0 0 36px;
    background: var(--cs-bg-soft);
    border: 1px solid var(--cs-ink-edge);
    object-fit: cover;
    display: block;
  }
  .cs-panel :global(ol.cs-books .cs-cover.is-miss) {
    background:
      repeating-linear-gradient(135deg,
        color-mix(in srgb, var(--cs-ink) 4%, transparent) 0 4px,
        transparent 4px 8px),
      var(--cs-bg-soft);
  }
  .cs-panel :global(ol.cs-books .cs-b-meta) { flex: 1; min-width: 0; }
  .cs-panel :global(ol.cs-books .cs-b-title-row) {
    display: flex;
    align-items: flex-start;
    gap: 5px;
  }
  .cs-panel :global(ol.cs-books .cs-b-title) {
    font-size: 13px;
    line-height: 1.35;
    color: var(--cs-ink);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1 1 auto;
    min-width: 0;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .cs-panel :global(ol.cs-books .cs-b-title:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent-soft);
  }
  .cs-panel :global(ol.cs-books .cs-b-count) {
    margin-top: 3px;
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--cs-ink-trace);
  }

  /* Books-mode hero block */
  .cs-panel :global(.cs-book-hero) {
    display: flex;
    gap: 12px;
    padding: 6px 0 14px;
    border-bottom: 1px solid var(--cs-rule);
    margin-bottom: 12px;
  }
  .cs-panel :global(.cs-big-cover) {
    width: 64px;
    height: 92px;
    flex: 0 0 64px;
    background: var(--cs-bg-soft);
    border: 1px solid var(--cs-ink-edge);
    object-fit: cover;
    display: block;
  }
  .cs-panel :global(.cs-big-cover.is-miss) {
    background:
      repeating-linear-gradient(135deg,
        color-mix(in srgb, var(--cs-ink) 4%, transparent) 0 4px,
        transparent 4px 8px),
      var(--cs-bg-soft);
  }
  .cs-panel :global(.cs-big-cover-link) {
    display: block;
    flex: 0 0 64px;
    border: 0;
  }
  .cs-panel :global(.cs-big-cover-link:hover .cs-big-cover) {
    border-color: var(--accent-soft);
  }
  .cs-panel :global(.cs-h-meta) { flex: 1; min-width: 0; }
  .cs-panel :global(.cs-h-number) {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    color: var(--cs-ink-trace);
    text-transform: uppercase;
  }
  .cs-panel :global(.cs-book-title-link) {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .cs-panel :global(.cs-book-title-link:hover) {
    color: var(--accent);
    border-bottom-color: var(--accent-soft);
  }
  .cs-panel :global(ul.cs-tags) {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 5px;
  }
  .cs-panel :global(ul.cs-tags li) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border: 1px solid var(--cs-ink-edge);
    border-radius: 10px;
    color: var(--cs-ink-faint);
  }
  .cs-panel :global(ul.cs-concepts) {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 5px;
  }
  .cs-panel :global(ul.cs-concepts li) {
    font-family: var(--serif);
    font-size: 12.5px;
    padding: 3px 8px;
    border: 1px solid var(--cs-ink-edge);
    border-radius: 2px;
    color: var(--cs-ink);
    background: color-mix(in srgb, var(--cs-panel-bg) 40%, transparent);
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }
  .cs-panel :global(ul.cs-concepts li .cs-n) {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--cs-ink-trace);
  }

  /* Panel scrollbar */
  .cs-panel::-webkit-scrollbar { width: 6px; }
  .cs-panel::-webkit-scrollbar-thumb {
    background: var(--cs-rule);
    border-radius: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-panel { transition: none; }
  }
</style>
