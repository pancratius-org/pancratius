---
import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import type { SeoMeta } from "@/lib/seo";

import GraphCanvas from "./GraphCanvas.astro";
import MobileList  from "./MobileList.astro";
import type {
  ConceptosphereBookRow,
  ConceptosphereConceptRow,
  ConceptosphereSection,
} from "./page-data";
import { conceptosphereStrings } from "./strings";

interface Props {
  locale: Locale;
  seo: SeoMeta;
  alternates: Partial<Record<Locale, string>>;
  conceptsUrl: string;
  booksUrl: string;
  initialMode: "concepts" | "books";
  modeCounts: Record<"concepts" | "books", string>;
  bookSlugInfo: Record<string, { number: number; title: string; href: string; localized: boolean; tags: readonly string[] }>;
  coverUrls: Record<string, string>;
  booksIndexHref: string;
  conceptSections: ConceptosphereSection<ConceptosphereConceptRow>[];
  bookSections: ConceptosphereSection<ConceptosphereBookRow>[];
}

const {
  locale,
  seo,
  alternates,
  conceptsUrl,
  booksUrl,
  initialMode,
  modeCounts,
  bookSlugInfo,
  coverUrls,
  booksIndexHref,
  conceptSections,
  bookSections,
} = Astro.props;
const t = conceptosphereStrings(locale);
---
<Base
  {locale}
  {seo}
  {alternates}
  mainClass="cs-main"
>
  <header class="cs-page-head">
    <h1 id="cs-page-h1">{t.modes[initialMode].h1}</h1>
    <p class="cs-lede" id="cs-page-lede">
      {t.modes[initialMode].lede}
    </p>
    <div class="cs-method">
      <span class="cs-method__trigger" tabindex="0" aria-describedby="cs-method-panel">
        {t.methodSummary}
      </span>
      <div class="cs-method__panel" id="cs-method-panel" role="note">
        <p class="cs-meth" id="cs-page-meth">{t.modes[initialMode].meth}</p>
        <p class="cs-meta" id="cs-counts">{modeCounts[initialMode]}</p>
      </div>
    </div>
  </header>

  <GraphCanvas
    {locale}
    {conceptsUrl}
    {booksUrl}
    {initialMode}
    {modeCounts}
    {bookSlugInfo}
    {coverUrls}
  />

  <MobileList
    {locale}
    {initialMode}
    {booksIndexHref}
    {conceptSections}
    {bookSections}
  />
</Base>

<style is:global>
  /* Conceptosphere theme tokens. These are page-global because the Sigma
     runtime snapshots them from :root when a session is built. */
  :root {
    --cs-stage-bg:   #06080c;
    --cs-panel-bg:   rgba(13, 17, 23, 0.86);
    --cs-panel-strong: rgba(13, 17, 23, 0.94);
    --cs-bg-soft:    #0d1117;
    --cs-rule:       rgba(232, 227, 214, 0.14);
    --cs-rule-2:     rgba(232, 227, 214, 0.24);
    --cs-ink:        #e8e3d6;
    --cs-ink-faint:  rgba(232, 227, 214, 0.62);
    --cs-ink-trace:  rgba(232, 227, 214, 0.36);
    --cs-ink-edge:   rgba(232, 227, 214, 0.12);
    --cs-grain-opacity: 0.035;

    --cs-label-color: #faf5e8;
    --cs-label-halo:  rgba(6, 8, 12, 0.76);
    --cs-badge-halo:  rgba(6, 8, 12, 0.75);
    --cs-badge-ink:   #f3eee0;
    --cs-callout-bg:  rgba(9, 11, 16, 0.96);
    --cs-callout-ink: #f3eee0;
    --cs-dim-node:    rgba(70, 65, 55, 0.45);
    --cs-dim-edge:    rgba(80, 70, 55, 0.04);
    --cs-default-edge: rgba(232, 227, 214, 0.10);
    --cs-focus-edge:  rgba(233, 161, 66, 0.55);
    --cs-focus-ring:  rgba(233, 161, 66, 0.96);
    --cs-focus-ring-muted: rgba(233, 161, 66, 0.82);
    --cs-focus-ring-soft: rgba(233, 161, 66, 0.30);
    --cs-focus-ring-muted-soft: rgba(233, 161, 66, 0.18);
    --cs-focus-callout-border: rgba(233, 161, 66, 0.72);
    --cs-focus-callout-border-muted: rgba(233, 161, 66, 0.50);
    --cs-edge-ink-rgb: 26 18 12;
    --cs-edge-neutral-rgb: 120 110 95;
    --cs-hull-fill-opacity: 0.08;
    --cs-hull-stroke-opacity: 0.22;
    --cs-hull-dim-fill-opacity: 0.012;
    --cs-hull-dim-stroke-opacity: 0.045;
    --cs-toggle-active-bg: rgba(233, 161, 66, 0.18);
  }
  [data-theme="light"] {
    --cs-stage-bg:    #fbf8f0;
    --cs-panel-bg:    rgba(251, 250, 246, 0.93);
    --cs-panel-strong: rgba(251, 250, 246, 0.96);
    --cs-bg-soft:     #efe6d4;
    --cs-rule:        rgba(45, 36, 24, 0.18);
    --cs-rule-2:      rgba(45, 36, 24, 0.30);
    --cs-ink:         #211b14;
    --cs-ink-faint:   rgba(33, 27, 20, 0.66);
    --cs-ink-trace:   rgba(33, 27, 20, 0.42);
    --cs-ink-edge:    rgba(33, 27, 20, 0.16);
    --cs-grain-opacity: 0;

    --cs-label-color: #1d1710;
    --cs-label-halo:  rgba(251, 250, 246, 0.97);
    --cs-badge-halo:  rgba(251, 250, 246, 0.95);
    --cs-badge-ink:   #2a241a;
    --cs-callout-bg:  rgba(251, 250, 246, 0.98);
    --cs-callout-ink: #2a241a;
    --cs-dim-node:    rgba(54, 45, 32, 0.68);
    --cs-dim-edge:    rgba(70, 48, 24, 0.22);
    --cs-default-edge: rgba(70, 48, 24, 0.24);
    --cs-focus-edge:  rgba(139, 73, 16, 0.66);
    --cs-focus-ring:  rgba(139, 73, 16, 0.92);
    --cs-focus-ring-muted: rgba(139, 73, 16, 0.74);
    --cs-focus-ring-soft: rgba(139, 73, 16, 0.24);
    --cs-focus-ring-muted-soft: rgba(139, 73, 16, 0.16);
    --cs-focus-callout-border: rgba(139, 73, 16, 0.48);
    --cs-focus-callout-border-muted: rgba(139, 73, 16, 0.34);
    --cs-edge-ink-rgb: 28 20 12;
    --cs-edge-neutral-rgb: 96 76 52;
    --cs-hull-fill-opacity: 0.07;
    --cs-hull-stroke-opacity: 0.18;
    --cs-hull-dim-fill-opacity: 0.014;
    --cs-hull-dim-stroke-opacity: 0.055;
    --cs-toggle-active-bg: rgba(166, 100, 25, 0.16);
  }
</style>

<style>
  :global(.cs-main) {
    padding-bottom: 0;
  }

  .cs-page-head {
    position: relative;
    z-index: 60;
    padding: 10px var(--rail);
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    gap: 1.15rem;
    min-height: 42px;
  }
  .cs-page-head h1 {
    flex: 0 0 auto;
    font-family: var(--mono);
    font-weight: 500;
    font-size: 11px;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }
  .cs-page-head .cs-lede {
    flex: 1 1 auto;
    margin: 0;
    max-width: none;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.55;
    font-style: italic;
    min-height: 0;
  }

  .cs-method {
    position: relative;
    flex: 0 0 auto;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-mute);
    z-index: 50;
  }
  .cs-method__trigger {
    display: inline-block;
    cursor: help;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: color 120ms ease;
    white-space: nowrap;
    outline: none;
  }
  .cs-method__trigger:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 4px;
  }
  .cs-method__trigger:hover,
  .cs-method:focus-within .cs-method__trigger { color: var(--accent); }
  .cs-method__panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(38rem, calc(100vw - var(--rail) * 2));
    padding: 14px 16px;
    background: var(--cs-panel-strong);
    border: 1px solid var(--cs-rule);
    color: var(--cs-ink-faint);
    box-shadow: 0 16px 42px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity 120ms ease, transform 120ms ease, visibility 120ms ease;
  }
  .cs-method:hover .cs-method__panel,
  .cs-method:focus-within .cs-method__panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  .cs-method__panel p {
    margin: 0;
  }
  .cs-method__panel .cs-meta {
    margin-top: 10px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  @media (min-width: 840px) {
    :global(html.cs-js body) { overflow: hidden; }
    :global(html.cs-js .cs-main) {
      position: fixed;
      left: 0;
      right: 0;
      top: var(--cs-header-top, 56px);
      bottom: 0;
      display: flex;
      flex-direction: column;
    }
    :global(html.cs-js) .cs-page-head { flex: 0 0 auto; }
  }
  @media (max-width: 839px) {
    .cs-page-head {
      display: block;
      padding: 18px var(--rail) 14px;
    }
    .cs-page-head h1 {
      margin: 0 0 0.45rem;
    }
    .cs-page-head .cs-lede {
      margin-bottom: 0.8rem;
    }
    .cs-method__panel {
      position: static;
      display: none;
      width: auto;
      margin-top: 0.65rem;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
    }
    .cs-method:hover .cs-method__panel,
    .cs-method:focus-within .cs-method__panel {
      display: block;
    }
  }

  :global(.cs-load-error) {
    padding: 24px;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 13px;
  }
</style>

<script is:inline>
  (function () {
    if (window.__csHeaderCleanup) window.__csHeaderCleanup();
    document.documentElement.classList.add("cs-js");
    function update() {
      const header = document.querySelector("header.rail");
      if (!header) return;
      const h = header.getBoundingClientRect().height;
      document.documentElement.style.setProperty("--cs-header-top", h + "px");
    }
    update();
    window.addEventListener("resize", update);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(update);
    }
    window.__csHeaderCleanup = function () {
      window.removeEventListener("resize", update);
      delete window.__csHeaderCleanup;
    };
  })();
</script>
