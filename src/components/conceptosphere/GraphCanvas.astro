---
// Sigma 3 + graphology canvas. The Astro shell here is intentionally thin —
// just the mount points the script needs. The script itself imports the
// renderer/layout libraries from `node_modules` (never CDN) and reads the
// page-owned config from the JSON island below.
//
// One Sigma instance per active mode; switching modes destroys the previous
// instance before constructing the next. The painter for focus + book-number
// badges runs on `afterRender`, so it stays in sync with the camera.

import type { Locale } from "@/lib/i18n";
import { conceptosphereStrings } from "./strings";

import Legend     from "./Legend.astro";
import SidePanel  from "./SidePanel.astro";
import ModeToggle from "./ModeToggle.astro";
import SearchInput from "./SearchInput.astro";

interface Props {
  /** Locale for chrome strings. */
  locale: Locale;
  /** Public URLs (under /data/) for the two graph payloads. */
  conceptsUrl: string;
  booksUrl:    string;
  /** Initial mode shown before a reader changes the toggle. */
  initialMode: "concepts" | "books";
  /** Pre-rendered localized count line for each graph mode. */
  modeCounts: Record<"concepts" | "books", string>;
  /**
   * Per-book slug → display metadata. The page resolves hrefs at build time
   * so the graph script never invents locale-specific work URLs.
   */
  bookSlugInfo: Record<string, { number: number; title: string; href: string; localized: boolean; tags: readonly string[] }>;
  /**
   * Per-book cover URL produced by the Astro build. The script looks up by
   * `book:<ru-slug>` so panels render real book-bundle covers, not raw
   * `./cover.ru.jpg` paths.
   */
  coverUrls: Record<string, string>;
}

const { locale, conceptsUrl, booksUrl, initialMode, modeCounts, bookSlugInfo, coverUrls } = Astro.props;
const t = conceptosphereStrings(locale);
const initialPlaceholder = t.modes[initialMode].searchPlaceholder;

function jsonForScript(value: unknown): string {
  return JSON.stringify(value).replace(/[<>&\u2028\u2029]/g, (char) => {
    switch (char) {
      case "<": return "\\u003c";
      case ">": return "\\u003e";
      case "&": return "\\u0026";
      case "\u2028": return "\\u2028";
      case "\u2029": return "\\u2029";
      default: return char;
    }
  });
}

const configJson = jsonForScript({
  conceptsUrl,
  booksUrl,
  initialMode,
  locale,
  modeCounts,
  bookSlugInfo,
  coverUrls,
  strings: t,
});
---
<section class="cs-stage" id="cs-stage" aria-label={t.stageAriaLabel}>
  <svg id="cs-hulls" aria-hidden="true"></svg>
  <div id="cs-graph" role="img" aria-label={t.graphAriaLabel}>
    <noscript>
      <p class="cs-noscript">{t.noscriptText}</p>
    </noscript>
  </div>

  <Legend {locale} />

  <div class="cs-modebar">
    <ModeToggle variant="desktop" {locale} activeMode={initialMode} />
    <SearchInput
      variant="desktop"
      {locale}
      placeholder={initialPlaceholder}
    />
  </div>

  <SidePanel {locale} />
</section>

<!-- The config payload is materialised into a JSON island so the TS module
     below can pick it up. `define:vars` would force inline mode and disable
     bundling for the second `<script>`, so we keep them separate.

     Strings travel with the payload so the route owns the locale — the
     runtime stays a pure consumer and never imports a locale dictionary. -->
<script type="application/json" id="cs-config" is:inline set:html={configJson}></script>

<script>
  import { bootGraph } from "@/components/conceptosphere/graph-runtime";
  bootGraph();
</script>

<style>
  /* Stage and graph canvas. The stage is the full-bleed area; the graph div
     is its absolutely-positioned child so the canvas resizes with the stage. */
  .cs-stage {
    display: none;
    position: relative;
    overflow: hidden;
    background: var(--cs-stage-bg);
    flex: 1;
    min-height: 0;
  }
  #cs-hulls {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }
  #cs-graph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
  }

  .cs-noscript {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 16px;
    background: var(--cs-panel-bg);
    border: 1px solid var(--cs-rule);
    color: var(--cs-ink);
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    border-radius: 2px;
    max-width: 38ch;
    text-align: center;
  }

  .cs-modebar {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 21;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Default: the stage is hidden so JS-disabled and small-screen loads
     show the static list instead of an empty canvas. The runtime sets
     `html.cs-js` once it boots, and that — paired with the desktop
     breakpoint — turns the stage back on. */
  @media (min-width: 840px) {
    :global(html.cs-js) .cs-stage { display: block; }
  }
</style>
