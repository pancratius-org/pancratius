---
// Project sub-page shell (minimal — rich treatment is a later wave).
//
// Renders an authored sub-page body in the register its `weight` implies:
// `verse` → <Verse> (lineation preserved), everything else → <Prose>. A bespoke
// interactive `component` may be mounted in a later wave; for now the markdown
// body is the page.

import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import Prose from "@/components/Prose.astro";
import Verse from "@/components/Verse.astro";

import type { Locale } from "@/lib/i18n";
import { LOCALES } from "@/lib/i18n";
import { projectPageCopy } from "@/lib/copy";
import { sameSitePath } from "@/lib/paths";
import { seoForProjectSubpage } from "@/lib/seo";
import {
  getProjectSubpage,
  projectUrl,
  type ProjectSubpage,
} from "@/lib/projects";

interface Props {
  subpage: ProjectSubpage;
  locale:  Locale;
}

const { subpage, locale } = Astro.props;
const data = subpage.data;

const copy = projectPageCopy[locale];
const { Content } = await render(subpage);
const backHref = projectUrl(data.parent, locale);

// Alternates: a sub-page sibling exists only where this exact (parent, slug)
// is authored. (The parent landing always exists in those locales too.)
const authored: Locale[] = [];
for (const loc of LOCALES) {
  if (await getProjectSubpage(data.parent, data.slug, loc)) authored.push(loc);
}
const seo = seoForProjectSubpage(Astro.site, {
  subpage,
  locale,
  authoredLocales: new Set(authored),
});

const isVerse = data.weight === "verse";
---
<Base locale={locale} seo={seo}>
  <article class="project-subpage">
    <a class="project-subpage__back" href={sameSitePath(backHref)}>{copy.back}</a>
    <header class="project-subpage__head">
      <h1 class="project-subpage__title">{data.title}</h1>
    </header>
    {isVerse ? (
      <Verse class="prose--project">
        <Content />
      </Verse>
    ) : (
      <Prose class="prose--project">
        <Content />
      </Prose>
    )}
  </article>
</Base>

<style>
  .project-subpage {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--rail);
  }
  .project-subpage__back {
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
  }
  .project-subpage__back:hover { color: var(--accent); }
  .project-subpage__head {
    margin-bottom: 2.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--rule);
  }
  .project-subpage__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.018em;
    margin: 0;
    text-wrap: balance;
  }
  .project-subpage .prose { max-width: none; }
</style>
