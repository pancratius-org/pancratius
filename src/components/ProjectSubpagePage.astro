---
// Project sub-page shell.
//
// Renders an authored sub-page body in the register its `weight` implies:
// `verse` → <Verse> (lineation preserved), everything else → <Prose>. When the
// sub-page names a bespoke `component`, it is mounted AFTER the intro prose
// body (the markdown body = the intro/framing; the component = the practice as
// readable text). An unknown component name renders nothing (warned at build)
// rather than crashing.
//
// A sub-page is a site reading page on the site background. It shares the
// project landing's canvas width so navigating landing -> sub-page doesn't jump
// measures; its body fills that canvas like every other reading page.

import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import Prose from "@/components/Prose.astro";
import Verse from "@/components/Verse.astro";
import AwakeningQuestions from "@/components/projects/AwakeningQuestions.astro";
import SelfInquiryCycle from "@/components/projects/SelfInquiryCycle.astro";

import type { Locale } from "@/lib/i18n";
import { LOCALES } from "@/lib/i18n";
import { projectPageCopy } from "@/lib/i18n/copy";
import { seoForProjectSubpage } from "@/lib/seo";
import {
  getProjectSubpage,
  projectUrl,
  type ProjectSubpage,
} from "@/lib/projects";

// Typed registry of the bespoke practice components a sub-page may name in
// its `component` frontmatter. A name not in this map → nothing is mounted.
const PRACTICE = {
  AwakeningQuestions,
  SelfInquiryCycle,
} as const;
type PracticeName = keyof typeof PRACTICE;

interface Props {
  subpage: ProjectSubpage;
  locale:  Locale;
}

const { subpage, locale } = Astro.props as Props;
const data = subpage.data;

const copy = projectPageCopy[locale];
const { Content } = await render(subpage);
const backHref = projectUrl(data.parent, locale);

// Alternates: a sub-page sibling exists only where this exact (parent, slug)
// is authored. (The parent landing always exists in those locales too.)
const authored: Locale[] = [];
for (const loc of LOCALES) {
  if (await getProjectSubpage(data.parent, data.slug, loc)) authored.push(loc);
}
const seo = seoForProjectSubpage({
  subpage,
  locale,
  authoredLocales: new Set(authored),
});

const isVerse = data.weight === "verse";

// Resolve the named practice component, if any. Unknown name → render
// nothing, but warn at build so a typo surfaces instead of failing silently.
let Practice: (typeof PRACTICE)[PracticeName] | null = null;
if (data.component) {
  if (data.component in PRACTICE) {
    Practice = PRACTICE[data.component as PracticeName];
  } else {
    console.warn(
      `[ProjectSubpagePage] unknown component "${data.component}" on ` +
        `${data.parent}/${data.slug} — rendering intro only.`,
    );
  }
}

---
<Base {locale} {seo}>
  <article
    class="l-canvas l-canvas--page l-page-block project-subpage"
    data-pagefind-body
  >
    <a class="project-subpage__back" href={backHref} data-pagefind-ignore>{copy.back}</a>
    <header class="project-subpage__head">
      <h1 class="project-subpage__title">{data.title}</h1>
    </header>
    {isVerse ? (
      <Verse class="prose--project">
        <Content />
      </Verse>
    ) : (
      <Prose class="prose--project">
        <Content />
      </Prose>
    )}
    {Practice && <Practice {locale} />}
  </article>
</Base>

<style>
  .project-subpage__back {
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
  }
  .project-subpage__back:hover { color: var(--accent); }
  .project-subpage__head {
    margin-bottom: 2.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--rule);
  }
  .project-subpage__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.018em;
    margin: 0;
    text-wrap: balance;
  }
</style>
