---
import type { Locale } from "@/lib/i18n";
import { FOOTER_EXTERNAL_LINKS, FOOTER_LINKS, localizePath, pageUrl } from "@/lib/i18n";
import { footerCopy } from "@/lib/i18n/copy";
import { feedPath } from "@/lib/feed-meta";
import { getPage } from "@/lib/pages";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Hide utility links whose target page does not exist for this locale.
const availableLinks = await Promise.all(
  FOOTER_LINKS.map(async link => {
    const page = await getPage(link.pageSlug, locale);
    return page ? link : null;
  }),
).then(xs => xs.filter((x): x is typeof FOOTER_LINKS[number] => x !== null));

const licenseHref = pageUrl("license", locale);

const copy = footerCopy[locale];

// Utility links, in order: locale-available internal pages, then external. One
// flat list so separators sit BETWEEN items rather than before each.
const links = [
  ...availableLinks.map(link => ({ href: localizePath(link.path, locale), label: link.label[locale], external: false })),
  { href: feedPath(locale), label: "RSS", external: false },
  ...FOOTER_EXTERNAL_LINKS.map(link => ({ href: link.href, label: link.label[locale], external: true })),
];
---
<footer class="footer-note">
  <p>{copy.cc0_before}<a href={licenseHref}>{copy.cc0_link}</a>{copy.cc0_after}</p>
  <p>{copy.cc0_b}</p>
  <p class="footer__links">
    {links.map((link, i) => (
      <>
        {i > 0 && <span class="sep">{copy.sep}</span>}
        <a href={link.href} rel={link.external ? "external" : undefined}>{link.label}</a>
      </>
    ))}
  </p>
</footer>

<style>
  footer {
    padding: 2.5rem var(--rail) 3rem;
    border-top: 1px solid var(--rule);
  }
  footer p { margin: 0; max-width: var(--col-page); }
  footer p + p { margin-top: 0.3rem; }
  footer a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
    text-underline-offset: 3px;
  }
  footer a:hover { color: var(--accent); }
  footer .sep { color: var(--rule-2); padding: 0 0.35em; }
  footer .footer__links { margin-top: 0.6rem; }
</style>
