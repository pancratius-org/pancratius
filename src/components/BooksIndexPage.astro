---
import Base from "@/layouts/Base.astro";
import BookCard from "@/components/BookCard.astro";
import LibraryFilter from "@/components/LibraryFilter.astro";

import type { Locale } from "@/lib/i18n";
import { DEFAULT_LOCALE, kindIndexUrl } from "@/lib/i18n";
import { booksIndexCopy, type BooksIndexCopy } from "@/lib/copy";
import { seoForKindIndex, clampDescription } from "@/lib/seo";
import { getPairsByKind, localizedWorkPairs, workTags } from "@/lib/works";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
// Widen to the interface so optional per-locale fields (e.g. `fullCatalogLink`,
// authored only in EN) are accessible regardless of the active locale.
const copy: BooksIndexCopy = booksIndexCopy[locale];
const allPairs = await getPairsByKind("book");
// Existence: a non-default-locale index lists only works authored in it; the
// default-locale index lists every work.
const pairs = localizedWorkPairs(allPairs, locale);
const seo = seoForKindIndex(Astro.site, "book", locale, { total: allPairs.length });
const defaultHref = kindIndexUrl("book", DEFAULT_LOCALE);

const tagCounts = new Map<string, number>();
for (const { entry } of pairs) {
  for (const t of workTags(entry)) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].map(([label, count]) => ({ label, count }));
---
<Base locale={locale} seo={seo}>
  <section class="page lib">
    <p class="eyebrow eyebrow--lg">{copy.eyebrow}</p>
    <div class="lib__head">
      <h1><b>{pairs.length}</b> {copy.headingLabel(pairs.length)}</h1>
      <p class="lib__sub">
        {copy.sub(allPairs.length, pairs.length)}
        {copy.fullCatalogLink && (
          <Fragment>
            {" "}<a href={defaultHref}>{copy.fullCatalogLink}</a>.
          </Fragment>
        )}
      </p>
    </div>

    <LibraryFilter locale={locale} tags={tags} total={pairs.length} />

    <div class="index" role="list" data-pagefind-ignore>
      {pairs.map(({ pair, entry }) => {
        return <BookCard pair={pair} locale={locale} blurb={clampDescription(entry.data.description, 120)} />;
      })}
    </div>
  </section>
</Base>

<style>
  .lib__head {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    gap: 1.1rem;
  }
  .lib__head h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 7.4vw, 5.4rem);
    line-height: 0.96;
    margin: 0;
    letter-spacing: -0.024em;
  }
  .lib__head h1 b {
    font-weight: 500;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-style: italic;
    color: var(--accent);
  }
  .lib__sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 40rem;
  }
  .lib__sub :global(a) {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
    text-underline-offset: 3px;
  }
  .lib__sub :global(a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .index {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.6rem 2.25rem;
    margin-top: 1rem;
  }
  @media (max-width: 720px) {
    .index { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
