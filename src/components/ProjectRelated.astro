---
// Featured-books strip for project pages.
//
// A project is a themed section; the books it leans on are surfaced here as a
// "Читать дальше" / "Read further" block — the project page is the manifesto;
// the books are the deeper exploration. The book list comes from the landing's
// `featured_books` (resolved by `src/lib/projects.ts`), NOT from work cross_refs.
//
// Visual register matches the book page's "См. также" block (a short accent
// rule above the heading, then a grid of BookCard thumbnails) so a reader who
// has already seen a book page recognises the gesture.

import type { Locale } from "@/lib/i18n";
import { relatedCopy } from "@/lib/copy";
import type { ResolvedFeaturedBook } from "@/lib/projects";
import BookCard from "./BookCard.astro";

interface Props {
  locale:   Locale;
  featured: ResolvedFeaturedBook[];
}

const { locale, featured } = Astro.props;
const labels = relatedCopy[locale];
---
{featured.length > 0 && (
  <aside class="project-related" aria-labelledby="pr-h">
    <header class="project-related__head">
      <h2 class="project-related__h" id="pr-h">{labels.projectHeading}</h2>
      <p class="project-related__sub">{labels.projectSub}</p>
    </header>
    <div class="project-related__grid">
      {featured.map(f => (
        <BookCard pair={f.pair} locale={locale} blurb={f.blurb} />
      ))}
    </div>
  </aside>
)}

<style>
  .project-related {
    margin: 4rem 0 0;
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .project-related__head {
    margin: 0 0 1.8rem;
  }
  .project-related__h {
    font-family: var(--serif);
    font-weight: 600;
    font-style: normal;
    font-size: 1.45rem;
    color: var(--ink);
    margin: 0 0 0.4rem;
    letter-spacing: -0.012em;
    position: relative;
    padding-top: 0.7rem;
  }
  .project-related__h::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 28px;
    height: 1px;
    background: var(--accent);
  }
  .project-related__sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 50rem;
  }
  .project-related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem 1.6rem;
  }
  @media (max-width: 720px) {
    .project-related__grid { grid-template-columns: 1fr; gap: 1.6rem; }
  }
</style>
