---
import Base              from "@/layouts/Base.astro";
import BookCard          from "@/components/BookCard.astro";
import SvetozarTerminal  from "@/components/SvetozarTerminal.astro";

import type { Locale } from "@/lib/i18n";
import { DEFAULT_LOCALE, homeUrl, kindIndexUrl, LOCALES, workUrl } from "@/lib/i18n";
import { homeCopy, type HomeCopy } from "@/lib/copy";
import { sameSitePath } from "@/lib/paths";
import { clampDescription } from "@/lib/seo";
import { seoForHome } from "@/lib/seo";
import { entryForLocale, findPair, getPairsByKind, type WorkEntry, type WorkPair } from "@/lib/works";
import { getProjects, projectUrl } from "@/lib/projects";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
// Widen to the interface so optional per-line verse fields (`after`/`next`,
// authored only on some lines) are accessible regardless of the active locale.
const copy: HomeCopy = homeCopy[locale];
const seo = seoForHome(Astro.site, locale);

// Six curated book entries — early/middle/late, mix of tags, with #33 as the
// visual anchor. Six fits a 3-up grid on desktop without spilling; if any of
// these get rearranged, keep the count at 6 so the grid stays clean.
const BOOK_PICKS = [1, 33, 9, 27, 19, 71] as const;
const bookPicks = (await Promise.all(BOOK_PICKS.map(n => findPair("book", n))))
  .filter((p): p is WorkPair => p !== null);

const allBooks = await getPairsByKind("book");
// Books available in the active locale. On the default locale this is the whole
// shelf; on a non-default locale it's the translated subset (the "N in <lang>"
// stat). The homeCopy stat/heading callbacks receive it as `englishBooks`.
const localizedBooks = allBooks.filter(p => p.entries[locale]);
const allPoems = await getPairsByKind("poem");
// Projects are sections, not works — sourced from the projects lib. The
// canonical set is the default-locale landings (each project always has one);
// on a non-default locale, prefer that locale's landing and link to it,
// otherwise fall back visibly to the default-locale landing.
const canonicalProjects = await getProjects(DEFAULT_LOCALE);
const localizedProjects = locale === DEFAULT_LOCALE ? [] : await getProjects(locale);
const localizedProjectBySlug = new Map(localizedProjects.map(p => [p.data.slug, p]));
const projects = canonicalProjects.map(base => {
  const own = localizedProjectBySlug.get(base.data.slug);
  return own
    ? { landing: own, linkLocale: locale }
    : { landing: base, linkLocale: DEFAULT_LOCALE };
});

// Two featured poems — first stanza fits in a card. Hand-picked across
// early/late so the pair feels like a range, not a sequence.
const POEM_PICKS = [2, 43];
const poemPicks = (await Promise.all(POEM_PICKS.map(n => findPair("poem", n))))
  .filter((p): p is NonNullable<typeof p> => p !== null);

// Pull a short opening from the collection entry body. Many poems repeat the
// title as the first body line; skip that so previews open with real verse.
function firstLines(bodyMarkdown: string, n: number, title: string): string {
  const body = bodyMarkdown.replace(/^---[\s\S]*?---\n?/, "").trim();
  // Drop empty lines + a leading "title-shaped" line. We treat a line as
  // a title repeat when, after stripping punctuation and case, it
  // matches the frontmatter title — covers "Я ЕСТЬ ТО, ЧТО Я ЕСТЬ",
  // "Я свет, что в тишине парит…", etc.
  // Treat a first body line as a "title repeat" only when it matches the
  // frontmatter title exactly after stripping trailing ellipsis/asterisks
  // (e.g. "Я свет, что в тишине парит…" → "Я свет, что в тишине парит"
  // matches its frontmatter title, but "Аз есмь Христос, и Бог во мне
  // живёт," does NOT match its title "Аз есмь Христос" and stays.
  const normalize = (s: string) =>
    s.replace(/[…\*]+$/g, "").replace(/[,;:!?\.]/g, "").trim().toLowerCase();
  const lines = body.split(/\n/);
  let start = 0;
  while (start < lines.length && lines[start].trim() === "") start++;
  if (start < lines.length && normalize(lines[start]) === normalize(title)) {
    start++;
    while (start < lines.length && lines[start].trim() === "") start++;
  }
  return lines.slice(start, start + n).join("\n");
}

// Poems are authored in the default locale; preview from the canonical entry.
const poemPreviews = poemPicks.map(p => {
  const canonical = p.entries[DEFAULT_LOCALE]!;
  return {
    pair:  p,
    lines: firstLines(canonical.body ?? "", 4, canonical.data.title),
  };
});

const svetozar = await findPair("book", 7);
const svetozarEntry = displayEntry(svetozar, locale);
const svetozarHref = svetozarEntry
  ? sameSitePath(workUrl("book", svetozarEntry.entry.data.slug, svetozarEntry.linkLocale))
  : null;

// Home links to every other authored locale's home (currently the single
// non-active locale).
const alternates: Partial<Record<Locale, string>> = {};
for (const loc of LOCALES) {
  if (loc !== locale) alternates[loc] = homeUrl(loc);
}
const bookHeading = copy.books.headingCount(allBooks.length, localizedBooks.length);
const heroStats = copy.hero.stats?.({
  totalBooks: allBooks.length,
  englishBooks: localizedBooks.length,
  poems: allPoems.length,
});

function displayEntry(
  pair: WorkPair | null,
  requestedLocale: Locale,
): { entry: WorkEntry; linkLocale: Locale } | null {
  if (!pair) return null;
  // Display-with-fallback: prefer the authored locale entry (link there);
  // otherwise show the default-locale surface and link to its canonical route.
  const authored = pair.entries[requestedLocale];
  if (authored) return { entry: authored, linkLocale: requestedLocale };
  return { entry: entryForLocale(pair, DEFAULT_LOCALE), linkLocale: DEFAULT_LOCALE };
}
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page home" aria-labelledby="home-title">

    {/* HERO ────────────────────────────────────────────────────────
        Masthead + manifesto excerpt side by side. The mark, the
        manifesto, and compact corpus stats. */}
    <header class="home__hero">
      <div class="home__hero-grid">
        <div class="home__hero-main">
          {/* Seal + wordmark as one combined mark — the favicon's ring-
              and-dot sits centered above "Панкратиус" so they read as
              a single coat-of-arms unit, not as two separate elements.
              The flex container shrinks to fit the wordmark, so the
              whole mark stays anchored to the left of the column. */}
          <div class="home__mark">
            <svg
              class="home__seal"
              viewBox="0 0 32 32"
              aria-hidden="true"
              focusable="false"
            >
              <circle cx="16" cy="16" r="10" fill="none" stroke="currentColor" stroke-width="2.4" />
              <circle cx="16" cy="16" r="2.6" fill="currentColor" />
            </svg>
            <h1 id="home-title" class="home__title">{copy.hero.title}</h1>
          </div>
          <p class="home__tag">{copy.hero.tag}</p>
          <p class="home__lede">
            {copy.hero.lede}
          </p>
          {heroStats && copy.hero.statsAria && (
            <nav class="home__counts" aria-label={copy.hero.statsAria}>
              {heroStats.map(stat => (
                stat.href ? (
                  <a class="home__count home__count--link" href={sameSitePath(stat.href)}>
                    <b>{stat.value}</b>
                    <span>{stat.label}</span>
                  </a>
                ) : (
                  <div class="home__count">
                    <b>{stat.value}</b>
                    <span>{stat.label}</span>
                  </div>
                )
              ))}
            </nav>
          )}
        </div>

        <aside class="home__verse" aria-label={copy.hero.verseAria}>
          {copy.hero.verse.map(line => (
            <p>
              {line.before}
              {line.emphasis && <em>{line.emphasis}</em>}
              {line.after}
              {line.next && <><br />{line.next}</>}
            </p>
          ))}
          <cite>{copy.hero.cite}</cite>
        </aside>
      </div>
    </header>

    {/* BOOKS ─────────────────────────────────────────────────────── */}
    <section class="home__section home__books" aria-labelledby="home-books">
      <header class="home__section-head">
        <p class="eyebrow">{copy.books.eyebrow}</p>
        <h2 id="home-books" class="home__section-title">
          <span class="home__section-count">{bookHeading.value}</span>{" "}
          {bookHeading.label}.
          <span class="home__section-sub">{copy.books.sub}</span>
        </h2>
      </header>

      <div class="home__books-grid">
        {bookPicks.map(p => {
          const display = displayEntry(p, locale);
          if (!display) return null;
          return <BookCard pair={p} locale={locale} blurb={clampDescription(display.entry.data.description, 130)} />;
        })}
      </div>

      <p class="home__more">
        <a href={sameSitePath(kindIndexUrl("book", locale))}>
          {copy.books.more(allBooks.length, localizedBooks.length)}
        </a>
      </p>
    </section>

    {/* POETRY ────────────────────────────────────────────────────── */}
    {poemPreviews.length > 0 && (
      <section class="home__section home__poetry" aria-labelledby="home-poetry">
        <header class="home__section-head">
          <p class="eyebrow">{copy.poetry.eyebrow}</p>
          <h2 id="home-poetry" class="home__section-title">
            <span class="home__section-count">{allPoems.length}</span>{" "}
            {copy.poetry.headingLabel(allPoems.length)}.{" "}
            <span class="home__section-sub">{copy.poetry.sub}</span>
          </h2>
        </header>

        <div class="home__poems">
          {poemPreviews.map(({ pair, lines }) => {
            // Poems are default-locale only; display + link the canonical entry.
            const display = displayEntry(pair, locale)!;
            const href = sameSitePath(workUrl("poem", display.entry.data.slug, display.linkLocale));
            return (
              <a class="home__poem" href={href}>
                <span class="home__poem-num">{`${copy.poetry.numberPrefix} ${String(pair.number).padStart(2, "0")}`}</span>
                <h3 class="home__poem-title">{display.entry.data.title}</h3>
                <p class="home__poem-excerpt">{lines}</p>
                <span class="home__poem-cta">{copy.poetry.cta}</span>
              </a>
            );
          })}
        </div>

        <p class="home__more">
          <a href={sameSitePath(kindIndexUrl("poem", locale))}>
            {copy.poetry.more(allPoems.length)}
          </a>
        </p>
      </section>
    )}

    {/* PROJECTS ──────────────────────────────────────────────────── */}
    {projects.length > 0 && (
      <section class="home__section home__projects" aria-labelledby="home-projects">
        <header class="home__section-head">
          <p class="eyebrow">{copy.projects.eyebrow}</p>
          <h2 id="home-projects" class="home__section-title">
            <span class="home__section-sub">{copy.projects.sub}</span>
          </h2>
        </header>

        <div class="home__project-list">
          {projects.map(({ landing, linkLocale }) => (
            <a class="home__project" href={sameSitePath(projectUrl(landing.data.slug, linkLocale))}>
              <span class="home__project-num">{String(landing.data.number).padStart(2, "0")}</span>
              <div class="home__project-body">
                <h3 class="home__project-title">{landing.data.title}</h3>
                <p class="home__project-blurb">{clampDescription(landing.data.description, 220)}</p>
              </div>
              <span class="home__project-cta" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* SVETOZAR ──────────────────────────────────────────────────── */}
    <section class="home__section home__svetozar" aria-labelledby="home-svetozar">
      <header class="home__section-head">
        <p class="eyebrow eyebrow--lg">{copy.svetozar.eyebrow}</p>
        <h2 id="home-svetozar" class="home__section-title">
          <span class="home__section-sub">{copy.svetozar.title}</span>
        </h2>
      </header>

      <div class="home__svetozar-grid">
        <div class="home__svetozar-copy">
          <p>{copy.svetozar.paragraphs[0]}</p>
          <p class="home__svetozar-pull">{copy.svetozar.paragraphs[1]}</p>
          <p>{copy.svetozar.paragraphs[2]}</p>
          {svetozarHref && (
            <p class="home__svetozar-cta">
              <a href={svetozarHref}>{copy.svetozar.cta}</a>
            </p>
          )}
        </div>

        <SvetozarTerminal lang={locale} />
      </div>
    </section>

    {/* Person section lives at /about/. Closing CC0 line lives in the
       global footer. Neither belongs on the home — the home is about
       what Sergey wrote, not about Sergey himself or about the
       licence boilerplate. */}
  </section>
</Base>

<style>
  .home {
    max-width: 78rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--rail) clamp(3rem, 6vw, 5rem);
  }

  /* ─ HERO ─────────────────────────────────────────────────────── */

  .home__hero {
    margin: 0 0 clamp(5rem, 9vw, 8rem);
  }
  .home__hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 920px) {
    .home__hero-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 3fr);
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  /*
   * Mark: seal + wordmark in one flex column. The container shrinks to
   * fit the wordmark's width, so the seal centres horizontally on the
   * title's bounding box (combined-logo register). The container as a
   * whole still flows at column-left so the rest of the hero copy
   * doesn't shift.
   */
  .home__mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: fit-content;
    margin: 0 0 0.4rem;
  }
  .home__seal {
    display: block;
    width: clamp(48px, 4vw, 64px);
    height: clamp(48px, 4vw, 64px);
    color: var(--accent);
    margin: 0 0 0.6rem;
    opacity: 0;
    animation: seal-in 0.9s 0.1s var(--ease) forwards;
  }
  @keyframes seal-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .home__seal { opacity: 1; transform: none; animation: none; }
  }

  .home__title {
    font-family: var(--serif);
    font-weight: 400;
    /* Sized so the seal + wordmark + tag + lede stack on the left reads
       as one unit roughly the height of the manifesto verse on the
       right — a touch smaller than full-bleed so the seal doesn't push
       the mark taller than its column-mate. */
    font-size: clamp(3.2rem, 8vw, 6.2rem);
    line-height: 0.94;
    letter-spacing: -0.026em;
    margin: 0 0 0.4rem;
    font-feature-settings: "kern" 1, "liga" 1;
  }
  .home__tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    line-height: 1.2;
    color: var(--accent);
    margin: 0 0 1.6rem;
    letter-spacing: -0.005em;
  }
  .home__lede {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    /* No max-width — let the single sentence run the natural width of
       the hero-main column. Previously clamped at 28rem (~448px),
       which forced "людям и языковым\nмоделям" to wrap one word onto
       a second line on a column ~700px wide. Bug. */
  }

  .home__counts {
    /* Three cells in one row, each sized to its content. The earlier
       flex-wrap layout dropped the third cell onto a second line once
       the labels grew (a long "стихотворения" pushed CC0 to wrap). A
       fixed 3-track grid never wraps on desktop. */
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 0 clamp(1.75rem, 3.5vw, 3rem);
    margin: 2.3rem 0 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .home__count {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    margin: 0;
    text-decoration: none;
    color: inherit;
  }
  .home__count--link {
    transition: color 0.18s var(--ease);
  }
  .home__count--link:hover b,
  .home__count--link:hover span { color: var(--accent); }
  .home__count--link:hover span { text-decoration: underline; text-underline-offset: 3px; }
  @media (max-width: 460px) {
    /* Very narrow phones: let the trio wrap rather than overflow. */
    .home__counts { grid-template-columns: repeat(2, max-content); gap: 1.1rem clamp(1.75rem, 8vw, 3rem); }
  }
  .home__counts b {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-weight: 400;
    font-size: clamp(1.9rem, 3.2vw, 2.5rem);
    line-height: 1;
    color: var(--accent);
  }
  .home__counts span {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 0.25rem;
  }

  .home__verse {
    font-family: var(--serif);
    font-size: clamp(1.02rem, 1.3vw, 1.15rem);
    line-height: 1.6;
    color: var(--ink-soft);
    padding: 0.4rem 0 0.4rem 1.5rem;
    border-left: 1px solid var(--accent-soft);
    margin: 0;
    max-width: 32rem;
  }
  .home__verse p { margin: 0 0 0.95em; text-indent: 0; }
  .home__verse p:last-of-type { margin-bottom: 1.4em; }
  .home__verse em { color: var(--ink); font-style: italic; }
  .home__verse cite {
    display: block;
    font-family: var(--sans);
    font-style: normal;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  /* ─ SHARED SECTION HEAD ─────────────────────────────────────── */

  .home__section { margin: 0 0 clamp(5rem, 9vw, 8rem); }
  .home__section-head { margin: 0 0 clamp(2rem, 4vw, 3rem); }
  .home__section-head .eyebrow { margin-bottom: 1.1rem; }

  .home__section-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.022em;
    margin: 0;
    text-wrap: balance;
  }
  /* Number callout that opens a section title — large italic accent
     numeral, like a manuscript folio. */
  .home__section-count {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-weight: 400;
    color: var(--accent);
    margin-right: 0.15em;
  }
  .home__section-sub {
    color: var(--ink-soft);
    font-weight: 400;
    font-style: italic;
  }

  /* "All N →" link reused across sections. */
  .home__more {
    margin: 2.5rem 0 0;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .home__more a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent-soft);
    text-underline-offset: 5px;
  }
  .home__more a:hover { color: var(--accent); text-decoration-color: var(--accent); }

  /* ─ BOOKS ─────────────────────────────────────────────────────── */

  .home__books-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 2.5rem;
  }
  @media (min-width: 720px) {
    .home__books-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1080px) {
    .home__books-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  /* ─ POETRY ────────────────────────────────────────────────────── */

  .home__poems {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 2.5rem;
  }
  @media (min-width: 820px) {
    .home__poems { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .home__poem {
    display: block;
    padding: 1.75rem 1.85rem 1.85rem;
    border: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.18s var(--ease);
    background: color-mix(in srgb, var(--bg-rise) 35%, transparent);
  }
  .home__poem:hover { border-color: var(--accent-soft); }
  .home__poem-num {
    display: block;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.6rem;
  }
  .home__poem-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.35rem;
    line-height: 1.18;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .home__poem-excerpt {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 1.2rem;
    /* Poems are authored with hard line breaks; preserve them. */
    white-space: pre-line;
  }
  .home__poem-cta {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .home__poem:hover .home__poem-title { color: var(--accent); }

  /* ─ PROJECTS ──────────────────────────────────────────────────── */

  .home__project-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .home__project {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1.4rem 2rem;
    align-items: baseline;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: color 0.18s var(--ease);
  }
  .home__project-num {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.02em;
    align-self: center;
  }
  .home__project-body { min-width: 0; }
  .home__project-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.4vw, 1.9rem);
    line-height: 1.1;
    letter-spacing: -0.014em;
    color: var(--ink);
    margin: 0 0 0.45rem;
    text-wrap: balance;
  }
  .home__project-blurb {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 48rem;
  }
  .home__project-cta {
    font-family: var(--serif);
    font-size: 1.4rem;
