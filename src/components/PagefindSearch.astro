---
import type { Locale } from "@/lib/i18n";
import { pagefindSearchCopy } from "@/lib/copy";
import { sameSitePath } from "@/lib/paths";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const pagefindPath = sameSitePath("/pagefind/pagefind.js");
// `unavailable` is deliberately user-facing: in dev the Pagefind index may
// not exist yet, and in production this reads as a temporary feature notice.
const copy = pagefindSearchCopy[locale];
---
<div class="pfs">
  <label class="search">
    <svg viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
      <circle cx="7" cy="7" r="4.5"/>
      <path d="m13.5 13.5-3.2-3.2"/>
    </svg>
    <input
      id="pfsInput"
      type="search"
      placeholder={copy.placeholder}
      autocomplete="off"
      spellcheck="false"
      aria-label={copy.placeholder}
    />
    <kbd id="pfsKbd" aria-hidden="true">⌘K</kbd>
  </label>
  <p class="pfs__status" id="pfsStatus" aria-live="polite">{copy.prompt}</p>
  <ol class="pfs__results" id="pfsResults"></ol>
  <button class="pfs__more" id="pfsMore" type="button" hidden>{copy.more}</button>
</div>

<script is:inline define:vars={{ copy, pagefindPath }}>
  (async function () {
    const input  = document.getElementById("pfsInput");
    const list   = document.getElementById("pfsResults");
    const status = document.getElementById("pfsStatus");
    const more   = document.getElementById("pfsMore");
    if (!input || !list || !status || !more) return;
    const kbd = document.getElementById("pfsKbd");
    if (kbd && !/Mac|iPad|iPhone|iPod/.test(navigator.platform)) kbd.textContent = "Ctrl K";

    let pagefindPromise;
    function loadPagefind() {
      if (!pagefindPromise) {
        pagefindPromise = import(pagefindPath)
          .catch(err => {
            pagefindPromise = null;
            throw err;
          });
      }
      return pagefindPromise;
    }

    function escape(s) {
      return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
    }

    let token = 0;
    let activeResults = [];
    let rendered = 0;

    async function renderMore(mine) {
      const next = activeResults.slice(rendered, rendered + 5);
      more.hidden = true;
      more.disabled = true;
      const hits = await Promise.all(next.map(r => r.data()));
      if (mine !== token) return;
      rendered += next.length;
      for (const h of hits) {
        const li = document.createElement("li");
        li.innerHTML = `
          <a href="${escape(h.url)}">
            <strong>${escape(h.meta?.title || h.url)}</strong>
            <span>${h.excerpt}</span>
          </a>`;
        list.appendChild(li);
      }
      more.disabled = false;
      more.hidden = rendered >= activeResults.length;
    }

    async function runSearch() {
      const q = input.value.trim();
      const mine = ++token;
      list.innerHTML = "";
      activeResults = [];
      rendered = 0;
      more.hidden = true;
      if (!q) { status.textContent = copy.prompt; return; }
      status.textContent = copy.searching;
      let pagefind;
      try {
        pagefind = await loadPagefind();
      } catch (e) {
        status.textContent = copy.unavailable;
        return;
      }
      if (mine !== token) return;
      const search = pagefind.debouncedSearch
        ? await pagefind.debouncedSearch(q, {}, 260)
        : await pagefind.search(q);
      if (search === null) return;
      if (mine !== token) return;
      activeResults = search.results;
      if (!activeResults.length) {
        status.textContent = copy.empty;
        return;
      }
      await renderMore(mine);
      if (mine !== token) return;
      status.textContent = `${copy.hits} ${activeResults.length}`;
    }

    let timer;
    input.addEventListener("input", () => {
      clearTimeout(timer);
      timer = setTimeout(runSearch, 220);
      const q = input.value.trim();
      if (q) {
        loadPagefind()
          .then(pagefind => pagefind.preload?.(q))
          .catch(() => {});
      }
      // Reflect the query in the URL so the search is shareable / bookmarkable.
      const url = new URL(location.href);
      if (q) url.searchParams.set("q", q); else url.searchParams.delete("q");
      history.replaceState(null, "", url);
    });
    // Pick up an initial query from ?q= and run it.
    const initial = new URLSearchParams(location.search).get("q");
    if (initial) { input.value = initial; runSearch(); }
    input.focus();
    more.addEventListener("click", () => renderMore(token));
    document.addEventListener("keydown", e => {
      if (e.defaultPrevented) return;
      if ((e.metaKey || e.ctrlKey) && (e.key === "k" || e.key === "K") && !e.altKey) {
        e.preventDefault();
        input.focus();
        input.select();
      }
    });

    const warmSearch = () => { loadPagefind().catch(() => {}); };
    if ("requestIdleCallback" in window) {
      requestIdleCallback(warmSearch, { timeout: 2500 });
    } else {
      setTimeout(warmSearch, 1200);
    }
  })();
</script>

<style>
  .pfs { max-width: var(--measure-wide); }
  .pfs .search {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--rule-2);
  }
  .pfs .search svg { width: 14px; height: 14px; color: var(--ink-mute); }
  .pfs .search input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--ink);
    padding: 0.3rem 0;
    font-style: italic;
  }
  .pfs .search input::placeholder { color: var(--ink-mute); opacity: 1; }
  .pfs .search kbd {
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--ink-mute);
    border: 1px solid var(--rule);
    padding: 0.12rem 0.4rem;
    border-radius: 2px;
    white-space: nowrap;
  }

  .pfs__status {
    margin: 1rem 0 0;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
  }
  .pfs__results {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 1.1rem;
  }
  .pfs__results li :global(a) {
    display: grid;
    gap: 0.35rem;
    color: inherit;
    text-decoration: none;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .pfs__results li :global(a:hover) { color: var(--accent); }
  .pfs__results li :global(strong) {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--ink);
  }
  .pfs__results li :global(span) {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .pfs__results :global(mark) {
    background: var(--mark-bg);
    color: var(--mark-ink);
    padding: 0 1px;
  }
  .pfs__more {
    margin-top: 1.2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--accent);
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    cursor: pointer;
  }
  .pfs__more:hover { color: var(--ink); }
  .pfs__more:disabled { cursor: wait; opacity: 0.55; }
</style>
