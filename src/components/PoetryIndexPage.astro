---
import Base from "@/layouts/Base.astro";
import FeedLink from "@/components/feed/FeedLink.astro";

import { LOCALES, type Locale, kindIndexUrl, workUrl } from "@/lib/i18n";
import { poetryIndexCopy } from "@/lib/i18n/copy";
import { poemIncipit, poemLeadStanza } from "@/lib/publication/poetry";
import { seoForKindIndex } from "@/lib/seo";
import {
  getPairsByKind,
  localizedWorkPairs,
  poemDate,
  type WorkEntry,
  type WorkPair,
} from "@/lib/works";

interface Props {
  locale: Locale;
}

interface PoetryRow {
  pair: WorkPair;
  entry: WorkEntry;
  linkLocale: Locale;
  date: string | null;
  incipit: string;
}

/** A month of writing — the poet works in waves, so groups are uneven by design. */
interface MonthGroup {
  key: string; // "2026-04", or "" for undated
  month: string; // localized month label, e.g. "апр." / "Apr"
  year: string;
  rows: PoetryRow[];
}

const { locale } = Astro.props;
const copy = poetryIndexCopy[locale];
const pairs = await getPairsByKind("poem");
const seo = seoForKindIndex("poem", locale, { total: pairs.length });
const alternates: Partial<Record<Locale, string>> = {};
for (const loc of LOCALES) {
  if (loc !== locale) alternates[loc] = kindIndexUrl("poem", loc);
}

// Only poems authored in the active locale (whole set on the default locale).
const rows: PoetryRow[] = localizedWorkPairs(pairs, locale).map(({ pair, entry }) => ({
  pair,
  entry,
  linkLocale: locale,
  date: poemDate(entry),
  incipit: poemIncipit(entry.body ?? "", entry.data.title),
}));

// Curated hero stanza (poem 03's first line is its title, which the preview helper
// would strip). Matched by number — slugs differ per locale.
const HERO_NUMBER = 3;
const heroRow = rows.find(row => row.pair.number === HERO_NUMBER) ?? rows[0] ?? null;
const heroStanza = heroRow ? poemLeadStanza(heroRow.entry.body ?? "") : "";

// Months, newest first; within a month, latest first, then catalog order. The hero
// poem also stays in its month — the masthead features it, the catalog stays whole.
const buckets = new Map<string, PoetryRow[]>();
for (const row of rows) {
  const key = row.date ? row.date.slice(0, 7) : "";
  const bucket = buckets.get(key) ?? [];
  bucket.push(row);
  buckets.set(key, bucket);
}
const months: MonthGroup[] = [...buckets.entries()]
  .map(([key, groupRows]) => {
    groupRows.sort((a, b) =>
      (b.date ?? "").localeCompare(a.date ?? "") || a.pair.number - b.pair.number);
    const monthIndex = key ? Number(key.slice(5, 7)) - 1 : -1;
    return {
      key,
      month: copy.months[monthIndex] ?? "",
      year: key.slice(0, 4),
      rows: groupRows,
    };
  })
  .sort((a, b) => b.key.localeCompare(a.key)); // undated ("") sorts last
---
<Base {locale} {seo} {alternates}>
  <section class="l-canvas l-canvas--page l-page-block poetry-index">
    <p class="eyebrow eyebrow--lg">{copy.eyebrow()}<FeedLink locale={locale} /></p>
    <div class="poetry-index__head">
      <h1><b>{rows.length}</b> {copy.headingLabel(rows.length)}</h1>
      <p class="poetry-index__intro index-lede l-measure l-measure--start">{copy.intro}</p>
    </div>

    {heroRow && heroStanza && (
      <a class="poetry-hero" href={workUrl("poem", heroRow.entry.data.slug, heroRow.linkLocale)}>
        <p class="poetry-hero__stanza l-measure l-measure--start">{heroStanza}</p>
        <p class="poetry-hero__attr">
          {heroRow.entry.data.title}<span class="poetry-hero__go" aria-hidden="true"> →</span>
        </p>
      </a>
    )}

    <div class="notebook">
      {months.map(group => (
        <section class="month">
          <div class="month__date" aria-hidden={group.month ? undefined : "true"}>
            <span class="month__mon">{group.month || "—"}</span>
            {group.year && <span class="month__yr">{group.year}</span>}
          </div>
          <ol class="month__poems">
            {group.rows.map(row => (
              <li>
                <a class="poem" href={workUrl("poem", row.entry.data.slug, row.linkLocale)}>
                  <span class="poem__title">{row.entry.data.title}</span>
                  {row.incipit && <span class="poem__incipit">{row.incipit}</span>}
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
</Base>

<style>
  .poetry-index__head {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-bottom: 2.5rem;
  }
  .poetry-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--type-index-masthead-title-size);
    line-height: var(--type-index-masthead-title-leading);
    margin: 0;
    letter-spacing: var(--type-index-masthead-title-tracking);
  }
  .poetry-index h1 b {
    font-weight: 500;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-style: italic;
    color: var(--accent);
  }

  .poetry-hero {
    display: block;
    margin: 0 0 3rem;
    padding: 0.4rem 0 0.4rem 1.5rem;
    border-left: 2px solid var(--accent);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.18s var(--ease);
  }
  .poetry-hero:hover { border-color: var(--accent-soft); }
  .poetry-hero__stanza {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.15rem, 1.7vw, 1.4rem);
    line-height: 1.45;
    color: var(--ink);
    margin: 0 0 1rem;
    white-space: pre-line;
    text-wrap: balance;
  }
  .poetry-hero__attr {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
  }
  .poetry-hero:hover .poetry-hero__attr { color: var(--accent); }
  .poetry-hero__go {
    display: inline-block;
    transition: transform 0.18s var(--ease);
  }
  .poetry-hero:hover .poetry-hero__go { transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) {
    .poetry-hero__go { transition: none; }
  }

  /* Month as a left-margin date-stamp; its poems hang in the column beside it. */
  .month {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 2.75rem);
    align-items: start;
    padding-top: 2.5rem;
    border-top: 1px solid var(--rule);
  }
  .month + .month { margin-top: 2.5rem; }

  /* The date-stamp floats beside its cluster while a long month scrolls past. */
  .month__date {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .month__mon {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    font-variant-numeric: oldstyle-nums proportional-nums;
  }
  .month__yr {
    margin-top: 0.5rem;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-variant-numeric: oldstyle-nums proportional-nums;
  }

  .month__poems {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.7rem;
  }
  .poem {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    color: inherit;
    text-decoration: none;
  }
  .poem__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.32rem;
    line-height: 1.2;
    letter-spacing: -0.014em;
    color: var(--ink);
    text-wrap: balance;
    transition: color 0.18s var(--ease);
  }
  .poem:hover .poem__title,
  .poem:focus-visible .poem__title { color: var(--accent); }
  .poem__incipit {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.4;
    color: var(--ink-soft);
    text-wrap: balance;
  }

  /* ─── narrow: the date steps up as a small running head over its poems ─── */
  @media (max-width: 720px) {
    .month {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-top: 1.8rem;
    }
    .month + .month { margin-top: 1.8rem; }
    .month__date {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
    }
    .month__yr { margin-top: 0; }
  }
</style>
