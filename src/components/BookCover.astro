---
import Cover from "@/components/Cover.astro";
import type { Locale } from "@/lib/i18n";
import { resolveCoverAsset, workCoverKey } from "@/lib/cover-assets";
import { COVER_ASSET_REGISTRY } from "@/lib/cover-registry";
import type { WorkPair } from "@/lib/works";

interface Props {
  pair:    WorkPair;
  locale:  Locale;
  alt:     string;
  /** `eager` for above-the-fold covers (book page masthead), `lazy` otherwise. */
  loading?: "lazy" | "eager";
}

const { pair, locale, alt, loading = "lazy" } = Astro.props;
const coverKey = workCoverKey(pair, locale);
const cover = coverKey ? resolveCoverAsset(coverKey, COVER_ASSET_REGISTRY) : null;
---
<Cover
  {...(cover ? { cover } : {})}
  {alt}
  widths={[96, 160, 220, 320, 440, 720]}
  sizes="(max-width: 720px) 200px, 220px"
  {loading}
  {...(loading === "eager" ? { fetchpriority: "high" as const } : {})}
  fallback={String(pair.number)}
/>
