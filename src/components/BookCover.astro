---
import type { ImageMetadata } from "astro";

import ResponsiveCoverImage from "@/components/ResponsiveCoverImage.astro";
import type { Locale } from "@/lib/i18n";
import { resolveCoverAsset, workCoverKey, type CoverAssetRegistry } from "@/lib/cover-assets";
import type { WorkPair } from "@/lib/works";

interface Props {
  pair:    WorkPair;
  locale:  Locale;
  alt:     string;
  /** `eager` for above-the-fold covers (book page masthead), `lazy` otherwise. */
  loading?: "lazy" | "eager";
}

const COVER_ASSETS = {
  raster: import.meta.glob<ImageMetadata>(
    "/src/content/**/cover.*.{jpg,jpeg,png,webp,avif}",
    { eager: true, import: "default" },
  ),
  svg: import.meta.glob<string>(
    "/src/content/**/cover.*.svg",
    { eager: true, query: "?url", import: "default" },
  ),
} satisfies CoverAssetRegistry;

const { pair, locale, alt, loading = "lazy" } = Astro.props;
const coverKey = workCoverKey(pair, locale);
const cover = coverKey ? resolveCoverAsset(coverKey, COVER_ASSETS) : null;
const coverImageProps = loading === "eager"
  ? { fetchpriority: "high" as const }
  : {};
---
<div class:list={["bcv", !cover && "bcv--empty"]} aria-hidden={cover ? undefined : "true"}>
  {cover ? (
    <ResponsiveCoverImage
      src={cover}
      alt={alt}
      widths={[96, 160, 220, 320, 440, 720]}
      sizes="(max-width: 720px) 200px, 220px"
      loading={loading}
      decoding="async"
      {...coverImageProps}
    />
  ) : (
    <span class="bcv__num">{pair.number}</span>
  )}
</div>

<style>
  .bcv {
    position: relative;
    aspect-ratio: 2 / 3;
    background: var(--bg-rise);
    border: 1px solid var(--rule);
    overflow: hidden;
    box-shadow: var(--paper-shadow);
    transition: border-color 0.18s var(--ease), transform 0.32s var(--ease);
  }
  .bcv img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.94;
    transition: opacity 0.32s var(--ease);
  }
  :global([data-theme="light"]) .bcv img { opacity: 1; }
  .bcv--empty {
    display: grid;
    place-items: center;
  }
  .bcv__num {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: 2.4rem;
    color: var(--ink-mute);
    line-height: 1;
  }
</style>
