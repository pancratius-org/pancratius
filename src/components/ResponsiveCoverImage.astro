---
import { Image } from "astro:assets";

import type { CoverAsset } from "@/lib/cover-assets";

interface Props {
  src:            CoverAsset;
  alt:            string;
  class?:         string;
  widths:         number[];
  sizes:          string;
  loading?:       "lazy" | "eager";
  decoding?:      "sync" | "async" | "auto";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  class: className,
  widths,
  sizes,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
} = Astro.props;
---
<Image
  class={className}
  {src}
  {alt}
  {widths}
  {sizes}
  {loading}
  {decoding}
  {fetchpriority}
/>
