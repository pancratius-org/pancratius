---
import type { Locale } from "@/lib/i18n";
import { DEFAULT_LOCALE, workUrl } from "@/lib/i18n";
import { authoredWorkPairs, displayWorkEntry, type WorkPair } from "@/lib/works";
import { bookCardCopy, localeBadge } from "@/lib/i18n/copy";
import BookCover from "./BookCover.astro";
import RussianOriginalBadge from "./RussianOriginalBadge.astro";

interface Props {
  pair:    WorkPair;
  locale:  Locale;
  /** Optional short blurb shown under the title (italic). Authoring source is up to the caller. */
  blurb?:  string;
}

const { pair, locale, blurb } = Astro.props;
const copy = bookCardCopy[locale];
// Existence check drives the visible fallback: on a non-default-locale index,
// when this work has no entry in the current locale, fall back to the default-
// locale surface. The card still links somewhere real — to the default-locale
// page — and marks the fallback visibly so a reader isn't surprised by the
// language flip on click.
const display = displayWorkEntry(pair, locale);
const localeFallback = display.linkLocale !== locale;
const linkLocale: Locale = display.linkLocale;
const entry = display.entry;
const href = workUrl(pair.kind, entry.data.slug, linkLocale);
const tags = "tags" in entry.data ? entry.data.tags : [];
// On the default-locale index, badge works that also have a non-default
// translation. (For RU+EN this is the "RU · EN" badge on /books/.)
const hasTranslationBadge =
  locale === DEFAULT_LOCALE && authoredWorkPairs(pair).some(item => item.locale !== DEFAULT_LOCALE);
const altPrefix = copy.coverAltPrefix;
---
<a
  class="book"
  {href}
  role="listitem"
  data-title={entry.data.title.toLowerCase()}
  data-tags={tags.join("|")}
  data-number={pair.number}
>
  <BookCover {pair} {locale} alt={`${altPrefix}: ${entry.data.title}`} />
  <div class="book__body">
    <span class="book__num work-card-num">{String(pair.number).padStart(2, "0")}</span>
    <h2 class="book__title">{entry.data.title}</h2>
    {blurb && <p class="work-card-teaser">{blurb}</p>}
    {hasTranslationBadge && <span class="work-card-badge">{localeBadge.both}</span>}
    {localeFallback && <RussianOriginalBadge {href} />}
  </div>
</a>

<style>
  .book {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 1.1rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }
  .book :global(.bcv) {
    transition: border-color 0.18s var(--ease);
  }
  .book:hover :global(.bcv) { border-color: var(--accent-soft); }
  .book__num { margin-bottom: 0.35rem; }
  .book__title {
    font-family: var(--serif);
    font-size: 1.22rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }
  .book:hover .book__title { color: var(--accent); }
  .book.is-hidden { display: none; }

  @media (max-width: 720px) {
    .book { grid-template-columns: 76px 1fr; gap: 0.9rem; }
  }
</style>
