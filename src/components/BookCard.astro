---
import type { Locale } from "@/lib/i18n";
import type { WorkPair } from "@/lib/works";
import { workUrl } from "@/lib/i18n";
import BookCover from "./BookCover.astro";

interface Props {
  pair:    WorkPair;
  locale:  Locale;
  /** Optional short blurb shown under the title (italic). Authoring source is up to the caller. */
  blurb?:  string;
}

const { pair, locale, blurb } = Astro.props;
// On EN pages, fall back to the RU surface when no EN translation exists. The
// card still links somewhere real — to the RU page — and we mark the fallback
// visibly so an EN reader isn't surprised by the language flip on click.
const enFallback = locale === "en" && !pair.en;
const display = enFallback ? pair.ru : (locale === "en" ? pair.en! : pair.ru);
const linkLocale: Locale = enFallback ? "ru" : locale;
const href = workUrl(pair.kind, display.data.slug, linkLocale);
const tags = "tags" in display.data ? display.data.tags : [];
const hasEnBadge = pair.en !== null && locale === "ru";
const altPrefix = locale === "en" ? "Cover" : "Обложка";
---
<a
  class="book"
  href={href}
  role="listitem"
  data-title={display.data.title.toLowerCase()}
  data-tags={tags.join("|")}
  data-number={pair.number}
>
  <BookCover pair={pair} locale={locale} alt={`${altPrefix}: ${display.data.title}`} />
  <div class="book__body">
    <span class="book__num">{String(pair.number).padStart(2, "0")}</span>
    <h2 class="book__title">{display.data.title}</h2>
    {blurb && <p class="book__annot">{blurb}</p>}
    {hasEnBadge && <span class="book__lang">RU · EN</span>}
    {enFallback && <span class="book__lang book__lang--fallback">Russian only</span>}
  </div>
</a>

<style>
  .book {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 1.1rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }
  .book :global(.bcv) {
    transition: border-color 0.18s var(--ease);
  }
  .book:hover :global(.bcv) { border-color: var(--accent-soft); }
  .book__num {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    display: block;
    margin-bottom: 0.35rem;
  }
  .book__title {
    font-family: var(--serif);
    font-size: 1.22rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }
  .book:hover .book__title { color: var(--accent); }
  .book__annot {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .book__lang {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--ink-mute);
    margin-top: 0.55rem;
    display: inline-block;
  }
  .book__lang--fallback {
    color: var(--accent-soft);
    border-bottom: 1px dashed var(--rule-2);
  }
  .book.is-hidden { display: none; }

  @media (max-width: 720px) {
    .book { grid-template-columns: 76px 1fr; gap: 0.9rem; }
  }
</style>
