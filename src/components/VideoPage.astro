---
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import RichText from "@/components/RichText.astro";
import VideoEmbed from "@/components/VideoEmbed.astro";
import Share from "@/components/Share.astro";
import BackLink from "@/components/BackLink.astro";
import TagRow from "@/components/TagRow.astro";
import Pager from "@/components/Pager.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, routedUrl } from "@/lib/i18n";
import { neighbors } from "@/lib/neighbors";
import { videoPageCopy, formatMessageDate } from "@/lib/i18n/copy";
import { seoForVideo } from "@/lib/seo";
import {
  getAllVideoPairs,
  channelForEntry,
  entryForAuthoredVideoLocale,
  formatDuration,
  localizedVideoPairs,
  videoCoverAbsoluteUrl,
  videoTags,
  videoWatchLinks,
  type VideoPair,
} from "@/lib/videos";

interface Props {
  pair:   VideoPair;
  locale: Locale;
}

const { pair, locale } = Astro.props;
const entry = entryForAuthoredVideoLocale(pair, locale);
if (!entry) {
  throw new Error(`VideoPage: no ${locale} entry for video #${pair.number}`);
}

const copy = videoPageCopy[locale];
const { Content } = await render(entry);
const coverUrl = videoCoverAbsoluteUrl(pair, locale);
const seo = seoForVideo({ pair, locale, coverUrl });
const tags = videoTags(entry);
// One page for every video. The written commentary is optional; only its
// presence adds a section — it never changes the chrome above it, so a
// catalogue entry and a full essay open identically.
const hasBody = (entry.body ?? "").trim().length > 0;
const backHref = kindIndexUrl("video", locale);

const allPairs = await getAllVideoPairs();
const pagerPairs = localizedVideoPairs(allPairs, locale);
const { prev, next } = neighbors(pagerPairs, pair.number);

const pad = (n: number) => String(n).padStart(2, "0");
const number = pad(pair.number);
const duration = formatDuration(entry.data.duration);
const published = formatMessageDate(locale, entry.data.published_at, { withYear: true });
const watchLinks = videoWatchLinks(entry);
const channel = await channelForEntry(entry);
---
<Base {locale} {seo}>
  <article class="l-canvas l-canvas--page l-page-block video-page">
    <BackLink href={backHref} label={copy.back(pagerPairs.length)} />

    <header class="video-page__head">
      <p class="video-page__meta kicker">
        {copy.meta}
        <span class="video-page__num">№ {number}</span>
        <time datetime={entry.data.published_at}>· {published}</time>
      </p>
      <div data-pagefind-body data-pagefind-meta={`title:${entry.data.title}`}>
        <h1 class="video-page__title">{entry.data.title}</h1>
        <div class="video-page__lede">
          <RichText text={entry.data.description} collapse={{ more: copy.showMore, less: copy.showLess }} />
        </div>
      </div>
    </header>

    <div class="video-page__embed">
      <VideoEmbed {entry} {pair} {locale} loading="eager" badge={duration} />
    </div>

    <div class="video-page__bar">
      <p class="video-page__watch">
        <a href={watchLinks.primary.url} rel="noopener" target="_blank">
          {copy.watchOn(copy.platformLabel(watchLinks.primary.platform))} →
        </a>
        {watchLinks.mirrors.length > 0 && (
          <span class="video-page__mirrors">
            <span class="video-page__mirrors-label">{copy.mirrorsLabel}</span>
            {watchLinks.mirrors.map((m, i) => (
              <>
                {i > 0 && " · "}
                <a href={m.url} rel="noopener" target="_blank">{copy.platformLabel(m.platform)}</a>
              </>
            ))}
          </span>
        )}
      </p>
      {channel && (
        <p class="video-page__channel">
          <span class="video-page__channel-label">{copy.channelLabel}</span>
          <a href={channel.data.url} rel="noopener" target="_blank">{channel.data.title[locale]}</a>
        </p>
      )}
      <Share {locale} />
    </div>

    <TagRow {tags} />

    {hasBody && (
      <div class="prose prose--note video-page__body" data-pagefind-body>
        <Content />
      </div>
    )}

    <Pager
      ariaLabel={copy.pagerAria}
      prev={prev && { href: routedUrl("video", prev.entry.data.slug, locale), label: pad(prev.pair.number), title: prev.entry.data.title }}
      next={next && { href: routedUrl("video", next.entry.data.slug, locale), label: pad(next.pair.number), title: next.entry.data.title }}
    />
  </article>
</Base>

<style>
  /* One reading column for every video — no body-density layout fork. */
  .video-page__head { margin: 1.6rem 0 0; }
  .video-page__meta {
    margin: 0 0 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: baseline;
  }
  .video-page__num {
    color: var(--accent);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .video-page__meta time {
    text-transform: none;
    letter-spacing: 0.02em;
    color: var(--ink-mute);
    font-variant-numeric: oldstyle-nums proportional-nums;
  }
  .video-page__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2rem, 4.4vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.018em;
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .video-page__lede {
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.6vw, 1.18rem);
    line-height: 1.6;
  }
  .video-page__lede :global(p) { margin: 0 0 0.7em; }
  .video-page__lede :global(p:last-child) { margin-bottom: 0; }

  .video-page__embed { margin: 1.8rem 0 1.3rem; }

  /* Meta bar under the embed: where to watch, the channel, and share. */
  .video-page__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.6rem;
    margin: 0 0 1.4rem;
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--ink-soft);
  }
  .video-page__watch,
  .video-page__channel { margin: 0; }
  .video-page__watch > a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
    text-underline-offset: 3px;
  }
  .video-page__watch > a:where(:hover) { color: var(--accent); }
  .video-page__mirrors { margin-left: 0.6em; }
  .video-page__mirrors-label,
  .video-page__channel-label {
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 11px;
    margin-right: 0.35em;
  }
  .video-page__mirrors a,
  .video-page__channel a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .video-page__mirrors a:where(:hover),
  .video-page__channel a:where(:hover) { color: var(--accent); }

  .video-page__body {
    margin-top: 1.8rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--rule);
  }
</style>
