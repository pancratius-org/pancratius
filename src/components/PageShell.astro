---
/*
 * PageShell — shared masthead + centred canvas for static pages.
 *
 * A building block, not a dispatcher: it renders the eyebrow / title / sub
 * masthead and the base `.static` grid container, then yields its default
 * slot for whatever blocks a dedicated route composes (Prose, Verse, a
 * portrait figure, a facts <dl>, a support widget…). Bespoke page bodies own
 * their internal layout inside the slot; they do not restyle the shell.
 *
 * The shell owns only the shared chrome: canvas size, masthead typography, and
 * the `static--with-toc` two-column variant for plain pages with headings.
 */

interface Props {
  /** Masthead title (the page's <h1>). */
  title: string;
  /** Optional small-caps eyebrow above the title. */
  eyebrow?: string;
  /** Optional italic sub-line under the title. */
  sub?: string;
  /** Extra class(es) on the `<article>`; used for shell-owned variants. */
  class?: string;
  /**
   * Canvas size from the `--col-*` scale. `page` (default) is the
   * informational column (license); `text` is the single reading column,
   * where the masthead and the body share the reading measure (mission,
   * svetozar).
   */
  width?: "text" | "page" | "wide" | "spread";
}

const { title, eyebrow, sub, class: extraClass, width = "page" } = Astro.props;
---
<article class:list={["l-canvas", `l-canvas--${width}`, "static", extraClass]}>
  <header class="static__head">
    {eyebrow && <p class="eyebrow eyebrow--lg">{eyebrow}</p>}
    <h1 class="static__title">{title}</h1>
    {sub && <p class="static__sub l-measure l-measure--start">{sub}</p>}
  </header>

  <slot />
</article>

<style>
  .static {
    padding-block: clamp(3.5rem, 7vw, 6rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .static__head { margin-bottom: 0.5rem; }
  .static__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.8rem, 5.8vw, 4.3rem);
    line-height: 0.98;
    margin: 0;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .static__sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    line-height: 1.45;
    color: var(--accent);
    margin: 0.6rem 0 0;
    text-wrap: balance;
  }

  /* Plain-prose page that grew h2/h3 headings: a left ToC rail. The bespoke
     pages (bio, support) own their own grid templates inside the slot and
     never use this variant. */
  @media (min-width: 1100px) {
    .static--with-toc {
      /* Rail + body pair, centered as one canvas. */
      grid-template-columns: 13.75rem var(--col-text);
      grid-template-areas:
        "head head"
        "toc  body";
      --l-canvas-size: calc(13.75rem + 3rem + var(--col-text));
      gap: 2.5rem 3rem;
    }
    .static--with-toc .static__head { grid-area: head; }
    .static--with-toc :global(.toc-aside) { grid-area: toc; }
    .static--with-toc :global(.prose) { grid-area: body; }
  }
</style>
