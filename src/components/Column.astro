---
/*
 * Column — the reading column. The ONE width owner.
 *
 * A centred, rail-padded column sized from the `--col-*` scale in
 * tokens.css. This is the only place a single-column page should set its
 * horizontal width: drop the page's content inside and pick a `size`. The
 * content fills the column — `.prose`, lists, search results never set their
 * own `max-width`, so the masthead and the body always share one edge. That
 * is the whole point: width lives here, not scattered as `Nrem` caps across
 * components, where they drift apart and a container ends up wider than its
 * own children.
 *
 *   <Column size="text">…poem / essay body…</Column>   // single reading column
 *   <Column size="page">…license / downloads…</Column>  // informational column
 *
 * Pages with a masthead use <PageShell> (which owns its column the same way);
 * two-column layouts (book, message, support) own their grid in their own
 * route. Reach for <Column> for the plain single-column pages.
 */

interface Props {
  /** Column width from the `--col-*` scale. */
  size?: "text" | "page" | "wide" | "bleed";
  /** Semantic element to render as (default `div`). */
  as?: "div" | "article" | "section" | "main";
  /** Extra class(es) on the column element. */
  class?: string;
}

const { size = "page", as: Tag = "div", class: extraClass } = Astro.props;
---
<Tag class:list={["col", `col--${size}`, extraClass]}>
  <slot />
</Tag>

<style>
  .col {
    margin-inline: auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--rail);
  }
  .col--text  { max-width: var(--col-text); }
  .col--page  { max-width: var(--col-page); }
  .col--wide  { max-width: var(--col-wide); }
  .col--bleed { max-width: var(--col-bleed); }
</style>
