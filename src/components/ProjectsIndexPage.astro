---
import Base from "@/layouts/Base.astro";

import type { Locale } from "@/lib/i18n";
import { DEFAULT_LOCALE } from "@/lib/i18n";
import { projectsIndexCopy } from "@/lib/copy";
import { seoForKindIndex } from "@/lib/seo";
import { getProjects, projectUrl, type ProjectLanding } from "@/lib/projects";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = projectsIndexCopy[locale];
const seo = seoForKindIndex(Astro.site, "project", locale);

// The projects index lists EVERY project. The canonical set is the
// default-locale landings (each project always has one). When the current
// locale has its own landing, link to it; otherwise fall back visibly to the
// default-locale landing and link to its canonical route.
const canonical = await getProjects(DEFAULT_LOCALE);
const localized = locale === DEFAULT_LOCALE ? [] : await getProjects(locale);
const localizedBySlug = new Map(localized.map(p => [p.data.slug, p]));

interface Row {
  landing:    ProjectLanding;
  hrefLocale: Locale;
  isFallback: boolean;
}

const rows: Row[] = canonical.map(base => {
  const own = localizedBySlug.get(base.data.slug);
  if (own) return { landing: own, hrefLocale: locale, isFallback: false };
  return { landing: base, hrefLocale: DEFAULT_LOCALE, isFallback: true };
});
---
<Base locale={locale} seo={seo}>
  <section class="page projects-index">
    <p class="eyebrow eyebrow--lg">{copy.eyebrow}</p>
    <div class="projects-index__head">
      <h1>{copy.heading}</h1>
      <p class="projects-index__intro">{copy.intro}</p>
    </div>

    <div class="projects-list">
      {rows.map(({ landing, hrefLocale, isFallback }) => (
        <a
          class="project-row"
          href={projectUrl(landing.data.slug, hrefLocale)}
          data-project-theme={landing.data.theme ?? undefined}
        >
          <span class="project-row__num">{String(landing.data.number).padStart(2, "0")}</span>
          <div class="project-row__body">
            <h2 class="project-row__title">
              {landing.data.title}
              {isFallback && <span class="project-row__fallback">{copy.fallbackLabel}</span>}
            </h2>
            {landing.data.tagline && (
              <p class="project-row__tagline">{landing.data.tagline}</p>
            )}
            {landing.data.description && (
              <p class="project-row__blurb">{landing.data.description}</p>
            )}
            <span class="project-row__cta">{copy.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .projects-index { max-width: 72rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .projects-index__head {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }
  .projects-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 7.4vw, 5.4rem);
    line-height: 0.96;
    margin: 0;
    letter-spacing: -0.024em;
  }
  .projects-index__intro {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 42rem;
  }

  .projects-list { border-top: 1px solid var(--rule); }
  .project-row {
    position: relative;
    display: grid;
    grid-template-columns: clamp(3.5rem, 7vw, 6rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
    padding: clamp(2.5rem, 4.5vw, 3.5rem) 0 clamp(2.5rem, 4.5vw, 3.5rem) clamp(1rem, 2vw, 1.6rem);
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: color 0.18s var(--ease), background 0.2s var(--ease);
  }
  /* Identity hint: a thin aperture bar in the row's own theme accent on the
     left edge, and a faint theme-tinted glow that warms/cools on hover — a
     whisper of each mini-site's register before you enter it. The row itself
     carries `data-project-theme`, so `--accent` here resolves per-project. */
  .project-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: clamp(2.5rem, 4.5vw, 3.5rem);
    bottom: clamp(2.5rem, 4.5vw, 3.5rem);
    width: 2px;
    background: var(--accent);
    opacity: 0.55;
    transition: opacity 0.2s var(--ease);
  }
  .project-row:hover::before { opacity: 1; }
  .project-row:hover {
    background: linear-gradient(90deg, var(--accent-mute) 0%, transparent 55%);
  }
  .project-row__tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.4;
    color: var(--accent);
    margin: 0 0 1rem;
    max-width: 44rem;
    text-wrap: pretty;
  }
  .project-row__num {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: clamp(3rem, 5vw, 4rem);
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .project-row__body { min-width: 0; }
  .project-row__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    line-height: 1.08;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .project-row__blurb {
    font-family: var(--serif);
    font-size: clamp(1.02rem, 1.25vw, 1.12rem);
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 1.25rem;
    max-width: 52rem;
  }
  .project-row__fallback {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.65rem;
    padding: 0.16rem 0.42rem;
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .project-row__cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .project-row:hover .project-row__title { color: var(--accent); }

  @media (max-width: 720px) {
    .project-row { grid-template-columns: 1fr; gap: 0.6rem; }
    .project-row__num { font-size: clamp(2.4rem, 8vw, 3.2rem); }
  }
</style>
