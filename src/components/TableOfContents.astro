---
import type { MarkdownHeading } from "astro";
import type { Locale } from "@/lib/i18n";
import { tocCopy } from "@/lib/i18n/copy";
import { tocHeadings, TOC_MIN_DEPTH, TOC_MAX_DEPTH } from "@/lib/toc";

interface Props {
  headings: MarkdownHeading[];
  locale:   Locale;
  /** Inclusive min/max heading depth to include in the ToC. */
  minDepth?: number;
  maxDepth?: number;
}

const { headings, locale, minDepth = TOC_MIN_DEPTH, maxDepth = TOC_MAX_DEPTH } = Astro.props;
const items = tocHeadings(headings, minDepth, maxDepth);
const label = tocCopy[locale].label;
---
{items.length > 0 && (
  <aside class="toc-aside">
    <details class="toc" open>
      <summary>{label}</summary>
      <ol class="toc__list">
        {items.map(h => (
          <li class:list={["toc__item", `toc__d${h.depth}`]}>
            <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
          </li>
        ))}
      </ol>
    </details>

    <script is:inline>
      // Active-section scroll-spy. Position-based: the active heading is
      // the LAST one whose top has scrolled above the reading line — a
      // sliver just under the sticky site header. IntersectionObserver
      // with rootMargin in the middle of the viewport mis-fires when the
      // reader jumps to an anchor (the heading lands at the top, outside
      // the active zone, so the previous heading stays highlighted).
      //
      // ToC renders before the prose in DOM order, so `getElementById`
      // on heading slugs only works once parsing is past the prose —
      // wait for DOMContentLoaded.
      (function () {
        // Must match `html { scroll-padding-top }` in global.css so that
        // a freshly-jumped heading sits at exactly the active line. A
        // few px slack handles fractional getBoundingClientRect values.
        const READING_LINE = 84;

        function init() {
          const links = Array.from(document.querySelectorAll("[data-toc-link]"));
          if (!links.length) return;
          const aside = document.querySelector(".toc-aside");
          const byId = new Map(links.map(a => [a.dataset.tocLink, a]));
          const headings = Array.from(byId.keys())
            .map(id => document.getElementById(id))
            .filter(Boolean);
          if (!headings.length) return;

          // Keep the active link visible inside the rail's own scroll box
          // (desktop only — the mobile ToC isn't a scroll container). Scroll
          // the aside directly rather than scrollIntoView() so a hidden
          // active link can never hijack the page scroll.
          function reveal(el) {
            if (!aside || aside.scrollHeight <= aside.clientHeight) return;
            // On desktop the rail is the link's offsetParent, so offsetTop is
            // already its position within the scroll box.
            const top = el.offsetTop;
            if (top < aside.scrollTop) {
              aside.scrollTop = top;
            } else if (top + el.offsetHeight > aside.scrollTop + aside.clientHeight) {
              aside.scrollTop = top + el.offsetHeight - aside.clientHeight;
            }
          }

          let active = null;
          const setActive = (el) => {
            if (active === el) return;
            if (active) active.removeAttribute("aria-current");
            if (el) { el.setAttribute("aria-current", "location"); reveal(el); }
            active = el;
          };

          function update() {
            let current = null;
            for (const h of headings) {
              if (h.getBoundingClientRect().top <= READING_LINE) current = h;
              else break;
            }
            setActive(current ? byId.get(current.id) : null);
          }

          let ticking = false;
          function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => { update(); ticking = false; });
          }
          window.addEventListener("scroll", onScroll, { passive: true });
          window.addEventListener("resize", onScroll, { passive: true });
          update();
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init, { once: true });
        } else {
          init();
        }
      })();
    </script>
  </aside>
)}

<style>
  /* Desktop: stick within the row of whatever parent grid we're dropped
     into. Sticky lives on the aside itself (not on .toc inside) so its
     containing block is the grid row — which spans the full prose column
     height. `align-self: start` keeps the aside's own height = its
     content, leaving the rest of the row as scroll runway. */
  @media (min-width: 1100px) {
    .toc-aside {
      position: sticky;
      top: 4.5rem;
      align-self: start;
      /* Bound the rail to the viewport so a long ToC scrolls inside itself
         instead of running off-screen unreachably. 0.75rem of breathing
         room below the sticky offset keeps it off the bottom edge. */
      max-height: calc(100vh - 4.5rem - 0.75rem);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--rule-2) transparent;
    }
    .toc-aside::-webkit-scrollbar { width: 6px; }
    .toc-aside::-webkit-scrollbar-thumb {
      background: var(--rule-2);
      border-radius: 3px;
    }
  }

  .toc {
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--ink-soft);
    border-left: 1px solid var(--rule);
    padding: 0.4rem 0 0.4rem 1.1rem;
  }
  .toc > summary {
    list-style: none;
    cursor: pointer;
    color: var(--ink-mute);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 500;
    margin-bottom: 0.6rem;
  }
  .toc > summary::-webkit-details-marker { display: none; }
  .toc__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    /* Touch target: each link is a 24+ px block so we don't trip Lighthouse's
       target-size audit on long ToC entries. Visual gap is preserved by the
       link's own padding rather than `gap`. */
    gap: 0;
  }
  .toc__item a {
    display: block;
    padding: 0.45rem 0;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.18s var(--ease);
    line-height: 1.35;
  }
  .toc__d3 { padding-left: 1rem; font-size: 12px; color: var(--ink-mute); }
  .toc__d3 a { color: var(--ink-mute); }
  .toc__item a:hover { color: var(--accent); }
  .toc__item a[aria-current="location"] {
    color: var(--ink);
    box-shadow: inset 2px 0 0 var(--accent);
    padding-left: 0.6rem;
    margin-left: -0.6rem;
  }
  .toc__d3 a[aria-current="location"] { color: var(--ink-soft); }
</style>
