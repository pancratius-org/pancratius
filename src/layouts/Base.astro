---
import "@/styles/global.css";

import type { Locale } from "@/lib/i18n";
import type { SeoMeta } from "@/lib/seo";

import ThemeInit from "@/components/ThemeInit.astro";
import HeadMeta  from "@/components/HeadMeta.astro";
import Header    from "@/components/Header.astro";
import Footer    from "@/components/Footer.astro";

interface Props {
  locale: Locale;
  seo:    SeoMeta;
  /** Map locale → URL of the alternate-language version (used by the switcher). */
  alternates: Partial<Record<Locale, string>>;
  /** Optional CSS class for <main>. */
  mainClass?: string;
}

const { locale, seo, alternates, mainClass } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <ThemeInit />
    <HeadMeta seo={seo} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=Inter:wght@400;500;600&display=swap&subset=cyrillic,cyrillic-ext,latin,latin-ext"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a href="#main" class="skip">{locale === "ru" ? "К содержанию" : "Skip to content"}</a>
    <Header locale={locale} currentPath={currentPath} alternates={alternates} />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
