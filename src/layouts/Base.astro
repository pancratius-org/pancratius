---
import "@/styles/global.css";

import type { Locale } from "@/lib/i18n";
import { chromeCopy } from "@/lib/i18n/copy";
import { switcherAlternatesFromSeo, type SeoMeta } from "@/lib/seo";

import ThemeInit from "@/components/ThemeInit.astro";
import HeadMeta  from "@/components/HeadMeta.astro";
import Header    from "@/components/Header.astro";
import Footer    from "@/components/Footer.astro";

interface Props {
  locale: Locale;
  seo:    SeoMeta;
  /** Map locale → URL of the alternate-language version (used by the switcher). */
  alternates?: Partial<Record<Locale, string>>;
  /** Optional CSS class for <main>. */
  mainClass?: string;
}

const { locale, seo, alternates, mainClass } = Astro.props;
const currentPath = Astro.url.pathname;
const copy = chromeCopy[locale];
const switcherAlternates = alternates ?? switcherAlternatesFromSeo(seo);
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <ThemeInit />
    <HeadMeta seo={seo} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=Inter:wght@400;500;600&display=swap&subset=cyrillic,cyrillic-ext,latin,latin-ext"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a href="#main" class="skip">{copy.skip}</a>
    <Header {locale} currentPath={currentPath} alternates={switcherAlternates} />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer {locale} />

    <script is:inline>
      // Share buttons (`<button data-share>`). Try the Web Share API first
      // (mobile + recent desktops show a native share sheet); fall back to
      // copying the URL and flipping the button label to the value of
      // `data-share-copied` for 1.6 s. Single delegated listener so any
      // page that drops a share button gets the behaviour for free.
      document.addEventListener("click", async (e) => {
        const btn = e.target instanceof Element && e.target.closest("[data-share]");
        if (!btn) return;
        e.preventDefault();
        const original = btn.textContent;
        const copied   = btn.dataset.shareCopied || "Copied";
        const failed   = btn.dataset.shareFailed || "Failed";
        const url      = location.href;
        const title    = document.title;
        try {
          if (navigator.share) {
            await navigator.share({ url, title });
            return;
          }
          await navigator.clipboard.writeText(url);
          btn.dataset.state = "done";
          btn.textContent = copied;
        } catch {
          btn.dataset.state = "done";
          btn.textContent = failed;
        }
        setTimeout(() => {
          delete btn.dataset.state;
          btn.textContent = original;
        }, 1600);
      });
    </script>
  </body>
</html>
