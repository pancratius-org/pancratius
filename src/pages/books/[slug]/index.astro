---
import type { GetStaticPaths } from "astro";

import BookPage from "@/components/BookPage.astro";
import { getPairsByKind } from "@/lib/works";

export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("book");
  return pairs.map(p => ({ params: { slug: p.ru.data.slug }, props: { pair: p } }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<BookPage pair={pair} locale="ru" />
