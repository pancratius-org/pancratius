---
import type { GetStaticPaths } from "astro";

import BookPage from "@/components/BookPage.astro";
import { DEFAULT_LOCALE } from "@/lib/i18n";
import { defaultWorkEntry, getPairsByKind } from "@/lib/works";

export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("book");
  return pairs.map(p => ({
    params: { slug: defaultWorkEntry(p).data.slug },
    props: { pair: p },
  }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<BookPage pair={pair} locale={DEFAULT_LOCALE} />
