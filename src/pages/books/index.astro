---
import Base           from "@/layouts/Base.astro";
import BookCard       from "@/components/BookCard.astro";
import LibraryFilter  from "@/components/LibraryFilter.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, plRu, RU_PLURALS } from "@/lib/i18n";
import { seoForKindIndex, clampDescription } from "@/lib/seo";
import { getPairsByKind, workTags } from "@/lib/works";

const locale: Locale = "ru";
const pairs = await getPairsByKind("book");
const seo = seoForKindIndex(Astro.site, "book", locale);

const tagCounts = new Map<string, number>();
for (const p of pairs) {
  for (const t of workTags(p.ru)) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].map(([label, count]) => ({ label, count }));

const alternates = { en: kindIndexUrl("book", "en") };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page lib">
    <p class="eyebrow eyebrow--lg">Обсерватория Света</p>
    <div class="lib__head">
      <h1><b>{pairs.length}</b> {plRu(pairs.length, RU_PLURALS.book)}</h1>
      <p class="lib__sub">
        Полный корпус — от 01 до {String(pairs.length).padStart(2, "0")}.
        По числу, по году, по метке. Каждая страница — отдельная книга.
        Читать. Скачать. Делиться.
      </p>
    </div>

    <LibraryFilter locale={locale} tags={tags} total={pairs.length} />

    <div class="index" role="list" data-pagefind-ignore>
      {pairs.map(p => (
        <BookCard pair={p} locale={locale} blurb={clampDescription(p.ru.data.description, 120)} />
      ))}
    </div>
  </section>
</Base>

<style>
  .lib__head {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    gap: 1.1rem;
  }
  .lib__head h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 7.4vw, 5.4rem);
    line-height: 0.96;
    margin: 0;
    letter-spacing: -0.024em;
  }
  .lib__head h1 b {
    font-weight: 500;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-style: italic;
    color: var(--accent);
  }
  .lib__sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 40rem;
  }

  .index {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.6rem 2.25rem;
    margin-top: 1rem;
  }
  @media (max-width: 720px) {
    .index { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
