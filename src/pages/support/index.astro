---
// /support/ ("Поддержка") — donation channels. Thin route: load the page,
// derive SEO + alternates, and compose the shared <SupportBody> block (appeal
// prose + channels widget) inside <PageShell>. The bespoke layout, validation,
// and styling live in <SupportBody> so the RU/EN routes don't duplicate them.

import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import PageShell from "@/components/PageShell.astro";
import SupportBody from "@/components/SupportBody.astro";

import type { Locale } from "@/lib/i18n";
import { LOCALES, pageUrl } from "@/lib/i18n";
import { getPage } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";

const SLUG = "support";
const locale: Locale = "ru";

const page = await getPage(SLUG, locale);
if (!page) throw new Error(`Missing src/content/pages/${SLUG}/${locale}.md`);
const { Content } = await render(page);

const authoredLocales = new Set<Locale>();
for (const loc of LOCALES) {
  if (await getPage(SLUG, loc)) authoredLocales.add(loc);
}
const seo = seoForPage(Astro.site, page, authoredLocales);
const alternates: Partial<Record<Locale, string>> = {};
for (const loc of authoredLocales) {
  if (loc !== locale) alternates[loc] = pageUrl(SLUG, loc);
}
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <PageShell
    title={page.data.title}
    eyebrow={page.data.eyebrow}
    sub={page.data.sub}
    class="static--support"
  >
    <SupportBody page={page} locale={locale}><Content /></SupportBody>
  </PageShell>
</Base>
