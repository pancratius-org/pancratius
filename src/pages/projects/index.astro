---
import Base       from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, workUrl } from "@/lib/i18n";
import { seoForKindIndex } from "@/lib/seo";
import { getPairsByKind, workTags } from "@/lib/works";

const locale: Locale = "ru";
const pairs = await getPairsByKind("project");
const seo = seoForKindIndex(Astro.site, "project", locale);
const alternates = { en: kindIndexUrl("project", "en") };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page projects-index">
    <p class="eyebrow eyebrow--lg">Проекты</p>
    <div class="projects-index__head">
      <h1>Два направления</h1>
      <p class="projects-index__intro">
        Два направления, в&nbsp;которых Слово выходит в&nbsp;дело.
        Один встречает машину; другой — землю.
      </p>
    </div>

    <div class="projects-list">
      {pairs.map(p => {
        const tags = workTags(p.ru);
        return (
          <a class="project-row" href={workUrl("project", p.ru.data.slug, locale)}>
            <span class="project-row__num">{String(p.number).padStart(2, "0")}</span>
            <div class="project-row__body">
              <h2 class="project-row__title">{p.ru.data.title}</h2>
              {p.ru.data.description && (
                <p class="project-row__blurb">{p.ru.data.description}</p>
              )}
              {tags.length > 0 && (
                <ul class="project-row__tags">
                  {tags.map(t => <li>{t}</li>)}
                </ul>
              )}
              <span class="project-row__cta">Открыть&nbsp;→</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Base>

<style>
  .projects-index { max-width: 72rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .projects-index__head {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }
  .projects-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 7.4vw, 5.4rem);
    line-height: 0.96;
    margin: 0;
    letter-spacing: -0.024em;
  }
  .projects-index__intro {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 42rem;
  }

  /* Stacked editorial list: full-width rows with dividers, giant italic
     accent numeral on the left, copy on the right. Mirrors
     .home__project from src/pages/index.astro but with room for the full
     description (no clamp), tags, and a CTA. */
  .projects-list {
    border-top: 1px solid var(--rule);
  }
  .project-row {
    display: grid;
    grid-template-columns: clamp(3.5rem, 7vw, 6rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
    padding: clamp(2.5rem, 4.5vw, 3.5rem) 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: color 0.18s var(--ease);
  }
  .project-row__num {
    font-family: var(--serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-size: clamp(3rem, 5vw, 4rem);
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .project-row__body { min-width: 0; }
  .project-row__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    line-height: 1.08;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .project-row__blurb {
    font-family: var(--serif);
    font-size: clamp(1.02rem, 1.25vw, 1.12rem);
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 1.25rem;
    max-width: 52rem;
  }
  .project-row__tags {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
  }
  .project-row__tags li {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--rule);
  }
  .project-row__cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .project-row:hover .project-row__title { color: var(--accent); }

  @media (max-width: 720px) {
    .project-row { grid-template-columns: 1fr; gap: 0.6rem; }
    .project-row__num { font-size: clamp(2.4rem, 8vw, 3.2rem); }
  }
</style>
