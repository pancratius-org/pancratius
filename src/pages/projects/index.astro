---
import Base       from "@/layouts/Base.astro";
import BookCard   from "@/components/BookCard.astro";
import type { Locale } from "@/lib/i18n";
import { kindIndexUrl } from "@/lib/i18n";
import { seoForKindIndex, clampDescription } from "@/lib/seo";
import { getPairsByKind } from "@/lib/works";

const locale: Locale = "ru";
const pairs = await getPairsByKind("project");
const seo = seoForKindIndex(Astro.site, "project", locale);
const alternates = { en: kindIndexUrl("project", "en") };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page projects-index">
    <p class="eyebrow">Два направления</p>
    <h1>Проекты</h1>
    <div class="index" role="list">
      {pairs.map(p => (
        <BookCard pair={p} locale={locale} blurb={clampDescription(p.ru.data.description, 200)} />
      ))}
    </div>
  </section>
</Base>

<style>
  .projects-index { max-width: 64rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .projects-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.8rem, 6.4vw, 4.8rem);
    line-height: 0.98;
    margin: 0 0 2rem;
    letter-spacing: -0.022em;
  }
  .index {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem 2rem;
  }
</style>
