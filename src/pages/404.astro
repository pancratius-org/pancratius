---
import Base from "@/layouts/Base.astro";
import { DEFAULT_LOCALE, LOCALE_META, type Locale } from "@/lib/i18n";
import { notFoundCopy } from "@/lib/i18n/copy";
import { absUrl } from "@/lib/seo";

const locale: Locale = DEFAULT_LOCALE;
const copy = notFoundCopy[locale];
const seo = {
  title:       copy.title,
  description: copy.description,
  canonical:   absUrl("/404"),
  ogImage:     null,
  ogImageAlt:  null,
  ogType:      "website" as const,
  alternates:  [],
  jsonLd:      null,
  locale,
  ogLocale:    LOCALE_META[locale].ogLocale,
  siteName:    LOCALE_META[locale].siteLabel,
};
---
<Base {locale} {seo} alternates={{}}>
  <section class="l-canvas l-canvas--text nf">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.heading}</h1>
    <p>{copy.body}</p>
    <p class="nf__links">
      <a href="/ru/">{copy.toHome}</a>
      <span class="sep">·</span>
      <a href="/ru/books/">{copy.toBooks}</a>
      <span class="sep">·</span>
      <a href="/ru/search/">{copy.toSearch}</a>
    </p>
  </section>
</Base>

<style>
  .nf {
    padding-block: clamp(5rem, 12vw, 9rem);
    text-align: center;
  }
  .nf .eyebrow { color: var(--accent); }
  .nf h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--type-utility-title-size);
    line-height: var(--type-utility-title-leading);
    margin: 0.4rem 0 1.5rem;
    letter-spacing: var(--type-utility-title-tracking);
  }
  .nf p {
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-soft);
    margin: 0 0 1.5rem;
  }
  .nf__links {
    font-family: var(--sans);
    font-style: normal;
    font-size: 12.5px;
    letter-spacing: 0.06em;
  }
  .nf__links a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .nf__links a:hover { color: var(--accent); }
  .nf__links .sep { color: var(--rule-2); padding: 0 0.4em; }
</style>
