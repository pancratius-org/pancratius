---
import type { GetStaticPaths } from "astro";

import StaticPage from "@/components/StaticPage.astro";
import type { Locale } from "@/lib/i18n";
import { getPagesForSlugRoute, type PageEntry } from "@/lib/pages";

const locale: Locale = "ru";

export const getStaticPaths = (async () => {
  const pages = await getPagesForSlugRoute("ru");
  return pages.map(p => ({ params: { slug: p.data.slug }, props: { page: p } }));
}) satisfies GetStaticPaths;

interface Props { page: PageEntry; }
const { page } = Astro.props;
---
<StaticPage locale={locale} page={page} />
