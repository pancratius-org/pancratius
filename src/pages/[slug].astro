---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import SupportChannels from "@/components/SupportChannels.astro";

import type { Locale } from "@/lib/i18n";
import { pageUrl } from "@/lib/i18n";
import { alternateLanguagePage, getPagesForSlugRoute, type PageEntry } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";

const locale: Locale = "ru";

export const getStaticPaths = (async () => {
  const pages = await getPagesForSlugRoute("ru");
  return pages.map(p => ({ params: { slug: p.data.slug }, props: { page: p } }));
}) satisfies GetStaticPaths;

interface Props { page: PageEntry; }
const { page } = Astro.props;
const { Content, headings } = await render(page);

const altEn = await alternateLanguagePage(page, "en");
const authoredLocales = new Set<Locale>(["ru"]);
if (altEn) authoredLocales.add("en");

const seo = seoForPage(Astro.site, page, authoredLocales);

const alternates: Partial<Record<Locale, string>> = {};
if (altEn) alternates.en = pageUrl(altEn.data.slug, "en");

// Pick a prose-modifier class for slug-specific typography.
const PROSE_CLASS: Record<string, string> = {
  mission:  "prose prose--manifesto",
  about:    "prose prose--bio",
  svetozar: "prose prose--svet",
  // license/support/downloads stay default
};
const proseClass = PROSE_CLASS[page.data.slug] ?? "prose";

// Bio layout opts out of the ToC pattern: it has its own portrait+facts
// rail. Mission is a manifesto — the structure is visual, not navigable.
const isBio = page.data.slug === "about" && page.data.portrait;
// Support — editorial copy left, channels widget right. Channels are
// supplied via frontmatter (page.data.channels). A small atom-seal
// stamps the foot as a quiet identity mark; the widget itself is the
// centrepiece, not the seal.
const isSupport = page.data.slug === "support";
const channels = isSupport ? (page.data.channels ?? []) : [];
const useToc =
  !isBio &&
  !isSupport &&
  page.data.slug !== "mission" &&
  headings.some(h => h.depth >= 2 && h.depth <= 3);
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <article
    class:list={[
      "static",
      useToc && "static--with-toc",
      isBio && "static--bio",
      isSupport && "static--support",
    ]}
  >
    <header class="static__head">
      {page.data.eyebrow && <p class="eyebrow eyebrow--lg">{page.data.eyebrow}</p>}
      <h1 class="static__title">{page.data.title}</h1>
      {page.data.sub && <p class="static__sub">{page.data.sub}</p>}
    </header>

    {isBio && page.data.portrait && (
      <figure class="static__portrait">
        <img
          src={page.data.portrait.src}
          alt={page.data.portrait.alt}
          loading="lazy"
          decoding="async"
        />
        {(page.data.portrait.caption || page.data.portrait.meta) && (
          <figcaption>
            {page.data.portrait.caption && <span>{page.data.portrait.caption}</span>}
            {page.data.portrait.meta    && <span>{page.data.portrait.meta}</span>}
          </figcaption>
        )}
      </figure>
    )}

    {useToc && <TableOfContents headings={headings} locale={locale} />}

    <div class={proseClass}>
      <Content />
      {isBio && page.data.facts && page.data.facts.length > 0 && (
        <dl class="static__facts">
          {page.data.facts.map(f => (
            <div>
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </div>

    {isSupport && (
      <div class="support-widget">
        <SupportChannels channels={channels} locale={locale} />
        <svg
          class="support-seal"
          viewBox="0 0 32 32"
          aria-hidden="true"
          focusable="false"
        >
          <circle cx="16" cy="16" r="10" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="16" cy="16" r="2.4" fill="currentColor" />
        </svg>
      </div>
    )}
  </article>
</Base>

<style>
  .static {
    max-width: 44rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--rail);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .static__head { margin-bottom: 0.5rem; }
  .static__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.8rem, 5.8vw, 4.3rem);
    line-height: 0.98;
    margin: 0;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .static__sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    line-height: 1.45;
    color: var(--accent);
    margin: 0.6rem 0 0;
    max-width: 36rem;
    text-wrap: balance;
  }

  /*
   * Portrait figure — Bio register only. Renders inline on mobile (above
   * the body), and is grid-positioned into a left rail at ≥900px by the
   * `.static--bio` rule below. Frame mirrors the home page portrait so
   * the two surfaces feel continuous.
   */
  .static__portrait {
    margin: 0 auto;
    max-width: 280px;
  }
  .static__portrait img {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-rise);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.45),
      0 40px 60px -30px rgba(0, 0, 0, 0.55);
    filter: saturate(0.95) contrast(1.02);
  }
  :global([data-theme="light"]) .static__portrait img {
    box-shadow:
      0 1px 0 rgba(20, 17, 13, 0.06),
      0 30px 50px -25px rgba(60, 45, 20, 0.30);
  }
  .static__portrait figcaption {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .static__portrait figcaption span:first-child { color: var(--ink-soft); }

  /*
   * Two layouts at ≥1100px:
   *
   *   1. With ToC (`.static--with-toc`): three-row grid — head spans
   *      both columns; below, the ToC sticks in the left rail and the
   *      prose flows in the right column.
   *   2. Without ToC (no modifier): single centred column. The earlier
   *      version always allocated a 220px ToC column, leaving the title
   *      and body floating on opposite sides of an empty rail —
   *      Mission, Поддержка, License all looked disbalanced because of
   *      this. With useToc=false we now collapse cleanly.
   */
  @media (min-width: 1100px) {
    .static--with-toc {
      grid-template-columns: 220px 1fr;
      grid-template-areas:
        "head head"
        "toc  body";
      max-width: 64rem;
      gap: 2.5rem 3rem;
    }
    .static--with-toc .static__head { grid-area: head; }
    .static--with-toc :global(.toc-aside) { grid-area: toc; }
    .static--with-toc .prose,
    .static--with-toc .prose--manifesto,
    .static--with-toc .prose--bio { grid-area: body; }
  }

  /*
   * Bio layout. At ≥900px the page becomes a two-column composition:
   * portrait left, head + body right. At <900px the portrait stacks
   * above the body (still after the head, which holds the eyebrow and
   * title — they want to lead).
   */
  @media (min-width: 900px) {
    .static--bio {
      max-width: 64rem;
      grid-template-columns: 280px minmax(0, 1fr);
      grid-template-areas:
        "head    head"
        "portrait body";
      gap: 2.5rem 3.2rem;
      align-items: start;
    }
    .static--bio .static__head      { grid-area: head; }
    .static--bio .static__portrait  { grid-area: portrait; position: sticky; top: 6rem; }
    .static--bio .prose--bio        { grid-area: body; }
  }

  /*
   * Bio facts <dl>. Two-column rows at desktop (label / value),
   * stacked on mobile. Lives inside `.prose--bio` so prose layout
   * doesn't double-pad it; visually a separate gesture (top rule +
   * generous breath) that closes the page.
   */
  .static__facts {
    margin: 3.2rem 0 0;
    padding-top: 1.6rem;
    border-top: 1px solid var(--rule);
    display: grid;
    gap: 0.9rem 1.6rem;
    grid-template-columns: 1fr;
  }
  .static__facts > div {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.15rem;
  }
  .static__facts dt {
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .static__facts dd {
    margin: 0;
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink);
  }
  @media (min-width: 560px) {
    .static__facts > div {
      grid-template-columns: 9rem minmax(0, 1fr);
      align-items: baseline;
      gap: 1rem;
    }
    .static__facts dt { margin-top: 0.18em; }
  }

  /*
   * Support — editorial copy + channels widget composition.
   *
   * The blockquote at the top of the body acts as a serif-italic pull
   * opener (sets voice in one sentence). Body paragraphs read at full
   * column width — no 34ch clamp. The closing line is the last paragraph
   * of the markdown (italic-free, just sits at body register), so the
   * widget on the right doesn't fight against a centred footer.
   */
  .static--support :global(.prose blockquote) {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2.2vw, 1.85rem);
    line-height: 1.32;
    color: var(--ink);
    border-left: none;
    padding: 0;
    margin: 0 0 2rem;
    text-wrap: balance;
    max-width: none;
  }
  .static--support :global(.prose blockquote p) {
    margin: 0;
    font-style: italic;
  }
  /* Body paragraphs at the natural column width — no 34ch clamp. The
     layout grid already gives the left column a sensible measure. */
  .static--support :global(.prose p) {
    color: var(--ink-soft);
    max-width: none;
  }
  .static--support :global(.prose > p:last-child) {
    margin-top: 1.6rem;
    font-style: italic;
    color: var(--ink-soft);
  }

  .support-widget {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    align-items: stretch;
    width: 100%;
  }
  /* Small atom-seal stamp under the widget — quiet identity mark, not
     the centrepiece. */
  .support-seal {
    display: block;
    width: 28px;
    height: 28px;
    margin: 0.4rem auto 0;
    color: var(--accent);
    opacity: 0.85;
  }

  /* Two-column composition at ≥920px: head spans both, prose left,
     widget right. Mobile stacks: head, prose, widget. */
  @media (min-width: 920px) {
    .static--support {
      max-width: 68rem;
      grid-template-columns: minmax(0, 1.4fr) minmax(280px, 1fr);
      grid-template-areas:
        "head    head"
        "body    widget";
      gap: 2.5rem 3.5rem;
      align-items: start;
    }
    .static--support .static__head    { grid-area: head; }
    .static--support .prose           { grid-area: body; max-width: none; }
    .static--support .support-widget  { grid-area: widget; position: sticky; top: 6rem; }
  }
  @media (min-width: 1180px) {
    .static--support {
      grid-template-columns: minmax(0, 1.5fr) minmax(320px, 1fr);
    }
  }
</style>
