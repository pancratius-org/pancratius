---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";

import Base     from "@/layouts/Base.astro";
import Colophon from "@/components/Colophon.astro";

import { coverAbsoluteUrl } from "@/lib/covers";
import { DEFAULT_LOCALE, downloadUrl, kindIndexUrl } from "@/lib/i18n";
import { availableFormatsForWork, type DownloadFormat } from "@/lib/downloads";
import { sameSitePath } from "@/lib/paths";
import { seoForWork } from "@/lib/seo";
import { getPairsByKind, poemDate, type WorkPair } from "@/lib/works";

const locale = DEFAULT_LOCALE;

export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("poem");
  return pairs.map(p => ({
    params: { slug: p.entries[DEFAULT_LOCALE]!.data.slug },
    props: { pair: p },
  }));
}) satisfies GetStaticPaths;

interface Props { pair: WorkPair; }
const { pair } = Astro.props;
const entry = pair.entries[DEFAULT_LOCALE]!;
const { Content } = await render(entry);
const coverUrl = await coverAbsoluteUrl(Astro.site, pair, locale);
const seo = seoForWork(Astro.site, { pair, locale, coverUrl });
const backHref = kindIndexUrl("poem", locale);
const date = poemDate(entry);
const formats = availableFormatsForWork(pair, locale);

const FORMAT_LABEL: Record<DownloadFormat, string> = {
  md:   "Markdown",
  txt:  "TXT",
  docx: "DOCX",
  pdf:  "PDF",
  epub: "EPUB",
};
---
<Base locale={locale} seo={seo} alternates={{}}>
  <article class="poem-page">
    <a class="poem-page__back" href={sameSitePath(backHref)}>← к стихам</a>

    <header class="poem-page__head">
      <p class="poem-page__meta">
        Стихотворение
        <span class="poem-page__num">№ {String(pair.number).padStart(2, "0")}</span>
        {date && <time datetime={String(date)}>· {String(date)}</time>}
      </p>
      <h1 class="poem-page__title">{entry.data.title}</h1>
      {formats.length > 0 && (
        <p class="poem-page__downloads" aria-label="Скачать">
          <span class="poem-page__downloads-label">Скачать:</span>
          {formats.map((fmt, i) => (
            <>
              {i > 0 && <span class="poem-page__downloads-sep">·</span>}
              <a href={sameSitePath(downloadUrl(pair.kind, entry.data.slug, fmt, locale))} download>{FORMAT_LABEL[fmt]}</a>
            </>
          ))}
          <span class="poem-page__downloads-sep">·</span>
          <button type="button" class="book-page__share" data-share data-share-copied="Скопировано" data-share-failed="Не получилось">
            Поделиться
          </button>
        </p>
      )}
    </header>

    <div
      class="prose prose--poem poem-page__body"
      data-pagefind-body
      data-pagefind-meta={`title:${entry.data.title}`}
    >
      <Content />
    </div>

    {/* Editorial close: a small ornament between the last verse and the
        colophon, so the reader feels a deliberate "fin" before the
        bibliographic block. Decorative — hidden from AT. */}
    <div class="poem-page__end" aria-hidden="true">·  ·  ·</div>

    <Colophon pair={pair} locale={locale} />
  </article>
</Base>

<style>
  .poem-page { max-width: 50rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .poem-page__back {
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 2.5rem;
    text-decoration: none;
  }
  .poem-page__back:hover { color: var(--accent); }
  .poem-page__head { margin-bottom: 2rem; }
  .poem-page__meta {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.6rem;
    display: flex;
    gap: 0.7rem;
    align-items: baseline;
  }
  .poem-page__num {
    color: var(--accent);
    font-style: italic;
    font-variant-numeric: oldstyle-nums proportional-nums;
    text-transform: none;
    letter-spacing: 0.05em;
  }
  .poem-page__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.012em;
  }
  .poem-page__downloads {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: baseline;
    margin: 1.2rem 0 0;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .poem-page__downloads-label { color: var(--ink-soft); font-weight: 500; }
  .poem-page__downloads a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .poem-page__downloads a:hover { color: var(--accent); }
  .poem-page__downloads-sep { color: var(--rule-2); }

  /* Poem opener: the first letter of the first verse picks up an oldstyle
     ember capital — large enough to anchor the page, not so large that it
     becomes a full drop cap (poems are too short for that gesture). The
     manifesto/poem variants of `.prose` unset `::first-letter` styling,
     so we re-apply it here at a more restrained scale. */
  .poem-page__body > :global(p:first-of-type)::first-letter,
  .poem-page__body > :global(h2:first-child + p)::first-letter {
    font-family: var(--serif);
    font-style: italic;
    font-size: 2.4em;
    line-height: 0.95;
    color: var(--accent);
    padding-right: 0.06em;
    vertical-align: -0.05em;
    font-feature-settings: "onum" 1, "kern" 1;
  }

  /* Editorial closing ornament: three centred dots in accent, between
     the verses and the colophon. Re-uses the visual idiom of `.prose hr`
     (three asterisks) but at a lighter intensity since a poem's close
     is quieter than a chapter break. */
  .poem-page__end {
    text-align: center;
    margin: 2.8rem 0 1.6rem;
    color: var(--accent);
    font-family: var(--serif);
    font-size: 1.2rem;
    letter-spacing: 0.4em;
    padding-left: 0.4em;
    user-select: none;
  }
</style>
