---
// /conceptosphere/ — the public corpus map.
//
// The graph data is RU-derived (concept lemmas and book titles ship as
// Russian), but the chrome — mode toggle, search, side panel, methodology
// footer — localises like everything else on the site. This file owns the
// RU surface; `/en/conceptosphere/` mirrors it with `locale: "en"`.
//
// Two surfaces ship in the same HTML:
//   * the desktop graph (Sigma 3 + graphology, bundled via npm) — mounts
//     after the page paints; never CDN.
//   * the mobile grouped list — statically rendered for every node so the
//     content is readable without JS and without WebGL.

import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { workUrl } from "@/lib/i18n";
import { loadBooksGraph, loadConceptsGraph } from "@/lib/conceptosphere";
import { findPair } from "@/lib/works";
import { coverAssetUrl } from "@/lib/covers";

import GraphCanvas from "@/components/conceptosphere/GraphCanvas.astro";
import MobileList  from "@/components/conceptosphere/MobileList.astro";
import { conceptosphereStrings } from "@/components/conceptosphere/strings";

const locale: Locale = "ru";
const t = conceptosphereStrings(locale);
const canonical = new URL("/conceptosphere/", Astro.site).toString();
const enHref    = new URL("/en/conceptosphere/", Astro.site).toString();

const seo = {
  title:       "Концептосфера — Панкратиус",
  description: "Карта понятий и связи между книгами Панкратиуса. Граф концептов и граф книг по совместному появлению.",
  canonical,
  ogImage:     null,
  ogType:      "website" as const,
  alternates:  [
    { hreflang: "ru" as const, href: canonical },
    { hreflang: "en" as const, href: enHref },
    { hreflang: "x-default", href: canonical },
  ],
  jsonLd:      null,
  locale,
};

// Build the (kind, slug) → cover URL map for every book the graph references.
// The graph script renders side-panel cover thumbnails and similarity rows;
// resolving covers at build time keeps the client off `astro:content` and
// avoids brittle `./cover.ru.jpg` paths that the prototype synthesised by
// stripping numeric prefixes from slugs.
const booksGraph = loadBooksGraph();
const conceptsGraph = loadConceptsGraph();

// Collect every book slug referenced anywhere in either payload.
const referencedBookSlugs = new Set<string>();
for (const n of booksGraph.nodes) {
  referencedBookSlugs.add(n.slug);
  for (const s of n.top_similar ?? []) referencedBookSlugs.add(s.slug);
  for (const s of n.top_similar_embed ?? []) referencedBookSlugs.add(s.slug);
}
for (const n of conceptsGraph.nodes) {
  for (const b of (n as { top_books?: { slug: string }[] }).top_books ?? []) {
    referencedBookSlugs.add(b.slug);
  }
}

// Resolve covers via the same import.meta.glob pipeline that powers
// BookCover.astro elsewhere. Missing pairs simply produce `null` — the
// runtime then paints the empty-cover hatch pattern.
const coverUrls: Record<string, string> = {};
const bookSlugInfo: Record<string, { number: number; title: string; href: string }> = {};
for (const slug of referencedBookSlugs) {
  const node = booksGraph.nodes.find((n) => n.slug === slug);
  if (!node) continue;
  const pair = await findPair("book", node.number);
  const title = pair?.ru.data.title ?? node.title;
  const href  = workUrl("book", pair?.ru.data.slug ?? node.slug, "ru");
  bookSlugInfo[slug] = { number: node.number, title, href };
  if (!pair) continue;
  const url = await coverAssetUrl(pair, locale);
  if (url) coverUrls[`book:${slug}`] = url;
}

// Stats line in the footer (initial value matches concepts because the
// runtime starts on the persisted mode but defaults to concepts). The
// runtime overwrites this text the moment the active payload finishes
// loading; this baseline keeps the JS-disabled load from looking empty.
const baselineCounts =
  `${conceptsGraph.stats.kept_nodes ?? conceptsGraph.nodes.length} ${t.modes.concepts.countsNoun} · ${conceptsGraph.stats.edges ?? conceptsGraph.edges.length} ${t.edgesNoun} · ${conceptsGraph.stats.communities ?? conceptsGraph.communities.length} ${t.communitiesNoun}`;

const initialMode: "concepts" | "books" = "concepts";
---
<Base
  locale={locale}
  seo={seo}
  alternates={{ en: "/en/conceptosphere/" }}
  mainClass="cs-main"
>
  <header class="cs-page-head">
    <h1 id="cs-page-h1">{t.modes.concepts.h1}</h1>
    <p class="cs-lede" id="cs-page-lede">
      {t.modes.concepts.lede}
    </p>
    <div class="cs-method">
      <span class="cs-method__trigger" tabindex="0" aria-describedby="cs-method-panel">
        {t.methodSummary}
      </span>
      <div class="cs-method__panel" id="cs-method-panel" role="note">
        <p class="cs-meth" id="cs-page-meth">{t.modes.concepts.meth}</p>
        <p class="cs-meta" id="cs-counts">{baselineCounts}</p>
      </div>
    </div>
  </header>

  <GraphCanvas
    locale={locale}
    conceptsUrl="/data/pancratius-concepts-graph.json"
    booksUrl="/data/pancratius-books-graph.json"
    initialMode={initialMode}
    bookSlugInfo={bookSlugInfo}
    coverUrls={coverUrls}
  />

  <MobileList locale={locale} initialMode={initialMode} />
</Base>

<style is:global>
  /* ─── Conceptosphere theme tokens. Resolved against the site palette so
       light and dark are both real designed registers. ─────────────────── */
  :root {
    --cs-stage-bg:   #06080c;
    --cs-panel-bg:   rgba(13, 17, 23, 0.86);
    --cs-panel-strong: rgba(13, 17, 23, 0.94);
    --cs-bg-soft:    #0d1117;
    --cs-rule:       rgba(232, 227, 214, 0.14);
    --cs-rule-2:     rgba(232, 227, 214, 0.24);
    --cs-ink:        #e8e3d6;
    --cs-ink-faint:  rgba(232, 227, 214, 0.62);
    --cs-ink-trace:  rgba(232, 227, 214, 0.36);
    --cs-ink-edge:   rgba(232, 227, 214, 0.12);
    --cs-grain-opacity: 0.035;

    /* Painter-facing values. Kept as plain rgba so they ship straight into a
       2D context (which doesn't understand color-mix). */
    --cs-label-color: #faf5e8;
    --cs-label-halo:  rgba(6, 8, 12, 0.76);
    --cs-badge-halo:  rgba(6, 8, 12, 0.75);
    --cs-badge-ink:   #f3eee0;
    --cs-callout-bg:  rgba(9, 11, 16, 0.96);
    --cs-callout-ink: #f3eee0;
    --cs-dim-node:    rgba(70, 65, 55, 0.45);
    --cs-dim-edge:    rgba(80, 70, 55, 0.04);
    --cs-toggle-active-bg: rgba(233, 161, 66, 0.18);
  }
  [data-theme="light"] {
    /* Light register — the void becomes warm paper. Painters get inverted
       so labels and badges read as dark ink on the disc, with a soft paper
       halo for separation. */
    --cs-stage-bg:    #fbf8f0;
    --cs-panel-bg:    rgba(251, 250, 246, 0.93);
    --cs-panel-strong: rgba(251, 250, 246, 0.96);
    --cs-bg-soft:     #efe6d4;
    --cs-rule:        rgba(45, 36, 24, 0.18);
    --cs-rule-2:      rgba(45, 36, 24, 0.30);
    --cs-ink:         #211b14;
    --cs-ink-faint:   rgba(33, 27, 20, 0.66);
    --cs-ink-trace:   rgba(33, 27, 20, 0.42);
    --cs-ink-edge:    rgba(33, 27, 20, 0.16);
    --cs-grain-opacity: 0;

    --cs-label-color: #1d1710;
    --cs-label-halo:  rgba(251, 250, 246, 0.97);
    --cs-badge-halo:  rgba(251, 250, 246, 0.95);
    --cs-badge-ink:   #2a241a;
    --cs-callout-bg:  rgba(251, 250, 246, 0.98);
    --cs-callout-ink: #2a241a;
    --cs-dim-node:    rgba(92, 78, 58, 0.52);
    --cs-dim-edge:    rgba(70, 48, 24, 0.18);
    --cs-toggle-active-bg: rgba(166, 100, 25, 0.16);
  }
</style>

<style>
  /* `.cs-main` is set on <main> by Base.astro, so the selector needs to
     pierce Astro's scope — otherwise the scoped-attribute selector won't
     match (Base's template doesn't carry this page's data-astro-cid) and
     the desktop fixed-position layout silently breaks. */
  :global(.cs-main) {
    /* The conceptosphere takes over the viewport between header/footer.
       Reset main's default bottom padding so the graph reaches the page foot. */
    padding-bottom: 0;
  }

  .cs-page-head {
    position: relative;
    z-index: 60;
    padding: 10px var(--rail);
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    gap: 1.15rem;
    min-height: 42px;
  }
  .cs-page-head h1 {
    flex: 0 0 auto;
    font-family: var(--mono);
    font-weight: 500;
    font-size: 11px;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }
  .cs-page-head .cs-lede {
    flex: 1 1 auto;
    margin: 0;
    max-width: none;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.55;
    font-style: italic;
    min-height: 0;
  }

  .cs-method {
    position: relative;
    flex: 0 0 auto;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-mute);
    z-index: 50;
  }
  .cs-method__trigger {
    display: inline-block;
    cursor: help;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: color 120ms ease;
    white-space: nowrap;
    outline: none;
  }
  .cs-method__trigger:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 4px;
  }
  .cs-method__trigger:hover,
  .cs-method:focus-within .cs-method__trigger { color: var(--accent); }
  .cs-method__panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(38rem, calc(100vw - var(--rail) * 2));
    padding: 14px 16px;
    background: var(--cs-panel-strong);
    border: 1px solid var(--cs-rule);
    color: var(--cs-ink-faint);
    box-shadow: 0 16px 42px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity 120ms ease, transform 120ms ease, visibility 120ms ease;
  }
  .cs-method:hover .cs-method__panel,
  .cs-method:focus-within .cs-method__panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  .cs-method__panel p {
    margin: 0;
  }
  .cs-method__panel .cs-meta {
    margin-top: 10px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  /* Desktop graph layout: head, then a flex stage, then foot, all locked
     into the viewport so the canvas occupies a clean rectangle and never
     spawns its own scrollbar. This shape is keyed on `html.cs-js` so the
     JS-disabled / small-screen variant stays in normal block flow. */
  @media (min-width: 701px) {
    :global(html.cs-js body) { overflow: hidden; }
    :global(html.cs-js .cs-main) {
      position: fixed;
      left: 0;
      right: 0;
      top: var(--cs-header-top, 56px);
      bottom: 0;
      display: flex;
      flex-direction: column;
    }
    :global(html.cs-js) .cs-page-head { flex: 0 0 auto; }
  }
  @media (max-width: 700px) {
    .cs-page-head {
      display: block;
      padding: 18px var(--rail) 14px;
    }
    .cs-page-head h1 {
      margin: 0 0 0.45rem;
    }
    .cs-page-head .cs-lede {
      margin-bottom: 0.8rem;
    }
    .cs-method__panel {
      position: static;
      display: none;
      width: auto;
      margin-top: 0.65rem;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
    }
    .cs-method:hover .cs-method__panel,
    .cs-method:focus-within .cs-method__panel {
      display: block;
    }
  }

  /* Internal error surface used by the runtime when the payload fetch fails. */
  :global(.cs-load-error) {
    padding: 24px;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 13px;
  }
</style>

<script is:inline>
  // Two jobs, both intentionally inline so they run before paint:
  //   1. Add `cs-js` to <html> so the conceptosphere swaps from its
  //      JS-disabled register (mobile list everywhere) to its full register
  //      (desktop = graph, ≤700px = list). No FOUC on a working browser.
  //   2. Measure the sticky site header so `.cs-main` can position itself
  //      directly below it on desktop.
  (function () {
    document.documentElement.classList.add("cs-js");
    function update() {
      const header = document.querySelector("header.rail");
      if (!header) return;
      const h = header.getBoundingClientRect().height;
      document.documentElement.style.setProperty("--cs-header-top", h + "px");
    }
    update();
    window.addEventListener("resize", update);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(update);
    }
  })();
</script>
