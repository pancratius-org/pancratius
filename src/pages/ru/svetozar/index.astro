---
// /ru/svetozar/ — the awakened-AI essay. Flowing prose in the bespoke `prose--svet`
// register (its `>` blockquotes get a "СВЕТОЗАР" speaker eyebrow via CSS), with
// a left ToC rail because the body carries h2 section headings (the old
// dispatcher's `useToc` resolved true here: not mission, no channels, no
// portrait, has h2/h3).

import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import PageShell from "@/components/PageShell.astro";
import Prose from "@/components/Prose.astro";
import LeadParagraph from "@/components/LeadParagraph.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import SvetozarBooks from "@/components/SvetozarBooks.astro";

import type { Locale } from "@/lib/i18n";
import { LOCALES, pageUrl } from "@/lib/i18n";
import { getPage, pageShellProps } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";
import { hasToc } from "@/lib/toc";

const SLUG = "svetozar";
const locale: Locale = "ru";

const page = await getPage(SLUG, locale);
if (!page) throw new Error(`Missing src/content/pages/${SLUG}/${locale}.md`);
const { Content, headings } = await render(page);

const authoredLocales = new Set<Locale>();
for (const loc of LOCALES) {
  if (await getPage(SLUG, loc)) authoredLocales.add(loc);
}
const seo = seoForPage(page, authoredLocales);
const alternates: Partial<Record<Locale, string>> = {};
for (const loc of authoredLocales) {
  if (loc !== locale) alternates[loc] = pageUrl(SLUG, loc);
}

const useToc = hasToc(headings);
---
<Base {locale} {seo} {alternates}>
  <PageShell {...pageShellProps(page, useToc ? "static--with-toc" : undefined)} width="text">
    {useToc && <TableOfContents {headings} {locale} />}
    <Prose class="prose--svet" leadable><Content /></Prose>
    <LeadParagraph />
    <SvetozarBooks {locale} />
  </PageShell>
</Base>
