---
import { DEFAULT_LOCALE, homeUrl } from "@/lib/i18n";

// The bare `/` has no content under prefix-all i18n; redirect to the
// default-locale home. Static output bakes this as an instant `<meta refresh>`
// (no adapter → no real 301); `.org` upgrades to a true 301 at the edge.
// See docs/architecture.md (Apex redirect is host-decided).
return Astro.redirect(homeUrl(DEFAULT_LOCALE), 301);
---
