---
// /downloads/ - bulk-archive index.

import { render } from "astro:content";

import DownloadsPage from "@/components/DownloadsPage.astro";
import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { LOCALES, pageUrl } from "@/lib/i18n";
import { getPage } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";
import { loadArchiveManifest } from "@/lib/bulk-archives";

const locale: Locale = "ru";

const page = await getPage("downloads", locale);
if (!page) {
  throw new Error("Missing src/content/pages/downloads/ru.md");
}
const { Content } = await render(page);
const authoredLocales = new Set<Locale>();
for (const loc of LOCALES) {
  if (await getPage("downloads", loc)) authoredLocales.add(loc);
}
const seo = seoForPage(Astro.site, page, authoredLocales);
const alternates: Partial<Record<Locale, string>> = {};
for (const loc of authoredLocales) {
  if (loc !== locale) alternates[loc] = pageUrl("downloads", loc);
}
const { archives, generatedAt } = loadArchiveManifest();
---
<Base {locale} seo={seo} alternates={alternates}>
  <DownloadsPage {locale} {page} archives={archives} generatedAt={generatedAt}>
    <Content />
  </DownloadsPage>
</Base>
