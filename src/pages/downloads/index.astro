---
// /downloads/ - bulk-archive index.

import { render } from "astro:content";

import DownloadsPage from "@/components/DownloadsPage.astro";
import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { pageUrl } from "@/lib/i18n";
import { getPage } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";
import { loadArchiveManifest } from "@/lib/bulk-archives";

const locale: Locale = "ru";

const page = await getPage("downloads", locale);
if (!page) {
  throw new Error("Missing src/content/pages/downloads/ru.md");
}
const { Content } = await render(page);
const enPage = await getPage("downloads", "en");
const authoredLocales = new Set<Locale>(["ru"]);
if (enPage) authoredLocales.add("en");
const seo = seoForPage(Astro.site, page, authoredLocales);
const { archives, generatedAt } = loadArchiveManifest();
---
<Base locale={locale} seo={seo} alternates={enPage ? { en: pageUrl("downloads", "en") } : {}}>
  <DownloadsPage locale={locale} page={page} archives={archives} generatedAt={generatedAt}>
    <Content />
  </DownloadsPage>
</Base>
