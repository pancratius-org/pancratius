---
// /en/downloads/ - localized bulk-archive index.

import { render } from "astro:content";

import DownloadsPage from "@/components/DownloadsPage.astro";
import Base from "@/layouts/Base.astro";
import { loadArchiveManifest } from "@/lib/bulk-archives";
import type { Locale } from "@/lib/i18n";
import { pageUrl } from "@/lib/i18n";
import { getPage } from "@/lib/pages";
import { seoForPage } from "@/lib/seo";

const locale: Locale = "en";

const page = await getPage("downloads", locale);
if (!page) {
  throw new Error("Missing src/content/pages/downloads/en.md");
}
const { Content } = await render(page);
const ruPage = await getPage("downloads", "ru");
const authoredLocales = new Set<Locale>(["en"]);
if (ruPage) authoredLocales.add("ru");
const seo = seoForPage(Astro.site, page, authoredLocales);
const { archives, generatedAt } = loadArchiveManifest();
---
<Base locale={locale} seo={seo} alternates={ruPage ? { ru: pageUrl("downloads", "ru") } : {}}>
  <DownloadsPage locale={locale} page={page} archives={archives} generatedAt={generatedAt}>
    <Content />
  </DownloadsPage>
</Base>
