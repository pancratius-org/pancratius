---
import type { GetStaticPaths } from "astro";

import BookPage from "@/components/BookPage.astro";
import { getPairsByKind, localizedWorkPairs } from "@/lib/works";

export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("book");
  return localizedWorkPairs(pairs, "en")
    .map(({ pair, entry }) => ({ params: { slug: entry.data.slug }, props: { pair } }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<BookPage {pair} locale="en" />
