---
import Base           from "@/layouts/Base.astro";
import BookCard       from "@/components/BookCard.astro";
import LibraryFilter  from "@/components/LibraryFilter.astro";

import type { Locale } from "@/lib/i18n";
import { kindIndexUrl } from "@/lib/i18n";
import { seoForKindIndex, clampDescription } from "@/lib/seo";
import { getPairsByKind, workTags } from "@/lib/works";

const locale: Locale = "en";
const allPairs = await getPairsByKind("book");
const pairs = allPairs.filter(p => p.en !== null);  // EN-available only
const seo = seoForKindIndex(Astro.site, "book", locale);

const tagCounts = new Map<string, number>();
for (const p of pairs) {
  const tagsForBook = p.en ? workTags(p.en) : workTags(p.ru);
  for (const t of tagsForBook) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].map(([label, count]) => ({ label, count }));

const alternates = { ru: new URL(kindIndexUrl("book", "ru"), Astro.site).toString() };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page lib">
    <p class="eyebrow">Observatory of Light</p>
    <div class="lib__head">
      <h1><b>{pairs.length}</b> books in English</h1>
      <p class="lib__sub">
        Of {allPairs.length} books in the corpus, {pairs.length} have been translated into English.
        <a href={alternates.ru}>See the full Russian catalogue</a>.
      </p>
    </div>

    <LibraryFilter locale={locale} tags={tags} total={pairs.length} />

    <div class="index" role="list" data-pagefind-ignore>
      {pairs.map(p => (
        <BookCard pair={p} locale={locale} blurb={clampDescription((p.en ?? p.ru).data.description, 120)} />
      ))}
    </div>
  </section>
</Base>

<style>
  .lib__head {
    display: flex;
    flex-direction: column;
    margin-bottom: 2.5rem;
    gap: 1rem;
  }
  .lib__head h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 0.98;
    margin: 0;
    letter-spacing: -0.018em;
  }
  .lib__head h1 b {
    font-weight: 500;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-style: italic;
    color: var(--accent);
  }
  .lib__sub {
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-soft);
    margin: 0;
    max-width: 36rem;
  }
  .index {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.25rem 2rem;
    margin-top: 1rem;
  }
  @media (max-width: 720px) {
    .index { grid-template-columns: 1fr; gap: 1.75rem; }
  }
</style>
