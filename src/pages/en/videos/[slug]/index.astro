---
import type { GetStaticPaths } from "astro";

import VideoPage from "@/components/VideoPage.astro";
import { getAllVideoPairs, localizedVideoPairs } from "@/lib/videos";

export const getStaticPaths = (async () => {
  const pairs = await getAllVideoPairs();
  return localizedVideoPairs(pairs, "en")
    .map(({ pair, entry }) => ({ params: { slug: entry.data.slug }, props: { pair } }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<VideoPage {pair} locale="en" />
