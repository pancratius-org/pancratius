---
import type { GetStaticPaths } from "astro";

import VideoPage from "@/components/VideoPage.astro";
import { getAllVideoPairs } from "@/lib/videos";

export const getStaticPaths = (async () => {
  const pairs = await getAllVideoPairs();
  return pairs
    .filter(p => p.entries.en)
    .map(p => ({ params: { slug: p.entries.en!.data.slug }, props: { pair: p } }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<VideoPage pair={pair} locale="en" />
