---
import Base from "@/layouts/Base.astro";
import { LOCALE_META } from "@/lib/i18n";
import { notFoundCopy } from "@/lib/copy";
import { sameSitePath } from "@/lib/paths";
import { absUrl } from "@/lib/seo";

const locale = "en" as const;
const copy = notFoundCopy[locale];
const seo = {
  title:       copy.title,
  description: copy.description,
  canonical:   absUrl(Astro.site, "/en/404"),
  ogImage:     null,
  ogType:      "website" as const,
  alternates:  [],
  jsonLd:      null,
  locale,
  ogLocale:    LOCALE_META[locale].ogLocale,
  siteName:    LOCALE_META[locale].siteLabel,
};
---
<Base locale={locale} seo={seo} alternates={{}}>
  <section class="nf">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.heading}</h1>
    <p>{copy.body}</p>
    <p class="nf__links">
      <a href={sameSitePath("/en/")}>{copy.toHome}</a>
      <span class="sep">·</span>
      <a href={sameSitePath("/en/books/")}>{copy.toBooks}</a>
      <span class="sep">·</span>
      <a href={sameSitePath("/en/search/")}>{copy.toSearch}</a>
    </p>
  </section>
</Base>

<style>
  .nf {
    max-width: 36rem;
    margin: 0 auto;
    padding: clamp(5rem, 12vw, 9rem) var(--rail);
    text-align: center;
  }
  .nf .eyebrow { color: var(--accent); }
  .nf h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3.2rem, 8.2vw, 5.4rem);
    line-height: 0.98;
    margin: 0.4rem 0 1.5rem;
    letter-spacing: -0.024em;
  }
  .nf p {
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-soft);
    margin: 0 0 1.5rem;
  }
  .nf__links {
    font-family: var(--sans);
    font-style: normal;
    font-size: 12.5px;
    letter-spacing: 0.06em;
  }
  .nf__links a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-2);
  }
  .nf__links a:hover { color: var(--accent); }
  .nf__links .sep { color: var(--rule-2); padding: 0 0.4em; }
</style>
