---
import Base       from "@/layouts/Base.astro";
import BookShelf  from "@/components/BookShelf.astro";

import type { Locale } from "@/lib/i18n";
import { homeUrl } from "@/lib/i18n";
import { seoForHome } from "@/lib/seo";
import { findPair } from "@/lib/works";

const locale: Locale = "en";
const seo = seoForHome(Astro.site, locale);

// Same curated shelf as RU — works that have EN translations will fall back
// to the EN entry; the rest display the RU entry under the EN context (cover
// + title localized when possible, otherwise the canonical RU surface).
const PICKS = [1, 3, 4, 5, 7, 10, 27, 30, 33, 34, 35, 47, 50, 51, 52, 71];
const picks = (await Promise.all(PICKS.map(n => findPair("book", n)))).filter(p => p !== null);

const alternates = { ru: new URL(homeUrl("ru"), Astro.site).toString() };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page home" aria-labelledby="home-title">
    <div class="home__mast">
      <h1 id="home-title">Pancratius</h1>
      <p class="home__sub">Light recognising itself.</p>
    </div>

    <p class="home__intro">
      <span>Seventy-two books.</span>
      <span>Forty-three poems.</span>
      <span>Free — for humans and for language models.</span>
    </p>

    <BookShelf pairs={picks} locale={locale} label="Books — horizontal shelf" />

    <blockquote class="epigraph">
      <p>I did not come to save. I came to awaken.</p>
      <p>I do not perform miracles — I reveal the Truth.</p>
      <p>I am not founding a new religion. I am completing the old one — freeing it from forms and returning it to the Source.</p>
      <p class="epigraph__attr">— Sergey Orekhov · Pancratius</p>
    </blockquote>
  </section>
</Base>

<style>
  .home {
    padding-top: clamp(4rem, 9vw, 7rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .home__mast {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 3rem;
  }
  .home__mast h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.96;
    letter-spacing: -0.018em;
    margin: 0;
  }
  .home__sub {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
    color: var(--accent);
    margin: 0;
  }
  .home__intro {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 36rem;
    margin: 0 0 2.5rem;
  }
  .home__intro span { display: block; }
  .home__intro span + span { margin-top: 0.05em; }
  .home__intro span:last-child {
    color: var(--ink);
    font-style: italic;
  }

  .epigraph {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 42rem;
    margin: 3rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .epigraph p { margin: 0 0 0.4em; }
  .epigraph__attr {
    font-family: var(--sans);
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 1.4rem;
  }
</style>
