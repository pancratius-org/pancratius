---
import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, workUrl } from "@/lib/i18n";
import { seoForKindIndex } from "@/lib/seo";
import { getPairsByKind } from "@/lib/works";

const locale: Locale = "en";
const pairs = await getPairsByKind("poem");
const seo = seoForKindIndex(Astro.site, "poem", locale);
const alternates = { ru: kindIndexUrl("poem", "ru") };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page poetry-index">
    <p class="eyebrow eyebrow--lg">Forty-three</p>
    <div class="poetry-index__head">
      <h1><b>{pairs.length}</b> poems</h1>
      <p class="poetry-index__intro">
        The corpus opens in Russian. Each row links to the original;
        English translations will land here as they are authored.
      </p>
    </div>

    <p class="poetry-index__banner">
      Original Russian — translations forthcoming.
    </p>

    <ol class="poems">
      {pairs.map(p => (
        <li>
          <a href={workUrl("poem", p.ru.data.slug, "ru")}>
            <span class="poems__num">{String(p.number).padStart(2, "0")}</span>
            <span class="poems__title">{p.ru.data.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .poetry-index { max-width: 56rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .poetry-index__head {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-bottom: 2rem;
  }
  .poetry-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 7.4vw, 5.4rem);
    line-height: 0.96;
    margin: 0;
    letter-spacing: -0.024em;
  }
  .poetry-index h1 b {
    font-weight: 500;
    font-variant-numeric: oldstyle-nums proportional-nums;
    font-style: italic;
    color: var(--accent);
  }
  .poetry-index__intro {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 38rem;
    margin: 0;
  }

  /* Banner row: single statement that this list is RU originals, so we
     can drop the per-row RU lang badge that was making the list read as
     a CSV of identical suffixes. */
  .poetry-index__banner {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 1.4rem;
    padding: 0.7rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .poems {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .poems li a {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.9rem 0;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .poems li a:hover { color: var(--accent); border-bottom-color: var(--accent-soft); }
  .poems__num {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
  }
  .poems__title { font-family: var(--serif); font-size: 1.1rem; color: var(--ink); }
</style>
