---
import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { kindIndexUrl, workUrl } from "@/lib/i18n";
import { seoForKindIndex } from "@/lib/seo";
import { getPairsByKind } from "@/lib/works";

const locale: Locale = "en";
const pairs = await getPairsByKind("poem");
const seo = seoForKindIndex(Astro.site, "poem", locale);
const alternates = { ru: kindIndexUrl("poem", "ru") };
---
<Base locale={locale} seo={seo} alternates={alternates}>
  <section class="page poetry-index">
    <p class="eyebrow">Forty-three</p>
    <h1>Poetry</h1>
    <p class="poetry-index__intro">
      The poems exist only in Russian for now. The list links back to the originals;
      English translations will land here as they are authored.
    </p>

    <ol class="poems">
      {pairs.map(p => (
        <li>
          <a href={workUrl("poem", p.ru.data.slug, "ru")}>
            <span class="poems__num">{String(p.number).padStart(2, "0")}</span>
            <span class="poems__title">{p.ru.data.title}</span>
            <span class="poems__lang">RU</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .poetry-index { max-width: 56rem; margin: 0 auto; padding: clamp(3.5rem, 7vw, 6rem) var(--rail); }
  .poetry-index h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.8rem, 6.4vw, 4.8rem);
    line-height: 0.98;
    margin: 0 0 0.4em;
    letter-spacing: -0.022em;
  }
  .poetry-index__intro {
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-soft);
    max-width: 38rem;
    margin: 0 0 2.5rem;
  }
  .poems { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.4rem; }
  .poems li a {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.5rem 0;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed var(--rule);
  }
  .poems li a:hover { color: var(--accent); border-bottom-color: var(--accent-soft); }
  .poems__num {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
  }
  .poems__title { font-family: var(--serif); font-size: 1.1rem; color: var(--ink); }
  .poems__lang {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-mute);
  }
</style>
