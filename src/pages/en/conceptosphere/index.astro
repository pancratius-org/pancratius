---
// /en/conceptosphere/ — the English-locale corpus map.
//
// Same components, same data payloads, same theme system as the RU page —
// only the chrome localises. Graph node labels remain Russian because the
// underlying corpus is Russian; an English reader sees the same lemma map
// behind English chrome.

import Base from "@/layouts/Base.astro";
import type { Locale } from "@/lib/i18n";
import { workUrl } from "@/lib/i18n";
import { loadBooksGraph, loadConceptsGraph } from "@/lib/conceptosphere";
import { findPair } from "@/lib/works";
import { coverAssetUrl } from "@/lib/covers";

import GraphCanvas from "@/components/conceptosphere/GraphCanvas.astro";
import MobileList  from "@/components/conceptosphere/MobileList.astro";
import { conceptosphereStrings } from "@/components/conceptosphere/strings";

const locale: Locale = "en";
const t = conceptosphereStrings(locale);
const canonical = new URL("/en/conceptosphere/", Astro.site).toString();
const ruHref    = new URL("/conceptosphere/", Astro.site).toString();

const seo = {
  title:       "Concept map — Pancratius",
  description: "A map of Pancratius's concepts and the connections between his books. A concept graph and a book graph built from co-occurrence.",
  canonical,
  ogImage:     null,
  ogType:      "website" as const,
  alternates:  [
    { hreflang: "ru" as const, href: ruHref },
    { hreflang: "en" as const, href: canonical },
    { hreflang: "x-default", href: ruHref },
  ],
  jsonLd:      null,
  locale,
};

// Same build-time cover resolution path as the RU page. `coverAssetUrl`
// already prefers the localized cover (`cover.en.jpg`) and falls back to RU
// when one isn't present, so an EN reader gets the right side-panel art.
const booksGraph = loadBooksGraph();
const conceptsGraph = loadConceptsGraph();

const referencedBookSlugs = new Set<string>();
for (const n of booksGraph.nodes) {
  referencedBookSlugs.add(n.slug);
  for (const s of n.top_similar ?? []) referencedBookSlugs.add(s.slug);
  for (const s of n.top_similar_embed ?? []) referencedBookSlugs.add(s.slug);
}
for (const n of conceptsGraph.nodes) {
  for (const b of (n as { top_books?: { slug: string }[] }).top_books ?? []) {
    referencedBookSlugs.add(b.slug);
  }
}

const coverUrls: Record<string, string> = {};
const bookSlugInfo: Record<string, { number: number; title: string; href: string }> = {};
for (const slug of referencedBookSlugs) {
  const node = booksGraph.nodes.find((n) => n.slug === slug);
  if (!node) continue;
  const pair = await findPair("book", node.number);
  // Localised title + href in one pass. When the EN sibling exists the
  // reader gets `/en/books/<en-slug>/`; otherwise the link points at the
  // RU canonical so it doesn't 404 on the EN graph.
  const display = pair?.en ?? pair?.ru ?? null;
  const linkLocale: Locale = display === pair?.en ? "en" : "ru";
  const linkSlug = display?.data.slug ?? node.slug;
  const title = display?.data.title ?? node.title;
  const href  = workUrl("book", linkSlug, linkLocale);
  bookSlugInfo[slug] = { number: node.number, title, href };
  if (!pair) continue;
  const url = await coverAssetUrl(pair, locale);
  if (url) coverUrls[`book:${slug}`] = url;
}

const baselineCounts =
  `${conceptsGraph.stats.kept_nodes ?? conceptsGraph.nodes.length} ${t.modes.concepts.countsNoun} · ${conceptsGraph.stats.edges ?? conceptsGraph.edges.length} ${t.edgesNoun} · ${conceptsGraph.stats.communities ?? conceptsGraph.communities.length} ${t.communitiesNoun}`;

const initialMode: "concepts" | "books" = "concepts";
---
<Base
  locale={locale}
  seo={seo}
  alternates={{ ru: ruHref }}
  mainClass="cs-main"
>
  <header class="cs-page-head">
    <h1 id="cs-page-h1">{t.modes.concepts.h1}</h1>
    <p class="cs-lede" id="cs-page-lede">
      {t.modes.concepts.lede}
    </p>
  </header>

  <GraphCanvas
    locale={locale}
    conceptsUrl="/data/pancratius-concepts-graph.json"
    booksUrl="/data/pancratius-books-graph.json"
    initialMode={initialMode}
    bookSlugInfo={bookSlugInfo}
    coverUrls={coverUrls}
  />

  <MobileList locale={locale} initialMode={initialMode} />

  <footer class="cs-page-foot">
    <div class="cs-meth" id="cs-page-meth">
      {t.modes.concepts.meth}
    </div>
    <div class="cs-meta" id="cs-counts">{baselineCounts}</div>
  </footer>
</Base>

<style is:global>
  /* ─── Conceptosphere theme tokens. Resolved against the site palette so
       light and dark are both real designed registers. The RU page defines
       the same global tokens; we keep them in both routes so either page
       can be entered directly with the styles already attached. ────────── */
  :root {
    --cs-panel-bg:   color-mix(in srgb, var(--bg-rise) 88%, transparent);
    --cs-bg-soft:    var(--bg-rise);
    --cs-rule:       var(--rule);
    --cs-rule-2:     var(--rule-2);
    --cs-ink:        var(--ink);
    --cs-ink-faint:  color-mix(in srgb, var(--ink) 62%, transparent);
    --cs-ink-trace:  color-mix(in srgb, var(--ink) 38%, transparent);
    --cs-ink-edge:   color-mix(in srgb, var(--ink) 18%, transparent);
    --cs-violet:     #7c6bb8;
    --cs-grain-opacity: 0.035;

    --cs-label-color: #f3eee0;
    --cs-label-halo:  rgba(6, 8, 12, 0.55);
    --cs-badge-halo:  rgba(6, 8, 12, 0.75);
    --cs-badge-ink:   #f3eee0;
    --cs-callout-bg:  rgba(9, 11, 16, 0.96);
    --cs-callout-ink: #f3eee0;
    --cs-dim-node:    rgba(70, 65, 55, 0.45);
    --cs-dim-edge:    rgba(80, 70, 55, 0.04);
  }
  [data-theme="light"] {
    --cs-panel-bg:    color-mix(in srgb, var(--bg-rise) 92%, transparent);
    --cs-grain-opacity: 0.02;

    --cs-label-color: #2a241a;
    --cs-label-halo:  rgba(251, 250, 246, 0.92);
    --cs-badge-halo:  rgba(251, 250, 246, 0.95);
    --cs-badge-ink:   #2a241a;
    --cs-callout-bg:  rgba(251, 250, 246, 0.98);
    --cs-callout-ink: #2a241a;
    --cs-dim-node:    rgba(150, 140, 120, 0.45);
    --cs-dim-edge:    rgba(120, 100, 70, 0.04);
  }
</style>

<style>
  /* `.cs-main` is set on <main> by Base.astro, so the selector needs to
     pierce Astro's scope — otherwise the scoped-attribute selector won't
     match (Base's template doesn't carry this page's data-astro-cid) and
     the desktop fixed-position layout silently breaks. */
  :global(.cs-main) {
    padding-bottom: 0;
  }

  .cs-page-head {
    padding: 18px var(--rail) 14px;
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .cs-page-head h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(22px, 1.4rem + 0.6vw, 30px);
    margin: 4px 0;
    letter-spacing: 0.005em;
  }
  .cs-page-head .cs-lede {
    margin: 0;
    max-width: 62ch;
    color: var(--ink-soft);
    font-size: 14px;
    font-style: italic;
  }

  .cs-page-foot {
    padding: 12px var(--rail);
    border-top: 1px solid var(--rule);
    color: var(--ink-soft);
    font-size: 12.5px;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .cs-page-foot .cs-meth { max-width: 72ch; }
  .cs-page-foot .cs-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
  }

  @media (min-width: 701px) {
    :global(html.cs-js body) { overflow: hidden; }
    :global(html.cs-js .cs-main) {
      position: fixed;
      left: 0;
      right: 0;
      top: var(--cs-header-top, 56px);
      bottom: 0;
      display: flex;
      flex-direction: column;
    }
    :global(html.cs-js) .cs-page-head { flex: 0 0 auto; }
    :global(html.cs-js) .cs-page-foot { flex: 0 0 auto; }
  }

  /* Footer holds methodology prose + counts — both are *content*, not
     graph chrome. Stack on phones (≤700 px) where the page is in mobile
     list flow; flow side-by-side on desktop regardless of JS, so the
     no-JS surface still presents the same two columns. */
  .cs-page-foot {
    flex-direction: column;
    gap: 8px;
  }
  @media (min-width: 701px) {
    .cs-page-foot {
      flex-direction: row;
      gap: 24px;
    }
  }

  :global(.cs-load-error) {
    padding: 24px;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 13px;
  }
</style>

<script is:inline>
  // Same inline shell as the RU page: add `cs-js` ASAP and measure the
  // sticky header so `.cs-main` slots directly under it on desktop.
  (function () {
    document.documentElement.classList.add("cs-js");
    function update() {
      const header = document.querySelector("header.rail");
      if (!header) return;
      const h = header.getBoundingClientRect().height;
      document.documentElement.style.setProperty("--cs-header-top", h + "px");
    }
    update();
    window.addEventListener("resize", update);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(update);
    }
  })();
</script>
