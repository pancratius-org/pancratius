---
// /en/conceptosphere/ — the English-locale corpus map.
//
// Same components and theme system as the RU page, but the EN payloads are the
// RU topology joined with the authored overlay (data/conceptosphere-i18n/en.json)
// at build time, so concept and community labels render in English. Book titles
// localise where an English work pair exists; RU-only books degrade to a
// "Russian original" badge + RU link.

import type { Locale } from "@/lib/i18n";

import ConceptospherePage from "@/components/conceptosphere/ConceptospherePage.astro";
import { loadConceptospherePageData } from "@/components/conceptosphere/page-data";
import { conceptosphereAlternate, conceptosphereSeo } from "@/components/conceptosphere/page-seo";
import { conceptosphereStrings } from "@/components/conceptosphere/strings";

const locale: Locale = "en";
const t = conceptosphereStrings(locale);
const seo = conceptosphereSeo(locale);
const initialMode: "concepts" | "books" = "concepts";
const graphData = await loadConceptospherePageData(locale, t);
---
<ConceptospherePage
  {locale}
  {seo}
  alternates={conceptosphereAlternate(locale)}
  conceptsUrl="/data/pancratius-concepts-graph.en.json"
  booksUrl="/data/pancratius-books-graph.en.json"
  {initialMode}
  modeCounts={graphData.modeCounts}
  bookSlugInfo={graphData.bookSlugInfo}
  coverUrls={graphData.coverUrls}
  booksIndexHref={graphData.booksIndexHref}
  conceptSections={graphData.conceptSections}
  bookSections={graphData.bookSections}
/>
