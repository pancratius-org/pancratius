---
import type { GetStaticPaths } from "astro";

import ProjectPage from "@/components/ProjectPage.astro";
import { getPairsByKind } from "@/lib/works";

export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("project");
  return pairs
    .filter(p => p.en !== null)
    .map(p => ({ params: { slug: p.en!.data.slug }, props: { pair: p } }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<ProjectPage pair={pair} locale="en" />
