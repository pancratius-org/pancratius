---
import type { GetStaticPaths } from "astro";

import ProjectPage from "@/components/ProjectPage.astro";
import { getProjects } from "@/lib/projects";

// Existence rule: only emit `/en/projects/<slug>/` for projects with an
// authored EN landing. EN landings are currently deleted (RU-under-EN bug), so
// this returns [] today — by design — and never renders RU body under /en/.
export const getStaticPaths = (async () => {
  const projects = await getProjects("en");
  return projects.map(p => ({
    params: { slug: p.data.slug },
    props: { project: p },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
---
<ProjectPage project={project} locale="en" />
