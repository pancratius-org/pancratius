---
import type { GetStaticPaths } from "astro";

import BookPage from "@/components/BookPage.astro";
import { displayWorkEntry, getPairsByKind, localizedWorkPairs } from "@/lib/works";

// CORRECT: existence is gated on the authored EN entry; params come from that
// entry. `displayWorkEntry` is used here ONLY for DISPLAY props — both forms:
//   - directly in a `props:` value, and
//   - via `const display = displayWorkEntry(...)` referenced only in `props:`.
// The display-fallback value never reaches `params` or a `.filter`, so PAN002
// must stay SILENT. (Regression test for the over-broad false positive.)
export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("book");
  return localizedWorkPairs(pairs, "en")
    .map(({ pair, entry }) => {
      const display = displayWorkEntry(pair, "en");
      return {
        params: { slug: entry.data.slug },
        props: { pair, display, inline: displayWorkEntry(pair, "en") },
      };
    });
}) satisfies GetStaticPaths;

const { pair, display } = Astro.props;
---
<BookPage pair={pair} display={display} locale="en" />
