---
import type { GetStaticPaths } from "astro";

import PoemPage from "@/components/PoemPage.astro";
import { displayWorkEntry, getPairsByKind, localizedWorkPairs } from "@/lib/works";

// CORRECT, and a regression test for branch-(b) shadowing: the selector is bound
// to `entry` for a DISPLAY value (featuredTitle, handed to props), while the map
// loop REUSES the name `entry` as the pair — and that inner `entry` is what feeds
// params. Existence is gated through `localizedWorkPairs`; params come from the EN entry.
// PAN002 must stay SILENT (the selector's value never reaches params).
export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("poem");
  const entry = displayWorkEntry(pairs[0], "en");
  const featuredTitle = entry.entry.data.title;
  return localizedWorkPairs(pairs, "en")
    .map(entry => ({
      params: { slug: entry.entry.data.slug },
      props: { pair: entry.pair, featuredTitle },
    }));
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<PoemPage pair={pair} locale="en" />
