{
  "name": "pancratius",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Pancratius — open-access library of Sergey Orekhov's spiritual writings",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev": "npm run prebuild && node --experimental-strip-types build/sync-pagefind-dev.ts && astro dev",
    "build": "npm run prebuild && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "npm run prebuild && astro check",
    "astro": "astro",
    "search:index": "pagefind --site dist",
    "test:smoke": "playwright test",
    "test:unit": "node --experimental-strip-types --test \"tests/unit/*.test.ts\"",
    "test:visual": "VISUAL_AUDIT=1 playwright test tests/e2e/visual_audit.spec.ts",
    "test:perf": "node --experimental-strip-types tests/visual/lighthouse-report.ts",
    "shots:audit": "node --experimental-strip-types tests/visual/capture-fullpage.ts",
    "shots:viewport": "node --experimental-strip-types tests/visual/capture-viewports.ts",
    "shots:projects": "node --experimental-strip-types tests/visual/capture-projects.ts",
    "lint": "eslint \"{src,build,audit,tests}/**/*.{ts,tsx,astro,js,mjs,cjs}\"",
    "lint:css": "stylelint \"src/**/*.{astro,css}\"",
    "dead": "knip",
    "check:js": "npm run typecheck:tooling && npm run lint && npm run lint:css && npm run dead && npm run test:unit",
    "typecheck:tooling": "tsc -p tsconfig.tooling.json",
    "check:ts": "npm run typecheck:tooling && npm run test:unit",
    "check:py": "uv run ruff check . && uv run ty check && uv run pytest tests/python -q",
    "audit": "node --experimental-strip-types audit/harness.ts",
    "audit:agent": "node --experimental-strip-types audit/harness.ts agent",
    "audit:post-build": "node --experimental-strip-types audit/harness.ts post-build",
    "audit:selftest": "node --experimental-strip-types audit/selftest.ts",
    "verify": "npm audit --audit-level=high && npm run check:js && npm run check && npm run check:py && npm run audit && npm run audit:selftest && npm run build && npm run audit:post-build",
    "prebuild": "npm run prebuild:slug-map && npm run prebuild:graph-payloads && npm run prebuild:bulk-archives",
    "prebuild:slug-map": "node --experimental-strip-types build/slug-map.ts",
    "prebuild:graph-payloads": "node --experimental-strip-types build/copy-graph-payloads.ts",
    "prebuild:bulk-archives": "node --experimental-strip-types build/bulk-archives.ts"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.3.8",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.5",
    "sigma": "^3.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "knip": "^6.14.2",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
