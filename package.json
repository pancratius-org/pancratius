{
  "name": "pancratius",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Pancratius — open-access library of Sergey Orekhov's spiritual writings",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "npm run prebuild && uv run scripts/sync_pagefind_dev.py && astro dev",
    "build": "npm run prebuild && astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "npm run prebuild && astro check",
    "astro": "astro",
    "search:index": "pagefind --site dist",
    "test:smoke": "playwright test",
    "test:unit": "node --experimental-strip-types --test \"scripts/visual/*.test.ts\"",
    "test:visual": "VISUAL_AUDIT=1 playwright test visual_audit.spec.ts",
    "test:perf": "node --experimental-strip-types scripts/visual/lighthouse.ts",
    "shots:audit": "node --experimental-strip-types scripts/visual/audit.ts",
    "shots:viewport": "node --experimental-strip-types scripts/visual/viewport.ts",
    "shots:projects": "node --experimental-strip-types scripts/visual/shots.ts",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "lint:py": "uv run ruff check .",
    "typecheck:py": "uv run ty check",
    "check:py": "uv run ruff check . && uv run ty check",
    "audit": "node --experimental-strip-types scripts/audit/harness.ts",
    "audit:agent": "node --experimental-strip-types scripts/audit/harness.ts agent",
    "audit:deploy": "node --experimental-strip-types scripts/audit/harness.ts deploy",
    "audit:selftest": "node --experimental-strip-types scripts/audit/selftest.ts",
    "prebuild": "npm run prebuild:slug-map && npm run prebuild:graph-payloads && npm run prebuild:bulk-archives",
    "prebuild:slug-map": "uv run scripts/build_slug_map.py",
    "prebuild:graph-payloads": "uv run scripts/build_copy_graph_payloads.py",
    "prebuild:bulk-archives": "node --experimental-strip-types scripts/build_bulk_archives.ts"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "typescript": "^6.0.3"
  }
}
