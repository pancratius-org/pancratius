{
  "name": "pancratius",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Pancratius — open-access library of Sergey Orekhov's spiritual writings",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=24.12.0"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "npm run generate && node build/sync-pagefind-dev.ts && astro dev",
    "build": "npm run generate && npm run build:site && npm run build:search-index",
    "build:site": "astro build",
    "build:search-index": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "generate": "npm run generate:slug-map && npm run generate:graph-payloads && npm run generate:bulk-archives",
    "generate:slug-map": "node build/slug-map.ts",
    "generate:graph-payloads": "node build/copy-graph-payloads.ts",
    "generate:bulk-archives": "node build/bulk-archives.ts",
    "lint": "npm run lint:code && npm run lint:style",
    "lint:code": "eslint \"{src,build,audit,tests}/**/*.{ts,tsx,astro,js,mjs,cjs}\"",
    "lint:style": "stylelint \"src/**/*.{astro,css}\"",
    "typecheck:tooling": "tsc -p tsconfig.tooling.json",
    "check:unused": "knip",
    "check:code": "npm run typecheck:tooling && npm run lint && npm run check:unused && npm run test:unit",
    "check:site": "npm run generate && astro check",
    "check:py": "uv run ruff check . && uv run ty check && uv run pytest tests/python -q",
    "check": "npm run check:code && npm run check:site && npm run check:py",
    "test": "npm run test:unit",
    "test:unit": "node --test \"tests/unit/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:visual": "VISUAL_AUDIT=1 playwright test tests/e2e/visual_audit.spec.ts",
    "test:perf": "node tests/visual/lighthouse-report.ts",
    "shots:audit": "node tests/visual/capture-fullpage.ts",
    "shots:viewport": "node tests/visual/capture-viewports.ts",
    "shots:projects": "node tests/visual/capture-projects.ts",
    "audit:deps": "npm audit --audit-level=high",
    "audit:repo": "node audit/harness.ts",
    "audit:agent": "node audit/harness.ts agent",
    "audit:post-build": "node audit/harness.ts post-build",
    "audit:selftest": "node audit/selftest.ts",
    "verify": "npm run audit:deps && npm run check && npm run audit:repo && npm run audit:selftest && npm run build && npm run audit:post-build"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.3.8",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.5",
    "sigma": "^3.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "knip": "^6.14.2",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
