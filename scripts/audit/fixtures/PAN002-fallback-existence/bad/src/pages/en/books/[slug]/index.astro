---
import type { GetStaticPaths } from "astro";

import BookPage from "@/components/BookPage.astro";
import { getPairsByKind } from "@/lib/works";
import { entryForLocale } from "@/lib/works";

// BUG: getStaticPaths uses the display-fallback selector to build params/props,
// so an `/en/…` route is emitted even for a pair with no authored EN entry.
export const getStaticPaths = (async () => {
  const pairs = await getPairsByKind("book");
  return pairs.map(p => {
    const entry = entryForLocale(p, "en");
    return { params: { slug: entry.data.slug }, props: { pair: p } };
  });
}) satisfies GetStaticPaths;

const { pair } = Astro.props;
---
<BookPage pair={pair} locale="en" />
